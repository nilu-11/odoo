<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Program Term — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_program_term_search" model="ir.ui.view">
        <field name="name">edu.program.term.search</field>
        <field name="model">edu.program.term</field>
        <field name="arch" type="xml">
            <search string="Program Terms">
                <field name="program_id"/>
                <field name="progression_no" string="Progression No."/>
                <filter string="Final Progressions" name="final"
                        domain="[('is_final_progression', '=', True)]"/>
                <separator/>
                <filter string="Archived" name="archived"
                        domain="[('active', '=', False)]"/>
                <group name="group_by">
                    <filter string="Program"    name="group_program"
                            context="{'group_by': 'program_id'}"/>
                    <filter string="Department" name="group_dept"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Company"    name="group_company"
                            context="{'group_by': 'company_id'}"
                            groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Program Term — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_program_term_list" model="ir.ui.view">
        <field name="name">edu.program.term.list</field>
        <field name="model">edu.program.term</field>
        <field name="arch" type="xml">
            <list string="Program Terms"
                  decoration-success="is_final_progression == True">
                <field name="sequence" widget="handle"/>
                <field name="program_id"/>
                <field name="progression_no" string="Prog. No."/>
                <field name="progression_label"/>
                <field name="is_final_progression" string="Final" widget="boolean_toggle"/>
                <field name="curriculum_count" string="Subjects"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Program Term — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_program_term_form" model="ir.ui.view">
        <field name="name">edu.program.term.form</field>
        <field name="model">edu.program.term</field>
        <field name="arch" type="xml">
            <form string="Program Term">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_curriculum"
                                icon="fa-book">
                            <field name="curriculum_count" widget="statinfo"
                                   string="Subjects"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Program Term"/>
                        <h1>
                            <field name="name"
                                   placeholder="Auto-computed after saving"/>
                        </h1>
                        <h3 class="text-muted">
                            <field name="code"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Program">
                            <field name="program_id"/>
                            <field name="department_id" readonly="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Progression">
                            <field name="progression_no"/>
                            <field name="progression_label"/>
                            <field name="is_final_progression" readonly="1"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Curriculum" name="curriculum">
                            <field name="curriculum_line_ids"
                                   context="{'default_program_term_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="subject_id"/>
                                    <field name="subject_type" readonly="1"/>
                                    <field name="subject_category"/>
                                    <field name="credit_hours"/>
                                    <field name="full_marks"/>
                                    <field name="pass_marks"/>
                                    <field name="active" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Program Term — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_program_term" model="ir.actions.act_window">
        <field name="name">Program Terms</field>
        <field name="res_model">edu.program.term</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_program_term_search"/>
        <field name="context">{'search_default_group_program': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define program progression stages
            </p>
            <p>
                Each record represents a reusable progression stage for a program
                (e.g. "Semester 1", "Semester 2", ..., "Semester 8" for a 4-year BCS).
                Use the "Generate Progressions" button on the Program form to auto-create them.
            </p>
        </field>
    </record>
</odoo>
