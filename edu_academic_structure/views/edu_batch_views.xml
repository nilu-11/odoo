<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Batch — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_batch_search" model="ir.ui.view">
        <field name="name">edu.batch.search</field>
        <field name="model">edu.batch</field>
        <field name="arch" type="xml">
            <search string="Batches">
                <field name="name" string="Batch Name/Code" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="program_id"/>
                <field name="academic_year_id"/>
                <filter string="Draft"  name="draft"  domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active_state" domain="[('state', '=', 'active')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group name="group_by">
                    <filter string="Academic Year" name="group_year"    context="{'group_by': 'academic_year_id'}"/>
                    <filter string="Program"       name="group_program" context="{'group_by': 'program_id'}"/>
                    <filter string="Status"        name="group_state"   context="{'group_by': 'state'}"/>
                    <filter string="Company"       name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Batch — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_batch_list" model="ir.ui.view">
        <field name="name">edu.batch.list</field>
        <field name="model">edu.batch</field>
        <field name="arch" type="xml">
            <list string="Batches" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-warning="state == 'closed'">
                <field name="name"/>
                <field name="code"/>
                <field name="program_id"/>
                <field name="academic_year_id"/>
                <field name="intake_name"/>
                <field name="capacity"/>
                <field name="section_count" string="Sections"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-warning="state == 'closed'"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Batch — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_batch_form" model="ir.ui.view">
        <field name="name">edu.batch.form</field>
        <field name="model">edu.batch</field>
        <field name="arch" type="xml">
            <form string="Batch">
                <header>
                    <button name="action_activate"
                            string="Activate"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="edu_academic_structure.group_education_admin,edu_academic_structure.group_academic_officer"/>
                    <button name="action_close"
                            string="Close Batch"
                            type="object"
                            invisible="state != 'active'"
                            groups="edu_academic_structure.group_education_admin"/>
                    <button name="action_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'closed'"
                            groups="edu_academic_structure.group_education_admin"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-th-large"
                                type="object" name="action_view_sections"
                                invisible="section_count == 0">
                            <field name="section_count" widget="statinfo" string="Sections"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" placeholder="Auto-generated"/>
                        </h1>
                        <h3 class="text-muted">
                            <field name="code" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Batch Details">
                            <field name="program_id"
                                   readonly="state != 'draft'"/>
                            <field name="academic_year_id"
                                   readonly="state != 'draft'"/>
                            <field name="intake_name" placeholder="e.g. Fall, Spring, Jan (optional)"
                                   readonly="state != 'draft'"/>
                            <field name="capacity"
                                   readonly="state == 'closed'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Progression &amp; Period">
                            <field name="current_program_term_id"
                                   readonly="state == 'closed'"/>
                            <field name="start_date"
                                   readonly="state == 'closed'"/>
                            <field name="end_date"
                                   readonly="state == 'closed'"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Optional notes..."/>
                    </group>
                    <notebook>
                        <page string="Sections" name="sections">
                            <field name="section_ids" context="{'default_batch_id': id}"
                                   readonly="state == 'closed'">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="capacity"/>
                                    <field name="active" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Batch — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_batch" model="ir.actions.act_window">
        <field name="name">Batches</field>
        <field name="res_model">edu.batch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_batch_search"/>
        <field name="context">{'search_default_group_year': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first batch</p>
            <p>A batch is an intake cohort of a program in a specific academic year.</p>
        </field>
    </record>
</odoo>
