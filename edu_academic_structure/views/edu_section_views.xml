<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Section — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_section_search" model="ir.ui.view">
        <field name="name">edu.section.search</field>
        <field name="model">edu.section</field>
        <field name="arch" type="xml">
            <search string="Sections">
                <field name="name" string="Name/Code" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="batch_id"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group name="group_by">
                    <filter string="Batch" name="group_batch" context="{'group_by': 'batch_id'}"/>
                    <!-- <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/> -->
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Section — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_section_list" model="ir.ui.view">
        <field name="name">edu.section.list</field>
        <field name="model">edu.section</field>
        <field name="arch" type="xml">
            <list string="Sections">
                <field name="full_label" string="Section"/>
                <field name="name"/>
                <field name="code"/>
                <field name="batch_id"/>
                <field name="capacity"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Section — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_section_form" model="ir.ui.view">
        <field name="name">edu.section.form</field>
        <field name="model">edu.section</field>
        <field name="arch" type="xml">
            <form string="Section">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="full_label" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="batch_id"/>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="capacity"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Section — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_section" model="ir.actions.act_window">
        <field name="name">Sections</field>
        <field name="res_model">edu.section</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_section_search"/>
        <field name="context">{'search_default_group_batch': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create sections for your batches</p>
            <p>Sections divide a batch into smaller class groups, e.g. Section A, Section B.</p>
        </field>
    </record>
</odoo>
