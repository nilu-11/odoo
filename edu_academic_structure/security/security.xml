<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ======================================================
         Module Category (ir.module.category)
    ====================================================== -->
    <record id="module_category_education" model="ir.module.category">
        <field name="name">Education</field>
        <field name="sequence">20</field>
    </record>

    <!-- ======================================================
         Privilege (res.groups.privilege)
         New in Odoo 19: groups are organised under a Privilege,
         which in turn belongs to a module category.
    ====================================================== -->
    <record id="privilege_education_access" model="res.groups.privilege">
        <field name="name">Education Access</field>
        <field name="description">Controls access levels for the Education module.</field>
        <field name="placeholder">No access</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_education"/>
    </record>

    <!-- ======================================================
         Security Groups (res.groups)
         Hierarchy: Admin → Officer → Viewer
         Each higher group implies the one below it.
    ====================================================== -->

    <!-- Academic Viewer: read-only access -->
    <record id="group_academic_viewer" model="res.groups">
        <field name="name">Viewer</field>
        <field name="privilege_id" ref="privilege_education_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Read-only access to all Education records.</field>
    </record>

    <!-- Academic Officer: create and edit, cannot delete or manage security -->
    <record id="group_academic_officer" model="res.groups">
        <field name="name">Officer</field>
        <field name="privilege_id" ref="privilege_education_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_academic_viewer'))]"/>
        <field name="comment">Can create and modify academic records. Cannot delete or manage security.</field>
    </record>

    <!-- Education Admin: full CRUD on all education models -->
    <record id="group_education_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="privilege_education_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_academic_officer'))]"/>
        <field name="comment">Full access to all Education records including configuration and deletion.</field>
    </record>

