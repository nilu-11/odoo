<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_my_project_list" model="ir.ui.view">
        <field name="name">my.project.list</field>
        <field name="model">my.project</field>
        <field name="arch" type="xml">
            <list string="Projects">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="task_count"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_my_project_form" model="ir.ui.view">
        <field name="name">my.project.form</field>
        <field name="model">my.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>

                    <!-- Embedded task list (the one2many widget) -->
                    <notebook>
                        <page string="Tasks">
                            <field name="task_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="deadline"/>
                                    <field name="priority"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban view -->
    <record id="view_my_project_kanban" model="ir.ui.view">
        <field name="name">my.project.kanban</field>
        <field name="model">my.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="sequence"/>
                <field name="name"/>
                <field name="state"/>
                <field name="task_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="task_count"/> tasks
                            </div>
                            <div>
                                <field name="state"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action (ties all views together) -->
    <record id="action_my_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">my.project</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>