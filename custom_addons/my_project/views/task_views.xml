<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_my_task_list" model="ir.ui.view">
        <field name="name">my.task.list</field>
        <field name="model">my.task</field>
        <field name="arch" type="xml">
            <list string="Tasks" open_form_view="true">
                <field name="name"/>
                <field name="project_id"/>
                <field name="deadline"/>
                <field name="priority"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_my_task_form" model="ir.ui.view">
        <field name="name">my.task.form</field>
        <field name="model">my.task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="state"/>
                        <field name="priority"/>
                        <field name="deadline"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_my_task_kanban" model="ir.ui.view">
        <field name="name">my.task.kanban</field>
        <field name="model">my.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="project_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="project_id"/>
                            </div>
                            <div>
                                Priority: <field name="priority"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_my_task" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">my.task</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>