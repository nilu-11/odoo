<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Privilege
    ══════════════════════════════════════════════════════ -->
    <record id="privilege_assessment_access" model="res.groups.privilege">
        <field name="name">Continuous Assessment</field>
        <field name="category_id" ref="edu_academic_structure.module_category_education"/>
        <field name="sequence">85</field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Groups
    ══════════════════════════════════════════════════════ -->
    <record id="group_assessment_viewer" model="res.groups">
        <field name="name">Viewer</field>
        <field name="privilege_id" ref="privilege_assessment_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_assessment_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="privilege_id" ref="privilege_assessment_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_assessment_viewer'))]"/>
    </record>

    <record id="group_assessment_officer" model="res.groups">
        <field name="name">Assessment Officer</field>
        <field name="privilege_id" ref="privilege_assessment_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_assessment_teacher'))]"/>
    </record>

    <record id="group_assessment_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="privilege_assessment_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_assessment_officer'))]"/>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Record Rules
    ══════════════════════════════════════════════════════ -->

    <!-- Teacher: can read/write assessment records for their own classroom or
         where they are the teacher_id.  Cannot create (wizard does that) or
         delete. -->
    <record id="rule_assessment_record_teacher" model="ir.rule">
        <field name="name">Assessment Record: Teacher sees own classroom</field>
        <field name="model_id" ref="model_edu_continuous_assessment_record"/>
        <field name="domain_force">
            ['|',
              ('teacher_id', '=', user.id),
              ('classroom_id.teacher_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('group_assessment_teacher'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Officer / Admin: see all records -->
    <record id="rule_assessment_record_officer" model="ir.rule">
        <field name="name">Assessment Record: Officer sees all</field>
        <field name="model_id" ref="model_edu_continuous_assessment_record"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_assessment_officer'))]"/>
    </record>
</odoo>
