<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add assessment smart buttons to edu.classroom form -->
    <record id="view_edu_classroom_form_assessment_button" model="ir.ui.view">
        <field name="name">edu.classroom.form.assessment.button</field>
        <field name="model">edu.classroom</field>
        <field name="inherit_id" ref="edu_classroom.view_edu_classroom_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_assessments" type="object"
                        class="oe_stat_button" icon="fa-bar-chart"
                        groups="edu_assessment.group_assessment_viewer,edu_academic_structure.group_education_admin">
                    <field name="assessment_record_count" widget="statinfo"
                           string="Assessments"/>
                </button>
                <button name="action_new_assessment" type="object"
                        class="oe_stat_button" icon="fa-plus-circle"
                        invisible="state != 'active'"
                        groups="edu_assessment.group_assessment_teacher,edu_assessment.group_assessment_officer,edu_assessment.group_assessment_admin,edu_academic_structure.group_education_admin">
                    <div class="o_stat_info">
                        <span class="o_stat_text">New Assessment</span>
                    </div>
                </button>
                <button name="action_pending_assessments" type="object"
                        class="oe_stat_button" icon="fa-clock-o"
                        invisible="assessment_pending_count == 0"
                        groups="edu_assessment.group_assessment_teacher,edu_assessment.group_assessment_officer,edu_assessment.group_assessment_admin,edu_academic_structure.group_education_admin">
                    <field name="assessment_pending_count" widget="statinfo"
                           string="Pending"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
