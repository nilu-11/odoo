<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         edu.continuous.assessment.record — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_continuous_assessment_record_search" model="ir.ui.view">
        <field name="name">edu.continuous.assessment.record.search</field>
        <field name="model">edu.continuous.assessment.record</field>
        <field name="arch" type="xml">
            <search string="Search Assessments">
                <field name="name"/>
                <field name="student_id"/>
                <field name="category_id"/>
                <field name="classroom_id"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="academic_year_id"/>
                <!-- State filters -->
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_pending" string="Pending (Draft)"
                        domain="[('state', '=', 'draft')]"/>
                <separator/>
                <filter name="filter_contributes" string="Contributes to Result"
                        domain="[('category_id.contributes_to_result', '=', True)]"/>
                <filter name="filter_my_assessments" string="My Assessments"
                        domain="[('teacher_id.user_id', '=', uid)]"/>
                <separator/>
                <filter name="filter_archived" string="Archived"
                        domain="[('active', '=', False)]"/>
                <!-- Group By -->
                <group name="group_by">
                    <filter name="group_classroom" string="Classroom"
                            context="{'group_by': 'classroom_id'}"/>
                    <filter name="group_subject" string="Subject"
                            context="{'group_by': 'subject_id'}"/>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_category_type" string="Category Type"
                            context="{'group_by': 'category_type'}"/>
                    <filter name="group_teacher" string="Teacher"
                            context="{'group_by': 'teacher_id'}"/>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'assessment_date:month'}"/>
                    <filter name="group_section" string="Section"
                            context="{'group_by': 'section_id'}"/>
                    <filter name="group_program_term" string="Program Term"
                            context="{'group_by': 'program_term_id'}"/>
                    <filter name="group_academic_year" string="Academic Year"
                            context="{'group_by': 'academic_year_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.continuous.assessment.record — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_continuous_assessment_record_list" model="ir.ui.view">
        <field name="name">edu.continuous.assessment.record.list</field>
        <field name="model">edu.continuous.assessment.record</field>
        <field name="arch" type="xml">
            <list string="Assessment Records"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'confirmed'"
                  editable="bottom">
                <field name="assessment_date"/>
                <field name="name"/>
                <field name="student_id"/>
                <field name="category_id"/>
                <field name="classroom_id" optional="show"/>
                <field name="subject_id" optional="show"/>
                <field name="section_id" optional="hide"/>
                <field name="teacher_id" optional="hide"/>
                <field name="max_marks" sum="Max Marks"/>
                <field name="marks_obtained" sum="Total Marks"/>
                <field name="percentage" widget="progressbar"
                       options="{'editable': false, 'current_value': 'percentage', 'max_value': 100}"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
                <!-- Inline confirm button -->
                <button name="action_confirm" type="object" string="Confirm"
                        icon="fa-check" invisible="state != 'draft'"
                        groups="edu_assessment.group_assessment_teacher"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.continuous.assessment.record — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_continuous_assessment_record_form" model="ir.ui.view">
        <field name="name">edu.continuous.assessment.record.form</field>
        <field name="model">edu.continuous.assessment.record</field>
        <field name="arch" type="xml">
            <form string="Assessment Record">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="edu_assessment.group_assessment_teacher,edu_academic_structure.group_education_admin"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'confirmed'"
                            groups="edu_assessment.group_assessment_admin,edu_academic_structure.group_education_admin"/>
                    <button name="action_snapshot_attendance" string="Snapshot Attendance" type="object"
                            invisible="category_type != 'attendance_score'"
                            groups="edu_assessment.group_assessment_teacher,edu_academic_structure.group_education_admin"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Assessment Title (e.g. Assignment 1)"
                                   readonly="state == 'confirmed'"/>
                        </h1>
                        <h2>
                            <field name="display_name" readonly="1"/>
                        </h2>
                    </div>

                    <group>
                        <group string="Assessment">
                            <field name="category_id" readonly="state == 'confirmed'"/>
                            <field name="category_type" readonly="1"/>
                            <field name="assessment_date" readonly="state == 'confirmed'"/>
                            <field name="teacher_id" readonly="state == 'confirmed'"/>
                        </group>
                        <group string="Student">
                            <field name="student_id" readonly="state == 'confirmed'"/>
                        </group>
                    </group>

                    <group>
                        <group string="Marks">
                            <field name="max_marks" readonly="state == 'confirmed'"/>
                            <field name="marks_obtained" readonly="state == 'confirmed'"/>
                            <field name="percentage" readonly="1" widget="progressbar"
                                   options="{'editable': false, 'current_value': 'percentage', 'max_value': 100}"/>
                        </group>
                        <group string="Class Context">
                            <field name="classroom_id" readonly="state == 'confirmed'"/>
                            <field name="subject_id" readonly="1"/>
                            <field name="section_id" readonly="1"/>
                            <field name="program_term_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Academic Snapshot" name="snapshot">
                            <group string="Stored Academic Context (Snapshot)">
                                <group>
                                    <field name="enrollment_id" readonly="1"/>
                                    <field name="student_progression_history_id" readonly="1"/>
                                    <field name="batch_id" readonly="1"/>
                                    <field name="section_id" readonly="1"/>
                                </group>
                                <group>
                                    <field name="program_term_id" readonly="1"/>
                                    <field name="curriculum_line_id" readonly="1"/>
                                    <field name="academic_year_id" readonly="1"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </group>
                            </group>
                        </page>
                        <page string="Remarks" name="remarks">
                            <field name="remarks" placeholder="Observations, notes, or feedback..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Actions
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_continuous_assessment_record_all" model="ir.actions.act_window">
        <field name="name">Assessment Records</field>
        <field name="res_model">edu.continuous.assessment.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_pending': 0}</field>
    </record>

    <record id="action_edu_continuous_assessment_record_mine" model="ir.actions.act_window">
        <field name="name">My Assessments</field>
        <field name="res_model">edu.continuous.assessment.record</field>
        <field name="view_mode">list,form</field>
        <!--
            teacher_id is m2o to hr.employee (edu_hr override), so the
            teacher filter must traverse teacher_id.user_id. The default
            teacher context is intentionally omitted; it must be resolved
            to the current user's employee record via an onchange or at
            create time, not via a plain uid substitution.
        -->
        <field name="domain">[('teacher_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_filter_my_assessments': 1}</field>
    </record>

    <record id="action_edu_continuous_assessment_record_pending" model="ir.actions.act_window">
        <field name="name">Draft Assessments</field>
        <field name="res_model">edu.continuous.assessment.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'draft')]</field>
    </record>

    <!-- Bulk confirm server action — accessible from list view action menu -->
    <record id="action_edu_assessment_bulk_confirm" model="ir.actions.server">
        <field name="name">Confirm Selected</field>
        <field name="model_id" ref="model_edu_continuous_assessment_record"/>
        <field name="binding_model_id" ref="model_edu_continuous_assessment_record"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_bulk_confirm()</field>
    </record>
</odoo>
