<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_hospital_patient" model="ir.actions.act_window"> <!-- same action we defined on menu.xml -->
        <field name="name">Patients</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            Create a new patient
            </p>
        </field>
    </record>

    <record id="view_hospital_patient_list" model="ir.ui.view">
         <field name="name">hospital.patient.list</field>
         <field name="model">hospital.patient</field>
         <field name="arch" type="xml">
             <list string="Patients">
                <field name="name"/>
                <field name="date_of_birth" optional="hide"/>  <!--enables custom field to show in the list view-->
                <field name="gender" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_patient_form" model="ir.ui.view">
         <field name="name">hospital.patient.form</field>
         <field name="model">hospital.patient</field>
         <field name="arch" type="xml">
             <form string="Patients">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date_of_birth"/>
                        </group>
                        <group>
                            <field name="gender"/>
                            <field name="tags_id" widget="many2many_tags"/>   <!--makes it appear horizontally-->
                        </group>
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_hospital_patient_kanban" model="ir.ui.view">
         <field name="name">hospital.patient.kanban</field>
         <field name="model">hospital.patient</field>
         <field name="arch" type="xml">
             <kanban string="Patients">
                <field name="name"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <templates>
                    <t t-name="card">
                         <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div>Gender: <field name="gender"/></div>
                                <div>DOB: <field name="date_of_birth"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>