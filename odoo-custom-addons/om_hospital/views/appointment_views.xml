<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_hospital_appointment" model="ir.actions.act_window"> <!-- window action linked to menu.xml -->
        <field name="name">Appointment</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            Create a new appointment
            </p>
        </field>
    </record>

    <record id="view_hospital_appointment_list" model="ir.ui.view">
         <field name="name">hospital.appointment.list</field>
         <field name="model">hospital.appointment</field>
         <field name="arch" type="xml">
             <list string="Appointment">
                <field name="reference"/>
                <field name="patient_id"/>
                <field name="date_appointment"/>  <!--enables custom field to show in the list view-->
            </list>
        </field>
    </record>

    <record id="view_hospital_appointment_form" model="ir.ui.view">
         <field name="name">hospital.appointment.form</field>
         <field name="model">hospital.appointment</field>
         <field name="arch" type="xml">
             <form string="Appointment">
            <header>
                <button name="action_confirm" type="object" string="Confirm" invisible="state!='draft'" class="oe_highlight"/>
                <button name="action_ongoing" type="object" string="Ongoing" invisible="state!='confirmed'"/>
                <button name="action_done" type="object" string="Done" invisible="state!='ongoing'"/>
                <button name="action_cancel" type="object" string="Cancel" />
                <field name="state" widget="statusbar" options="{'clickable':'1'}" statusbar_visible="draft, ongoing, confirmed, done"/>       
           </header>
                <sheet>
                    <group>
                        <group>
                            <field name="reference"/>
                            <field name="patient_id"/>
                            <field name="date_appointment"/>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_hospital_appointment_kanban" model="ir.ui.view">
         <field name="name">hospital.appointment.kanban</field>
         <field name="model">hospital.appointment</field>
         <field name="arch" type="xml">
             <kanban string="Appointment">
                <field name="patient_id"/>
                <field name="date_appointment"/>
                <templates>
                    <t t-name="card">
                         <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong><field name="patient_id"/></strong>
                                <div>Gender: <field name="date_appointment"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>