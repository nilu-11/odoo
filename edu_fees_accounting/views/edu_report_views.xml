<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════
         REPORTING VIEWS — Foundations for Finance Analysis
         Uses pivot and graph views on existing models.
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- ──────────────────────────────────────────────────────────────────
         Fee Collection Analysis (Pivot on Dues)
    ────────────────────────────────────────────────────────────────── -->
    <record id="view_edu_fee_due_pivot" model="ir.ui.view">
        <field name="name">edu.student.fee.due.pivot</field>
        <field name="model">edu.student.fee.due</field>
        <field name="arch" type="xml">
            <pivot string="Fee Collection Analysis">
                <field name="fee_head_id" type="row"/>
                <field name="program_term_id" type="row"/>
                <field name="due_amount" type="measure"/>
                <field name="paid_amount" type="measure"/>
                <field name="balance_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_edu_fee_due_graph" model="ir.ui.view">
        <field name="name">edu.student.fee.due.graph</field>
        <field name="model">edu.student.fee.due</field>
        <field name="arch" type="xml">
            <graph string="Fee Collection" type="bar">
                <field name="fee_head_id"/>
                <field name="paid_amount" type="measure"/>
                <field name="balance_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Fee Collection action -->
    <record id="action_edu_fee_collection_report" model="ir.actions.act_window">
        <field name="name">Fee Collection Analysis</field>
        <field name="res_model">edu.student.fee.due</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="edu_fees.view_edu_student_fee_due_search"/>
        <field name="domain">[('state', '!=', 'draft')]</field>
        <field name="context">{}</field>
    </record>

    <!-- ──────────────────────────────────────────────────────────────────
         Outstanding Dues Summary (Pivot)
    ────────────────────────────────────────────────────────────────── -->
    <record id="view_edu_fee_due_outstanding_pivot" model="ir.ui.view">
        <field name="name">edu.student.fee.due.outstanding.pivot</field>
        <field name="model">edu.student.fee.due</field>
        <field name="arch" type="xml">
            <pivot string="Outstanding Dues">
                <field name="enrollment_id" type="row"/>
                <field name="fee_head_id" type="col"/>
                <field name="balance_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_edu_outstanding_dues_report" model="ir.actions.act_window">
        <field name="name">Outstanding Dues</field>
        <field name="res_model">edu.student.fee.due</field>
        <field name="view_mode">pivot,list</field>
        <field name="search_view_id" ref="edu_fees.view_edu_student_fee_due_search"/>
        <field name="domain">[('state', 'in', ('due', 'partial', 'overdue')), ('balance_amount', '>', 0)]</field>
        <field name="context">{}</field>
    </record>

    <!-- ──────────────────────────────────────────────────────────────────
         Deposit Summary (Pivot on Deposit Ledger)
    ────────────────────────────────────────────────────────────────── -->
    <record id="view_edu_deposit_ledger_pivot" model="ir.ui.view">
        <field name="name">edu.deposit.ledger.pivot</field>
        <field name="model">edu.deposit.ledger</field>
        <field name="arch" type="xml">
            <pivot string="Deposit Summary">
                <field name="student_id" type="row"/>
                <field name="total_collected" type="measure"/>
                <field name="total_adjusted" type="measure"/>
                <field name="total_refunded" type="measure"/>
                <field name="balance" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_edu_deposit_summary_report" model="ir.actions.act_window">
        <field name="name">Deposit Summary</field>
        <field name="res_model">edu.deposit.ledger</field>
        <field name="view_mode">pivot,list</field>
        <field name="search_view_id" ref="view_edu_deposit_ledger_search"/>
        <field name="context">{}</field>
    </record>

    <!-- ──────────────────────────────────────────────────────────────────
         Fee Plan Summary (Pivot)
    ────────────────────────────────────────────────────────────────── -->
    <record id="view_edu_fee_plan_pivot" model="ir.ui.view">
        <field name="name">edu.student.fee.plan.pivot</field>
        <field name="model">edu.student.fee.plan</field>
        <field name="arch" type="xml">
            <pivot string="Fee Plan Summary">
                <field name="program_id" type="row"/>
                <field name="batch_id" type="row"/>
                <field name="total_original" type="measure"/>
                <field name="total_discount" type="measure"/>
                <field name="total_final" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_edu_fee_plan_report" model="ir.actions.act_window">
        <field name="name">Fee Plan Summary</field>
        <field name="res_model">edu.student.fee.plan</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="edu_fees.view_edu_student_fee_plan_search"/>
        <field name="context">{}</field>
    </record>

    <!-- ──────────────────────────────────────────────────────────────────
         Payment Analysis (Pivot on Payments)
    ────────────────────────────────────────────────────────────────── -->
    <record id="view_edu_payment_pivot" model="ir.ui.view">
        <field name="name">edu.student.payment.pivot</field>
        <field name="model">edu.student.payment</field>
        <field name="arch" type="xml">
            <pivot string="Payment Analysis">
                <field name="payment_method" type="row"/>
                <field name="payment_date" type="col" interval="month"/>
                <field name="amount" type="measure"/>
                <field name="allocated_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_edu_payment_graph" model="ir.ui.view">
        <field name="name">edu.student.payment.graph</field>
        <field name="model">edu.student.payment</field>
        <field name="arch" type="xml">
            <graph string="Payment Volume" type="bar">
                <field name="payment_date" interval="month"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_edu_payment_report" model="ir.actions.act_window">
        <field name="name">Payment Analysis</field>
        <field name="res_model">edu.student.payment</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="edu_fees.view_edu_student_payment_search"/>
        <field name="domain">[('state', '=', 'posted')]</field>
        <field name="context">{}</field>
    </record>

    <!-- ──────────────────────────────────────────────────────────────────
         Student Invoices (filtered account.move action)
    ────────────────────────────────────────────────────────────────── -->
    <record id="action_edu_student_invoices" model="ir.actions.act_window">
        <field name="name">Student Fee Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_type', 'in', ('out_invoice', 'out_refund')), ('invoice_origin', 'ilike', 'EDU-')]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No student fee invoices</p>
            <p>Invoices are created from student fee dues.</p>
        </field>
    </record>
</odoo>
