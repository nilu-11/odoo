<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Deposit Refund — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_deposit_refund_search" model="ir.ui.view">
        <field name="name">edu.deposit.refund.search</field>
        <field name="model">edu.deposit.refund</field>
        <field name="arch" type="xml">
            <search string="Deposit Refunds">
                <field name="name"/>
                <field name="student_id"/>
                <filter string="Draft" name="state_draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Submitted" name="state_submitted"
                        domain="[('state','=','submitted')]"/>
                <filter string="Approved" name="state_approved"
                        domain="[('state','=','approved')]"/>
                <filter string="Done" name="state_done"
                        domain="[('state','=','done')]"/>
                <filter string="Cancelled" name="state_cancelled"
                        domain="[('state','=','cancelled')]"/>
                <group name="group_by">
                    <filter string="Student" name="group_student"
                            context="{'group_by': 'student_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Payment Method" name="group_method"
                            context="{'group_by': 'payment_method'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'refund_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Deposit Refund — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_deposit_refund_list" model="ir.ui.view">
        <field name="name">edu.deposit.refund.list</field>
        <field name="model">edu.deposit.refund</field>
        <field name="arch" type="xml">
            <list string="Deposit Refunds"
                  decoration-info="state == 'draft'"
                  decoration-warning="state in ('submitted', 'approved')"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="student_id"/>
                <field name="refund_date"/>
                <field name="amount" sum="Total"/>
                <field name="payment_method" optional="show"/>
                <field name="approved_by" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('submitted', 'approved')"
                       decoration-success="state == 'done'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Deposit Refund — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_deposit_refund_form" model="ir.ui.view">
        <field name="name">edu.deposit.refund.form</field>
        <field name="model">edu.deposit.refund</field>
        <field name="arch" type="xml">
            <form string="Deposit Refund">
                <header>
                    <button name="action_submit" type="object"
                            string="Submit for Approval" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" type="object"
                            string="Approve" class="btn-success"
                            invisible="state != 'submitted'"
                            groups="edu_fees_accounting.group_deposit_approver"
                            confirm="Approve this deposit refund?"/>
                    <button name="action_process" type="object"
                            string="Process Refund" class="btn-primary"
                            invisible="state != 'approved'"
                            confirm="Process the refund payment?"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('done', 'cancelled')"
                            confirm="Cancel this refund?"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"
                                   placeholder="Auto-generated"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Refund Details">
                            <field name="ledger_id"
                                   readonly="state != 'draft'"/>
                            <field name="student_id"/>
                            <field name="partner_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount"
                                   readonly="state != 'draft'"/>
                            <field name="refund_date"
                                   readonly="state != 'draft'"/>
                            <field name="payment_method"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Accounting">
                            <field name="journal_id"
                                   readonly="state not in ('draft', 'submitted', 'approved')"/>
                            <field name="deposit_account_id"
                                   readonly="state not in ('draft', 'submitted', 'approved')"/>
                            <field name="account_payment_id" readonly="1"
                                   invisible="not account_payment_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" readonly="state == 'done'"
                               placeholder="Notes about this refund..."/>
                    </group>
                    <group string="Approval" invisible="not approved_by">
                        <group>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                        <group invisible="not processed_by">
                            <field name="processed_by" readonly="1"/>
                            <field name="processed_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Deposit Refund — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_deposit_refund" model="ir.actions.act_window">
        <field name="name">Deposit Refunds</field>
        <field name="res_model">edu.deposit.refund</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_deposit_refund_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No deposit refunds</p>
            <p>Deposit refunds are created from the deposit ledger.</p>
        </field>
    </record>
</odoo>
