<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Deposit Adjustment sequence -->
        <record id="seq_edu_deposit_adjustment" model="ir.sequence">
            <field name="name">Deposit Adjustment</field>
            <field name="code">edu.deposit.adjustment</field>
            <field name="prefix">DADJ/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <!-- Deposit Refund sequence -->
        <record id="seq_edu_deposit_refund" model="ir.sequence">
            <field name="name">Deposit Refund</field>
            <field name="code">edu.deposit.refund</field>
            <field name="prefix">DREF/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

    </data>
</odoo>
