<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Pre-Admission top-level menu
         Positioned after the main CRM menu.
    ══════════════════════════════════════════════════════ -->
    <menuitem id="menu_pre_admission_root"
              name="Pre-Admission"
              sequence="40"
              web_icon="edu_pre_admission_crm,static/description/icon.svg"
              groups="group_pre_admission_viewer,group_pre_admission_officer,edu_academic_structure.group_education_admin"/>

    <!-- ── Main Operational Items ──────────────────────────────────────── -->
    <menuitem id="menu_pre_admission_main"
              name="Pre-Admission"
              parent="menu_pre_admission_root"
              sequence="10"/>

    <menuitem id="menu_crm_leads_pre_admission"
              name="Inquiries &amp; Leads"
              parent="menu_pre_admission_main"
              action="action_pre_admission_pipeline"
              sequence="10"/>

    <menuitem id="menu_applicant_profiles"
              name="Applicant Profiles"
              parent="menu_pre_admission_main"
              action="action_edu_applicant_profile"
              sequence="20"/>

    <menuitem id="menu_guardians"
              name="Guardians"
              parent="menu_pre_admission_main"
              action="action_edu_guardian"
              sequence="30"
              groups="group_pre_admission_officer,edu_academic_structure.group_education_admin"/>

    <menuitem id="menu_edu_interaction_log"
              name="Interactions"
              parent="menu_pre_admission_main"
              sequence="40"
              action="action_edu_interaction_log"
              groups="group_pre_admission_viewer,group_pre_admission_officer,edu_academic_structure.group_education_admin"/>

    <menuitem id="menu_edu_counselors"
              name="Counselors"
              parent="menu_pre_admission_main"
              sequence="50"
              action="action_edu_counselors"
              groups="group_pre_admission_officer,edu_academic_structure.group_education_admin"/>

    <!-- ── Configuration ──────────────────────────────────────────────── -->
    <menuitem id="menu_pre_admission_configuration"
              name="Configuration"
              parent="menu_pre_admission_root"
              sequence="90"
              groups="group_pre_admission_officer,edu_academic_structure.group_education_admin"/>

</odoo>
