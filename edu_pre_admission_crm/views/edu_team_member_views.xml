<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         Team Member — Form View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_team_member_form" model="ir.ui.view">
        <field name="name">edu.team.member.form</field>
        <field name="model">edu.team.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image_128" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Full Name"/></h1>
                        <!-- <field name="job_title" placeholder="Job Title" class="text-muted"/> -->
                    </div>
                    <group>
                        <group string="Contact Details">
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                        </group>
                      
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Team Member — List View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_team_member_list" model="ir.ui.view">
        <field name="name">edu.team.member.list</field>
        <field name="model">edu.team.member</field>
        <field name="arch" type="xml">
            <list string="Team Members">
                <field name="name"/>
                <field name="phone" widget="phone"/>
                <field name="email" widget="email"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Team Member — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_team_member" model="ir.actions.act_window">
        <field name="name">Team</field>
        <field name="res_model">edu.team.member</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="context">{'active_test': False}</field> -->
    </record>

</odoo>
