<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Relationship Type — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_relationship_type_list" model="ir.ui.view">
        <field name="name">edu.relationship.type.list</field>
        <field name="model">edu.relationship.type</field>
        <field name="arch" type="xml">
            <list string="Relationship Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description" optional="show"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Relationship Type — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_relationship_type_form" model="ir.ui.view">
        <field name="name">edu.relationship.type.form</field>
        <field name="model">edu.relationship.type</field>
        <field name="arch" type="xml">
            <form string="Relationship Type">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Optional description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Relationship Type — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_relationship_type_search" model="ir.ui.view">
        <field name="name">edu.relationship.type.search</field>
        <field name="model">edu.relationship.type</field>
        <field name="arch" type="xml">
            <search string="Relationship Types">
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Relationship Type — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_relationship_type" model="ir.actions.act_window">
        <field name="name">Relationship Types</field>
        <field name="res_model">edu.relationship.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_relationship_type_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add a relationship type</p>
            <p>Relationship types define how a guardian is related to an applicant (Father, Mother, Guardian, Sponsor, etc.).</p>
        </field>
    </record>
</odoo>
