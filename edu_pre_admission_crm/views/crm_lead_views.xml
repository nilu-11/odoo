<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Pre-Admission Kanban
         Columns = all 5 lead_education_status values (always visible).
         No js_class="crm_kanban" — avoids CRM pipeline JS overriding grouping.
    ══════════════════════════════════════════════════════ -->
    <record id="view_pre_admission_lead_kanban" model="ir.ui.view">
        <field name="name">crm.lead.kanban.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <kanban default_group_by="lead_education_status"
                    group_create="false"
                    group_delete="false"
                    group_edit="false"
                    archivable="false"
                    sample="1">
                <field name="lead_education_status"/>
                <field name="priority"/>
                <field name="color"/>
                <field name="activity_state"/>
                <field name="activity_ids"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="email_from"/>
                <field name="interested_program_id"/>
                <field name="tag_ids"/>
                <field name="next_followup_date"/>
                <field name="counselor_id"/>
                <progressbar field="activity_state"
                             colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <field name="name" class="fw-bold flex-grow-1"/>
                            <field name="priority" widget="priority" class="ms-1 flex-shrink-0"/>
                        </div>
                        <div class="text-muted small">
                            <field name="partner_id"/>
                        </div>
                        <div class="d-flex gap-2 mt-1 flex-wrap small">
                            <field name="phone" widget="phone"/>
                            <field name="email_from" widget="email"/>
                        </div>
                        <div t-if="record.interested_program_id.value" class="mt-1 small">
                            <field name="interested_program_id"/>
                        </div>
                        <field name="tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}" class="mt-1"/>
                        <footer class="d-flex align-items-center justify-content-between mt-2 pt-1">
                            <span t-if="record.next_followup_date.value" class="text-muted small">
                                <i class="fa fa-calendar me-1"/><field name="next_followup_date"/>
                            </span>
                            <span class="ms-auto d-flex align-items-center gap-1">
                                <field name="activity_ids" widget="activity"/>
                                <field name="counselor_id" widget="many2one_avatar_user"/>
                            </span>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Pre-Admission Pipeline — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_pre_admission_pipeline" model="ir.actions.act_window">
        <field name="name">Inquiries &amp; Leads</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form,activity</field>
        <field name="domain">['|', ('type', '=', 'lead'), ('type', '=', False)]</field>
        <field name="context">{'default_type': 'lead'}</field>
        <field name="search_view_id" ref="crm.view_crm_case_leads_filter"/>
    </record>

    <record id="action_pre_admission_pipeline_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="0"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_pre_admission_lead_kanban"/>
        <field name="act_window_id" ref="action_pre_admission_pipeline"/>
    </record>

    <record id="action_pre_admission_pipeline_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="act_window_id" ref="action_pre_admission_pipeline"/>
    </record>

    <!-- ══════════════════════════════════════════════════════
         CRM Lead — Form Extension (Pre-Admission tab + smart button)
    ══════════════════════════════════════════════════════ -->
    <record id="view_crm_lead_form_pre_admission" model="ir.ui.view">
        <field name="name">crm.lead.form.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- ══════════════════════════════════════════════════════════════
                 HEADER: Hide standard CRM buttons & pipeline statusbar
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//header/button[@name='action_set_won_rainbowman']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='%(crm.action_crm_lead2opportunity_partner)d']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Restore Lost/Mark as Lost buttons — kept at CRM default visibility -->
            <xpath expr="//header/button[@name='action_restore']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='%(crm.crm_lead_lost_action)d']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//header/field[@name='stage_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_set_prospect"
                        type="object"
                        string="Mark as Prospect"
                        class="btn-secondary"
                        invisible="lead_education_status != 'inquiry'"/>
                <button name="action_set_qualified"
                        type="object"
                        string="Mark as Qualified"
                        class="btn-secondary"
                        invisible="lead_education_status not in ['inquiry', 'prospect']"/>
                <button name="action_set_ready_for_application"
                        type="object"
                        string="Ready for Application"
                        class="btn-secondary"
                        invisible="lead_education_status not in ['inquiry', 'prospect', 'qualified']"/>
                <button name="action_check_duplicate_applicants"
                        type="object"
                        string="Check Duplicates"
                        class="btn-secondary"
                        invisible="is_converted_to_application"/>
                <button name="action_convert_to_admission_application"
                        type="object"
                        string="Convert to Application"
                        class="btn-primary"
                        invisible="lead_education_status != 'ready_for_application' or is_converted_to_application"
                        confirm="Convert this lead to a formal admission application? This action cannot be undone."/>
                <field name="lead_education_status"
                       widget="statusbar"
                       statusbar_visible="inquiry,prospect,qualified,ready_for_application,converted"/>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 BUTTON BOX: Hide standard CRM smart buttons, add ours
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//button[@name='action_schedule_meeting']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_show_potential_duplicates']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(edu_pre_admission_crm.action_edu_applicant_profile)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-user-circle"
                    invisible="not applicant_profile_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Applicant</span>
                        <field name="applicant_profile_id" class="o_stat_value" readonly="1"/>
                    </div>
                </button>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 TITLE: Hide revenue/probability row; inject priority stars
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//div[hasclass('oe_title')]//h2" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]//field[@name='name']" position="attributes">
                <attribute name="placeholder">e.g. Inquiry 001</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]//field[@name='name']" position="after">
                <label for="inquiry_date_time" string="Inquiry DateTime" />
                <field name="inquiry_date_time" class="text-muted small ms-2"/>
            </xpath>
            <!-- Add priority stars next to the lead name (h1) -->
            <xpath expr="//div[hasclass('oe_title')]//div[hasclass('d-flex')]" position="inside">
                <field name="priority" widget="priority" class="ms-2 align-self-center"/>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 MAIN SECTION: Hide all CRM field groups, show partner_id
            ══════════════════════════════════════════════════════════════ -->
            <!-- Hide the entire parent group containing all CRM fields -->
            <xpath expr="//sheet/group[1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add a clean group with only partner_id -->
            <xpath expr="//sheet/group[1]" position="before">
                <group>
                    <group>
                        <field name="partner_id" widget="res_partner_many2one" string="Contact" invisible="1"/>
                    </group>
                    <group/>
                </group>
            </xpath>

            <!-- Render pre-admission fields directly in form (no custom notebook page) -->
            <xpath expr="//sheet/notebook" position="before">
                <group>
                    <group string="Profile Information" >
                        <field name="quick_applicant_name"
                               placeholder="e.g. Ram Shah"
                               invisible="applicant_profile_id or lead_education_status in ['qualified', 'ready_for_application', 'converted', 'lost']"
                               string="Applicant Name"/>
                        <field name="applicant_profile_id"
                                options="{'no_create': False}"
                                readonly="is_converted_to_application"
                                help="Link or create the structured applicant profile. Required before conversion."
                                invisible="not applicant_profile_id and lead_education_status not in ['qualified', 'ready_for_application', 'converted']"/>
                        <field name="phone" widget="phone"/>
                        <field name="email_from" widget="email"/>
                        <label for="street" string="Address"/>
                        <div class="o_address_format">
                            <field name="street" placeholder="Street..." class="o_address_street"/>
                            <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                            <field name="city" placeholder="City" class="o_address_city"/>
                            <field name="state_id" placeholder="State" class="o_address_state" options="{'no_open': True, 'no_quick_create': True}" context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"/>
                            <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                            <div name="partner_address_country" class="d-flex justify-content-between">
                                <field name="country_id" placeholder="Country" class="o_address_country" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                            </div>
                        </div>
                        <field name="qualification"
                               placeholder="e.g. A-Levels, Bachelor of Science"/>
                        <field name="cgpa_percentage"
                               string="CGPA / Percentage"/>
                    </group>
                    <group string="Academic Information" >
                        <field name="interested_program_id" readonly="is_converted_to_application" invisible="lead_education_status not in ['qualified','ready_for_application', 'converted']"/>
                        <field name="other_interested_program_ids" readonly="is_converted_to_application" widget="many2many_tags"/>
                        <field name="show_advanced_options" widget="boolean_toggle"/>
                        <field name="intended_academic_year_id" string="Intended Intake Year" readonly="is_converted_to_application" invisible="not show_advanced_options"/>
                        <field name="preferred_batch_id"
                            domain="[('program_id','=',interested_program_id),('academic_year_id','=',intended_academic_year_id)]"
                            options="{'no_create': True}"
                            readonly="is_converted_to_application"
                            invisible="not show_advanced_options"/>
                        <field name="preferred_term_id"
                            options="{'no_create': True}"
                            readonly="is_converted_to_application"
                            invisible="not show_advanced_options"/>
                    </group>
                </group>

                <!-- Status + quick progression buttons -->
                <group>
                    <group string="How did you know about us?" >
                        <!-- <field name="inquiry_date"/>
                        <field name="last_contact_date" invisible="1"/>
                        <field name="next_followup_date"/>
                        <field name="counselor_id"/> -->
                        <field name="medium_id"/>
                        <field name="campaign_id"/>
                        <field name="source_id"/>
                        <field name="referred_by_id"/>
                    </group>
                    <group string =  "Counselor">
                        <field name="counselor_id"/>
                    </group>
                </group>

                <!-- Conversion indicator -->
                <!-- <div class="alert alert-success mb-3"
                     invisible="not is_converted_to_application">
                    <i class="fa fa-check-circle me-2"/>
                    Converted to an admission application on
                    <field name="conversion_date" readonly="1" nolabel="1" class="d-inline"/>
                </div>

                      <div class="o_horizontal_separator mt-4 mb-3">Academic Interest</div>

                      <group>
                          <group string="Program &amp; Intake">
                           <field name="interested_program_id"
                               readonly="is_converted_to_application"/>
                           <field name="intended_academic_year_id"
                               string="Intended Intake Year"
                               readonly="is_converted_to_application"/>
                           <field name="preferred_batch_id"
                               domain="[('program_id','=',interested_program_id),('academic_year_id','=',intended_academic_year_id)]"
                               options="{'no_create': True}"
                               readonly="is_converted_to_application"/>
                           <field name="preferred_term_id"
                               options="{'no_create': True}"
                               readonly="is_converted_to_application"/>
                          </group>
                          <group string="Additional Interests">
                           <field name="scholarship_interest"/>
                           <field name="hostel_interest"/>
                           <field name="transport_interest"/>
                          </group>
                      </group> -->
                <group>
                <group string="Pending Call Activities" colspan="1">
                    <field name="pending_call_activity_ids" nolabel="1" mode="list" readonly="1" width="600px">
                        <list string="Pending Call Activities" create="0" edit="0" delete="0">
                            <field name="summary" string="Activity Type"/>
                            <field name="date_deadline" string="Due Date"
                                decoration-danger="date_deadline &lt; today"
                                decoration-warning="date_deadline == today"/>
                            <field name="note" string="Notes"/>
                            <field name="user_id" string="Assigned To"/>
                        </list>
                    </field>
                </group>
                <group string="Done Call Activities" colspan="1">
                    <field name="done_call_message_ids" nolabel="1" mode="list" readonly="1" width="300px">
                        <list string="Done Call Activities" create="0" edit="0" delete="0">
                            <field name="date" string="Date"/>
                            <field name="call_feedback" string="Feedback"/>
                            <field name="author_id" string="Done By"/>
                        </list>
                    </field>
                </group>
                </group>
                
                <group>
                    <group string="Counseling Notes">
                        <field name="counseling_note" nolabel="1"
                               placeholder="Record counseling session notes, discussion points, concerns..."/>
                    </group>
                    <group string="Qualification Notes">
                        <field name="qualification_note" nolabel="1"
                               placeholder="Eligibility check notes, document status, academic qualification summary..."/>
                    </group>
                </group>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 PROPERTIES: Hide CRM lead properties
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//field[@name='lead_properties']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 NOTEBOOK: Hide standard CRM pages, add Pre-Admission page
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//page[@name='internal_notes']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='extra']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='lead']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>



        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         CRM Lead — List Extension (add education status column)
    ══════════════════════════════════════════════════════ -->
    <record id="view_crm_lead_list_pre_admission" model="ir.ui.view">
        <field name="name">crm.lead.list.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="lead_education_status"
                       string="Edu. Status"
                       optional="show"
                       widget="badge"/>
                <field name="interested_program_id" string="Program" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         CRM Lead — Search Extension (add education filters)
    ══════════════════════════════════════════════════════ -->
    <record id="view_crm_lead_search_pre_admission" model="ir.ui.view">
        <field name="name">crm.lead.search.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/separator[last()]" position="after">
                <separator/>
                <filter string="Inquiry"
                        name="edu_inquiry"
                        domain="[('lead_education_status', '=', 'inquiry')]"/>
                <filter string="Prospect"
                        name="edu_prospect"
                        domain="[('lead_education_status', '=', 'prospect')]"/>
                <filter string="Qualified"
                        name="edu_qualified"
                        domain="[('lead_education_status', '=', 'qualified')]"/>
                <filter string="Ready for Application"
                        name="edu_ready"
                        domain="[('lead_education_status', '=', 'ready_for_application')]"/>
                <filter string="Converted"
                        name="edu_converted"
                        domain="[('is_converted_to_application', '=', True)]"/>
                <separator/>
                <filter string="Has Applicant Profile"
                        name="has_profile"
                        domain="[('applicant_profile_id', '!=', False)]"/>
                <filter string="No Applicant Profile"
                        name="no_profile"
                        domain="[('applicant_profile_id', '=', False)]"/>
                <filter string="My Leads (as Counselor)"
                        name="my_counselor"
                        domain="[('counselor_id', '=', uid)]"/>
                <filter string="Follow-up Due"
                        name="followup_due"
                        domain="[('next_followup_date', '&lt;=', context_today())]"/>
                <separator/>
                <field name="applicant_profile_id"/>
                <field name="interested_program_id"/>
                <field name="counselor_id"/>
            </xpath>
        </field>
    </record>

</odoo>
