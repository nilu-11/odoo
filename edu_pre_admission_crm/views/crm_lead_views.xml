<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Pre-Admission Kanban
         Columns = all 4 lead_education_status values (always visible).
         No js_class="crm_kanban" — avoids CRM pipeline JS overriding grouping.
    ══════════════════════════════════════════════════════ -->
    <record id="view_pre_admission_lead_kanban" model="ir.ui.view">
        <field name="name">crm.lead.kanban.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <kanban default_group_by="lead_education_status"
                    group_create="false"
                    group_delete="false"
                    group_edit="false"
                    archivable="false"
                    sample="1">
                <field name="lead_education_status"/>
                <field name="priority"/>
                <field name="color"/>
                <field name="activity_state"/>
                <field name="activity_ids"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="interested_program_id"/>
                <field name="tag_ids"/>
                <field name="counselor_id"/>
                <field name="is_duplicate"/>
                <field name="call_count"/>
                <field name="visit_count"/>
                <field name="session_count"/>
                <field name="last_interaction_summary"/>
                <field name="next_activity_summary"/>
                <field name="profile_completeness"/>
                <progressbar field="activity_state"
                             colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <!-- Name + priority -->
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <field name="name" class="fw-bold text-truncate"/>
                            <field name="priority" widget="priority" class="ms-1 flex-shrink-0"/>
                        </div>

                        <!-- Program -->
                        <div t-if="record.interested_program_id.value" class="text-muted small text-truncate">
                            <i class="fa fa-graduation-cap me-1"/><field name="interested_program_id"/>
                        </div>

                        <!-- Phone -->
                        <div t-if="record.phone.value" class="small mt-1">
                            <field name="phone" widget="phone"/>
                        </div>

                        <!-- Interaction badges -->
                        <div class="d-flex gap-2 mt-2 small">
                            <span t-if="record.call_count.raw_value" class="badge bg-primary-subtle text-primary-emphasis"
                                  title="Calls">
                                <i class="fa fa-phone me-1"/><field name="call_count"/>
                            </span>
                            <span t-if="record.visit_count.raw_value" class="badge bg-success-subtle text-success-emphasis"
                                  title="Campus Visits">
                                <i class="fa fa-university me-1"/><field name="visit_count"/>
                            </span>
                            <span t-if="record.session_count.raw_value" class="badge bg-info-subtle text-info-emphasis"
                                  title="Counseling Sessions">
                                <i class="fa fa-comments me-1"/><field name="session_count"/>
                            </span>
                            <span class="badge bg-warning ms-auto" t-if="record.is_duplicate.raw_value">Dup</span>
                        </div>

                        <!-- Last interaction -->
                        <div t-if="record.last_interaction_summary.value"
                             class="small text-muted mt-1 text-truncate">
                            <i class="fa fa-history me-1"/><field name="last_interaction_summary"/>
                        </div>

                        <!-- Next activity -->
                        <div t-if="record.next_activity_summary.value"
                             class="small mt-1 text-truncate">
                            <i class="fa fa-clock-o me-1 text-primary"/><field name="next_activity_summary"/>
                        </div>

                        <!-- Tags + counselor -->
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <field name="tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                            <field name="counselor_id" widget="many2one_avatar_user" class="ms-auto"/>
                        </div>

                        <!-- Profile completeness bar -->
                        <div t-if="record.profile_completeness.raw_value" class="mt-2">
                            <div class="progress" style="height: 4px;" t-att-title="record.profile_completeness.value + '%'">
                                <div class="progress-bar"
                                     role="progressbar"
                                     t-att-style="'width: ' + record.profile_completeness.value + '%'"
                                     t-att-class="record.profile_completeness.raw_value &gt;= 60 ? 'bg-success' : 'bg-warning'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Pre-Admission Pipeline — Graph
    ══════════════════════════════════════════════════════ -->
    <record id="view_pre_admission_lead_graph" model="ir.ui.view">
        <field name="name">crm.lead.graph.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <graph string="Pipeline" type="bar">
                <field name="lead_education_status"/>
                <field name="interested_program_id"/>
            </graph>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Pre-Admission Pipeline — Pivot
    ══════════════════════════════════════════════════════ -->
    <record id="view_pre_admission_lead_pivot" model="ir.ui.view">
        <field name="name">crm.lead.pivot.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <pivot string="Pipeline">
                <field name="interested_program_id" type="row"/>
                <field name="lead_education_status" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Pre-Admission Pipeline — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_pre_admission_pipeline" model="ir.actions.act_window">
        <field name="name">Inquiries &amp; Leads</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form,activity,graph,pivot</field>
        <field name="domain">['|', ('type', '=', 'lead'), ('type', '=', False)]</field>
        <field name="context">{'default_type': 'lead'}</field>
        <field name="search_view_id" ref="crm.view_crm_case_leads_filter"/>
    </record>

    <record id="action_pre_admission_pipeline_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="0"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_pre_admission_lead_kanban"/>
        <field name="act_window_id" ref="action_pre_admission_pipeline"/>
    </record>

    <record id="action_pre_admission_pipeline_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="act_window_id" ref="action_pre_admission_pipeline"/>
    </record>

    <record id="action_pre_admission_pipeline_view_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="10"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_pre_admission_lead_graph"/>
        <field name="act_window_id" ref="action_pre_admission_pipeline"/>
    </record>

    <record id="action_pre_admission_pipeline_view_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="11"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_pre_admission_lead_pivot"/>
        <field name="act_window_id" ref="action_pre_admission_pipeline"/>
    </record>

    <!-- ══════════════════════════════════════════════════════
         CRM Lead — Form Extension (Pre-Admission tab + smart button)
    ══════════════════════════════════════════════════════ -->
    <record id="view_crm_lead_form_pre_admission" model="ir.ui.view">
        <field name="name">crm.lead.form.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- ══════════════════════════════════════════════════════════════
                 HEADER: Hide standard CRM buttons & pipeline statusbar
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//header/button[@name='action_set_won_rainbowman']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='%(crm.action_crm_lead2opportunity_partner)d']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Restore Lost/Mark as Lost buttons — kept at CRM default visibility -->
            <xpath expr="//header/button[@name='action_restore']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='%(crm.crm_lead_lost_action)d']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//header/field[@name='stage_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_set_qualified"
                        type="object"
                        string="Qualify"
                        class="btn-secondary"
                        invisible="lead_education_status != 'inquiry'"/>
                <button name="action_check_duplicate_applicants"
                        type="object"
                        string="Check Duplicates"
                        class="btn-secondary"
                        invisible="1"/>
                <button name="action_convert_to_admission_application"
                        type="object"
                        string="Convert to Application"
                        class="btn-primary"
                        invisible="lead_education_status != 'qualified' or is_converted_to_application"
                        confirm="Convert this lead to a formal admission application? This action cannot be undone."/>
                <field name="lead_education_status"
                       widget="statusbar"
                       statusbar_visible="inquiry,qualified,converted"/>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 BUTTON BOX: Hide standard CRM smart buttons, add ours
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//button[@name='action_schedule_meeting']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_show_potential_duplicates']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(edu_pre_admission_crm.action_edu_applicant_profile)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-user-circle"
                    invisible="not applicant_profile_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Applicant</span>
                        <field name="applicant_profile_id" class="o_stat_value" readonly="1"/>
                    </div>
                </button>
                <button name="action_open_similar_inquiries"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-clone"
                        invisible="not is_duplicate">
                    <field name="duplicate_lead_count" widget="statinfo" string="Similar Inquiry"/>
                </button>
                <button name="action_open_merge_wizard"
                        type="object"
                        string="Merge Lead"
                        class="oe_stat_button btn-secondary"
                        icon="fa-compress"
                        invisible="not is_duplicate"/>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 TITLE: Hide revenue/probability row; inject priority stars
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//div[hasclass('oe_title')]//h2" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]//field[@name='name']" position="attributes">
                <attribute name="placeholder">e.g. Inquiry 001</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]//field[@name='name']" position="after">
                <label for="inquiry_date_time" string="Inquiry DateTime" />
                <field name="inquiry_date_time" class="text-muted small ms-2"/>
            </xpath>
            <!-- Add priority stars next to the lead name (h1) -->
            <xpath expr="//div[hasclass('oe_title')]//div[hasclass('d-flex')]" position="inside">
                <field name="priority" widget="priority" class="ms-2 align-self-center"/>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 MAIN SECTION: Hide all CRM field groups, show partner_id
            ══════════════════════════════════════════════════════════════ -->
            <!-- Hide the entire parent group containing all CRM fields -->
            <xpath expr="//sheet/group[1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add a clean group with only partner_id -->
            <xpath expr="//sheet/group[1]" position="before">
                <group>
                    <group>
                        <field name="partner_id" widget="res_partner_many2one" string="Contact" invisible="1"/>
                    </group>
                    <group/>
                </group>
            </xpath>

            <!-- web_ribbon for duplicate detection -->
            <xpath expr="//sheet" position="inside">
                <widget name="web_ribbon" title="Duplicate" bg_color="bg-warning" invisible="not is_duplicate"/>
            </xpath>

            <!-- Next step guidance banner -->
            <xpath expr="//div[@name='button_box']" position="before">
                <field name="next_step_banner" readonly="1" nolabel="1"
                       invisible="lead_education_status in ('converted', 'lost')"
                       class="w-100" widget="html"/>
            </xpath>

            <!-- Duplicate alert before the title -->
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="alert alert-warning py-1 px-2 mb-2 small" role="alert" invisible="not is_duplicate">
                    <i class="fa fa-exclamation-triangle me-1"/>This enquiry appears to be a duplicate (same phone or email).
                </div>
            </xpath>

            <!-- Render pre-admission fields directly in form (no custom notebook page) -->
            <xpath expr="//sheet/notebook" position="before">                
                
                <group>
                    <group string="Profile Information" >
                        <field name="quick_applicant_name"
                               placeholder="e.g. Ram Shah"
                               invisible="applicant_profile_id or lead_education_status in ['qualified', 'converted', 'lost']"
                               string="Applicant Name"/>
                        <field name="applicant_profile_id"
                                options="{'no_create': False}"
                                readonly="is_converted_to_application"
                                help="Link or create the structured applicant profile. Required before conversion."
                                invisible="not applicant_profile_id and lead_education_status not in ['qualified', 'converted']"/>
                        <field name="phone" widget="phone" required="1"/>
                        <field name="email_from" widget="email" required="1"/>
                        <label for="street" string="Address"/>
                        <div class="o_address_format">
                            <field name="street" placeholder="Street..." class="o_address_street"/>
                            <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                            <field name="city" placeholder="City" class="o_address_city"/>
                            <field name="state_id" placeholder="State" class="o_address_state" options="{'no_open': True, 'no_quick_create': True}" context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"/>
                            <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                            <div name="partner_address_country" class="d-flex justify-content-between">
                                <field name="country_id" placeholder="Country" class="o_address_country" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                            </div>
                        </div>
                           <field name="qualification_id"
                               options="{'no_create': False}"
                               placeholder="Select Qualification"/>
                        <field name="cgpa_percentage"
                               string="CGPA / Percentage"/>
                    </group>
                    <group string="Academic Information" >
                        <field name="other_interested_program_ids" readonly="is_converted_to_application" widget="many2many_tags"/>
                        <field name="tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color', 'no_create_edit': False}"
                               placeholder="Tags..."/>
                        <field name="interested_program_id" string="Selected Program"
                               readonly="is_converted_to_application"/>
                        <field name="show_advanced_options" widget="boolean_toggle" invisible="lead_education_status not in ['qualified', 'converted']"/>
                        <field name="intended_academic_year_id" string="Intended Intake Year" readonly="is_converted_to_application" invisible="not show_advanced_options"/>
                        <field name="preferred_batch_id"
                            domain="[('program_id','=',interested_program_id),('academic_year_id','=',intended_academic_year_id)]"
                            options="{'no_create': True}"
                            readonly="is_converted_to_application"
                            invisible="not show_advanced_options"/>
                        <field name="preferred_term_id"
                            options="{'no_create': True}"
                            readonly="is_converted_to_application"
                            invisible="not show_advanced_options"/>
                    </group>
                </group>

                <!-- Status + quick progression buttons -->
                <group>
                    <group string="How did you know about us?" >
                        <!-- <field name="inquiry_date"/>
                        <field name="last_contact_date" invisible="1"/>
                        <field name="next_followup_date"/>
                        <field name="counselor_id"/> -->
                        <field name="medium_id"/>
                        <field name="campaign_id"/>
                        <field name="source_id"/>
                        <field name="referred_by_id" invisible="not is_referral_source"/>
                    </group>
                    <group string="Counselor">
                        <field name="counselor_id"/>
                        <field name="is_converted_to_application" readonly="1"
                               invisible="not is_converted_to_application"/>
                        <field name="conversion_date" readonly="1"
                               invisible="not is_converted_to_application"/>
                    </group>
                </group>

                <!-- Conversion indicator -->
                <!-- <div class="alert alert-success mb-3"
                     invisible="not is_converted_to_application">
                    <i class="fa fa-check-circle me-2"/>
                    Converted to an admission application on
                    <field name="conversion_date" readonly="1" nolabel="1" class="d-inline"/>
                </div>

                      <div class="o_horizontal_separator mt-4 mb-3">Academic Interest</div>

                      <group>
                          <group string="Program &amp; Intake">
                           <field name="interested_program_id" string="Selected Program"
                               readonly="is_converted_to_application"/>
                           <field name="intended_academic_year_id"
                               string="Intended Intake Year"
                               readonly="is_converted_to_application"/>
                           <field name="preferred_batch_id"
                               domain="[('program_id','=',interested_program_id),('academic_year_id','=',intended_academic_year_id)]"
                               options="{'no_create': True}"
                               readonly="is_converted_to_application"/>
                           <field name="preferred_term_id"
                               options="{'no_create': True}"
                               readonly="is_converted_to_application"/>
                          </group>
                          <group string="Additional Interests">
                           <field name="scholarship_interest"/>
                           <field name="hostel_interest"/>
                           <field name="transport_interest"/>
                          </group>
                      </group> -->
                <!-- ── Interaction Timeline ── -->
                <div class="o_horizontal_separator mt-4 mb-3">Interactions</div>

                <div class="mb-3">
                    <button name="action_quick_schedule"
                            type="object"
                            string="Schedule Activity"
                            class="btn-secondary btn-sm"
                            icon="fa-plus"
                            invisible="lead_education_status in ('converted', 'lost')"/>
                    <button name="action_log_interaction"
                            type="object"
                            string="Log Interaction"
                            class="btn-secondary btn-sm ms-1"
                            icon="fa-pencil"
                            invisible="lead_education_status in ('converted', 'lost')"/>
                </div>

                <!-- Upcoming scheduled activities -->
                <field name="activity_ids" nolabel="1" mode="list" readonly="1">
                    <list string="Scheduled Activities" create="0" edit="0" delete="0"
                          decoration-danger="date_deadline &lt; current_date"
                          decoration-warning="date_deadline == current_date">
                        <field name="activity_type_id" string="Type"/>
                        <field name="summary" string="Summary"/>
                        <field name="date_deadline" string="Due Date"/>
                        <field name="user_id" string="Assigned To" widget="many2one_avatar_user"/>
                    </list>
                </field>

                <div class="o_horizontal_separator mt-3 mb-3">Interaction History</div>

                <field name="interaction_log_ids" nolabel="1" mode="list" readonly="1">
                    <list string="Interactions" create="0" edit="0" delete="0"
                          decoration-success="outcome == 'positive'"
                          decoration-danger="outcome == 'negative'"
                          limit="5">
                        <field name="date" widget="datetime"/>
                        <field name="interaction_type" widget="badge"/>
                        <field name="summary"/>
                        <field name="counselor_id" widget="many2one_avatar_user"/>
                        <field name="outcome" widget="badge"
                               decoration-success="outcome == 'positive'"
                               decoration-warning="outcome == 'neutral'"
                               decoration-danger="outcome == 'negative'"/>
                    </list>
                </field>
                
                <group string="Notes" colspan="2">
                    <field name="counseling_note" nolabel="1" colspan="2"
                           placeholder="Record counseling session notes, discussion points, concerns..."/>
                </group>
      
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 PROPERTIES: Hide CRM lead properties
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//field[@name='lead_properties']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 NOTEBOOK: Hide standard CRM pages, add Pre-Admission page
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//page[@name='internal_notes']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='extra']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='lead']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- ══════════════════════════════════════════════════════════════
                 NOTEBOOK: Inline applicant profile data tab
            ══════════════════════════════════════════════════════════════ -->
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Applicant Profile"
                      invisible="not applicant_profile_id">
                    <group>
                        <group string="Profile Completeness">
                            <field name="profile_completeness" widget="progressbar"
                                   options="{'editable': false}"/>
                        </group>
                        <group string="Quick Access">
                            <div>
                                <button name="action_open_applicant_profile"
                                        type="object"
                                        string="Open Full Profile"
                                        class="btn-link btn-sm ps-0"
                                        icon="fa-external-link"/>
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>



        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         CRM Lead — List Extension (add education status column)
    ══════════════════════════════════════════════════════ -->
    <record id="view_crm_lead_list_pre_admission" model="ir.ui.view">
        <field name="name">crm.lead.list.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="lead_education_status"
                       string="Edu. Status"
                       optional="show"
                       widget="badge"/>
                <field name="interested_program_id" string="Program" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         CRM Lead — Search Extension (add education filters)
    ══════════════════════════════════════════════════════ -->
    <record id="view_crm_lead_search_pre_admission" model="ir.ui.view">
        <field name="name">crm.lead.search.pre_admission</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/separator[last()]" position="after">
                <separator/>
                <filter string="Inquiry"
                        name="edu_inquiry"
                        domain="[('lead_education_status', '=', 'inquiry')]"/>
                <filter string="Qualified"
                        name="edu_qualified"
                        domain="[('lead_education_status', '=', 'qualified')]"/>
                <filter string="Converted"
                        name="edu_converted"
                        domain="[('is_converted_to_application', '=', True)]"/>
                <separator/>
                <filter string="Has Applicant Profile"
                        name="has_profile"
                        domain="[('applicant_profile_id', '!=', False)]"/>
                <filter string="No Applicant Profile"
                        name="no_profile"
                        domain="[('applicant_profile_id', '=', False)]"/>
                <filter string="My Leads (as Counselor)"
                        name="my_counselor"
                        domain="[('counselor_id', '=', uid)]"/>
                <filter string="Follow-up Due"
                        name="followup_due"
                        domain="[('next_followup_date', '&lt;=', context_today())]"/>
                <separator/>
                <field name="applicant_profile_id"/>
                <field name="interested_program_id"/>
                <field name="counselor_id"/>
                <separator/>
                <filter string="By Program" name="group_program"
                        context="{'group_by': 'interested_program_id'}"/>
                <filter string="By Counselor" name="group_counselor"
                        context="{'group_by': 'counselor_id'}"/>
                <filter string="By Source" name="group_source"
                        context="{'group_by': 'source_id'}"/>
                <filter string="By Medium" name="group_medium"
                        context="{'group_by': 'medium_id'}"/>
                <filter string="By Month" name="group_month"
                        context="{'group_by': 'inquiry_date:month'}"/>
            </xpath>
        </field>
    </record>

</odoo>
