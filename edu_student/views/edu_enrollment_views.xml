<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Enrollment Form — add "View Student" smart button
         and update student_id display for edu.student
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_enrollment_form_student_btn" model="ir.ui.view">
        <field name="name">edu.enrollment.form.student.btn</field>
        <field name="model">edu.enrollment</field>
        <field name="inherit_id" ref="edu_enrollment.view_edu_enrollment_form"/>
        <field name="arch" type="xml">
            <!-- Add "View Student" button next to "Create Student" -->
            <xpath expr="//button[@name='action_create_student']" position="after">
                <button name="action_view_student"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-graduation-cap"
                        invisible="not student_created or state != 'active'">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Student</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
