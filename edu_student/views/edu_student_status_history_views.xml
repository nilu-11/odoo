<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Student Status History — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_status_history_list" model="ir.ui.view">
        <field name="name">edu.student.status.history.list</field>
        <field name="model">edu.student.status.history</field>
        <field name="arch" type="xml">
            <list string="Status History" default_order="changed_on desc"
                  create="false" edit="false" delete="false">
                <field name="student_no" decoration-bf="1"/>
                <field name="student_id"/>
                <field name="old_state" widget="badge"/>
                <field name="new_state" widget="badge"/>
                <field name="changed_on"/>
                <field name="changed_by"/>
                <field name="reason"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Status History — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_status_history_form" model="ir.ui.view">
        <field name="name">edu.student.status.history.form</field>
        <field name="model">edu.student.status.history</field>
        <field name="arch" type="xml">
            <form string="Status History" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Transition">
                            <field name="student_id" readonly="1"/>
                            <field name="student_no" readonly="1"/>
                            <field name="old_state" readonly="1"/>
                            <field name="new_state" readonly="1"/>
                        </group>
                        <group string="Details">
                            <field name="changed_on" readonly="1"/>
                            <field name="changed_by" readonly="1"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Status History — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_status_history_search" model="ir.ui.view">
        <field name="name">edu.student.status.history.search</field>
        <field name="model">edu.student.status.history</field>
        <field name="arch" type="xml">
            <search string="Status History">
                <field name="student_id"/>
                <field name="student_no"/>
                <field name="changed_by"/>
                <separator/>
                <group name="group_by">
                    <filter string="Student" name="group_student"
                            context="{'group_by': 'student_id'}"/>
                    <filter string="New Status" name="group_new_state"
                            context="{'group_by': 'new_state'}"/>
                    <filter string="Changed By" name="group_changed_by"
                            context="{'group_by': 'changed_by'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'changed_on:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Status History — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_student_status_history" model="ir.actions.act_window">
        <field name="name">Student Status History</field>
        <field name="res_model">edu.student.status.history</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_student_status_history_search"/>
    </record>
</odoo>
