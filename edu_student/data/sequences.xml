<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- ══════════════════════════════════════════════════════
         Student No — Global Institutional Sequence
         Format: STU/2026/00001
    ══════════════════════════════════════════════════════ -->
    <record id="seq_edu_student" model="ir.sequence">
        <field name="name">Student Number</field>
        <field name="code">edu.student</field>
        <field name="prefix">STU/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
