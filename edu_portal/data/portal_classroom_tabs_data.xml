<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- ══════════════════════════════════════════════════════
         Built-in classroom tabs.

         12 records total: 6 built-in tabs x 2 roles.
         Route patterns use {classroom_id} as the sole placeholder.
         The role is baked into the record itself; permission logic
         and templates diverge between teacher and student routes.

         Icons are monochrome Unicode glyphs, no emoji.

         noupdate="1" so admin edits (toggling active, changing
         sequence) survive module updates.
    ══════════════════════════════════════════════════════ -->

    <!-- ═══ Teacher tabs ═══ -->
    <record id="tab_teacher_stream" model="edu.portal.classroom.tab">
        <field name="key">stream</field>
        <field name="label">Stream</field>
        <field name="icon">≡</field>
        <field name="sequence">10</field>
        <field name="route_pattern">/portal/teacher/classroom/{classroom_id}/stream</field>
        <field name="role">teacher</field>
    </record>

    <record id="tab_teacher_attendance" model="edu.portal.classroom.tab">
        <field name="key">attendance</field>
        <field name="label">Attendance</field>
        <field name="icon">✓</field>
        <field name="sequence">20</field>
        <field name="route_pattern">/portal/teacher/classroom/{classroom_id}/attendance</field>
        <field name="role">teacher</field>
    </record>

    <record id="tab_teacher_exams" model="edu.portal.classroom.tab">
        <field name="key">exams</field>
        <field name="label">Exams</field>
        <field name="icon">✎</field>
        <field name="sequence">30</field>
        <field name="route_pattern">/portal/teacher/classroom/{classroom_id}/exams</field>
        <field name="role">teacher</field>
    </record>

    <record id="tab_teacher_assessments" model="edu.portal.classroom.tab">
        <field name="key">assessments</field>
        <field name="label">Assessments</field>
        <field name="icon">◧</field>
        <field name="sequence">40</field>
        <field name="route_pattern">/portal/teacher/classroom/{classroom_id}/assessments</field>
        <field name="role">teacher</field>
    </record>

    <record id="tab_teacher_results" model="edu.portal.classroom.tab">
        <field name="key">results</field>
        <field name="label">Results</field>
        <field name="icon">▦</field>
        <field name="sequence">50</field>
        <field name="route_pattern">/portal/teacher/classroom/{classroom_id}/results</field>
        <field name="role">teacher</field>
    </record>

    <record id="tab_teacher_people" model="edu.portal.classroom.tab">
        <field name="key">people</field>
        <field name="label">People</field>
        <field name="icon">◉</field>
        <field name="sequence">60</field>
        <field name="route_pattern">/portal/teacher/classroom/{classroom_id}/people</field>
        <field name="role">teacher</field>
    </record>

    <!-- ═══ Student tabs ═══ -->
    <record id="tab_student_stream" model="edu.portal.classroom.tab">
        <field name="key">stream</field>
        <field name="label">Stream</field>
        <field name="icon">≡</field>
        <field name="sequence">10</field>
        <field name="route_pattern">/portal/student/classroom/{classroom_id}/stream</field>
        <field name="role">student</field>
    </record>

    <record id="tab_student_attendance" model="edu.portal.classroom.tab">
        <field name="key">attendance</field>
        <field name="label">Attendance</field>
        <field name="icon">✓</field>
        <field name="sequence">20</field>
        <field name="route_pattern">/portal/student/classroom/{classroom_id}/attendance</field>
        <field name="role">student</field>
    </record>

    <record id="tab_student_exams" model="edu.portal.classroom.tab">
        <field name="key">exams</field>
        <field name="label">Exams</field>
        <field name="icon">✎</field>
        <field name="sequence">30</field>
        <field name="route_pattern">/portal/student/classroom/{classroom_id}/exams</field>
        <field name="role">student</field>
    </record>

    <record id="tab_student_assessments" model="edu.portal.classroom.tab">
        <field name="key">assessments</field>
        <field name="label">Assessments</field>
        <field name="icon">◧</field>
        <field name="sequence">40</field>
        <field name="route_pattern">/portal/student/classroom/{classroom_id}/assessments</field>
        <field name="role">student</field>
    </record>

    <record id="tab_student_results" model="edu.portal.classroom.tab">
        <field name="key">results</field>
        <field name="label">Results</field>
        <field name="icon">▦</field>
        <field name="sequence">50</field>
        <field name="route_pattern">/portal/student/classroom/{classroom_id}/results</field>
        <field name="role">student</field>
    </record>

    <record id="tab_student_people" model="edu.portal.classroom.tab">
        <field name="key">people</field>
        <field name="label">People</field>
        <field name="icon">◉</field>
        <field name="sequence">60</field>
        <field name="route_pattern">/portal/student/classroom/{classroom_id}/people</field>
        <field name="role">student</field>
    </record>
</odoo>
