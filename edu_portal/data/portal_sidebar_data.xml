<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- ══════════════════════════════════════════════════════
         Built-in sidebar items.

         Icons are plain monochrome Unicode glyphs so they render
         consistently and match the professional theme. Avoid
         emoji/color glyphs here.

         Bridge modules can add more by shipping their own data
         records into the same model. noupdate="1" preserves
         admin edits across -u edu_portal.
    ══════════════════════════════════════════════════════ -->

    <!-- ─── Teacher ─── -->
    <record id="sidebar_teacher_home" model="edu.portal.sidebar.item">
        <field name="key">home</field>
        <field name="label">Home</field>
        <field name="icon">⌂</field>
        <field name="sequence">10</field>
        <field name="url">/portal/teacher/home</field>
        <field name="role">teacher</field>
    </record>

    <record id="sidebar_teacher_profile" model="edu.portal.sidebar.item">
        <field name="key">profile</field>
        <field name="label">My Profile</field>
        <field name="icon">◉</field>
        <field name="sequence">90</field>
        <field name="url">/portal/teacher/profile</field>
        <field name="role">teacher</field>
    </record>

    <!-- ─── Student ─── -->
    <record id="sidebar_student_home" model="edu.portal.sidebar.item">
        <field name="key">home</field>
        <field name="label">Home</field>
        <field name="icon">⌂</field>
        <field name="sequence">10</field>
        <field name="url">/portal/student/home</field>
        <field name="role">student</field>
    </record>

    <record id="sidebar_student_fees" model="edu.portal.sidebar.item">
        <field name="key">fees</field>
        <field name="label">Fees</field>
        <field name="icon">¤</field>
        <field name="sequence">70</field>
        <field name="url">/portal/student/fees</field>
        <field name="role">student</field>
    </record>

    <record id="sidebar_student_profile" model="edu.portal.sidebar.item">
        <field name="key">profile</field>
        <field name="label">My Profile</field>
        <field name="icon">◉</field>
        <field name="sequence">90</field>
        <field name="url">/portal/student/profile</field>
        <field name="role">student</field>
    </record>

    <!-- ─── Parent ─── -->
    <record id="sidebar_parent_home" model="edu.portal.sidebar.item">
        <field name="key">home</field>
        <field name="label">Overview</field>
        <field name="icon">⌂</field>
        <field name="sequence">10</field>
        <field name="url">/portal/parent/home</field>
        <field name="role">parent</field>
    </record>

    <record id="sidebar_parent_attendance" model="edu.portal.sidebar.item">
        <field name="key">attendance</field>
        <field name="label">Attendance</field>
        <field name="icon">✓</field>
        <field name="sequence">30</field>
        <field name="url">/portal/parent/attendance</field>
        <field name="role">parent</field>
    </record>

    <record id="sidebar_parent_results" model="edu.portal.sidebar.item">
        <field name="key">results</field>
        <field name="label">Results</field>
        <field name="icon">▦</field>
        <field name="sequence">40</field>
        <field name="url">/portal/parent/results</field>
        <field name="role">parent</field>
    </record>

    <record id="sidebar_parent_assessments" model="edu.portal.sidebar.item">
        <field name="key">assessments</field>
        <field name="label">Assessments</field>
        <field name="icon">✎</field>
        <field name="sequence">50</field>
        <field name="url">/portal/parent/assessments</field>
        <field name="role">parent</field>
    </record>

    <record id="sidebar_parent_fees" model="edu.portal.sidebar.item">
        <field name="key">fees</field>
        <field name="label">Fees</field>
        <field name="icon">¤</field>
        <field name="sequence">70</field>
        <field name="url">/portal/parent/fees</field>
        <field name="role">parent</field>
    </record>

    <record id="sidebar_parent_profile" model="edu.portal.sidebar.item">
        <field name="key">profile</field>
        <field name="label">My Profile</field>
        <field name="icon">◉</field>
        <field name="sequence">90</field>
        <field name="url">/portal/parent/profile</field>
        <field name="role">parent</field>
    </record>
</odoo>
