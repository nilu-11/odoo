<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <!-- ══════════════════════════════════════════════════════
         Built-in sidebar items — Kopilā design.

         Icons are plain monochrome Unicode glyphs. Group field
         controls section headers in the sidebar.
    ══════════════════════════════════════════════════════ -->

    <!-- ─── Teacher: Teach ─── -->
    <record id="sidebar_teacher_home" model="edu.portal.sidebar.item">
        <field name="key">home</field>
        <field name="label">Today</field>
        <field name="icon">⌂</field>
        <field name="group">Teach</field>
        <field name="sequence">10</field>
        <field name="url">/portal/teacher/home</field>
        <field name="role">teacher</field>
    </record>

