<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Sidebar — Kopila design
         Grouped nav with section headers, course list, footer.
         Expects: portal_role, sidebar_items, active_sidebar_key,
                  user, classrooms (optional, for course list)
    ══════════════════════════════════════════════════════ -->
    <template id="sidebar_component" name="Portal Sidebar">
        <aside class="portal-sidebar" data-sidebar="">
            <!-- Brand -->
            <div class="sidebar-brand">
                <div class="sidebar-brand-icon">क</div>
                <div class="sidebar-brand-text">
                    <div class="sidebar-brand-name display">Kopilā</div>
                    <div class="sidebar-brand-sub">EMIS Portal</div>
                </div>
            </div>

            <!-- Scrollable nav area -->
            <div class="sidebar-scroll">
                <t t-set="last_group" t-value="''"/>
                <t t-foreach="sidebar_items" t-as="item">
                    <!-- Section header when group changes -->
                    <t t-if="item.get('group') and item['group'] != last_group">
                        <div class="nav-section"><t t-esc="item['group']"/></div>
                        <t t-set="last_group" t-value="item['group']"/>
                    </t>
                    <div class="nav-list">
                        <a t-att-href="item['url']"
                           t-attf-class="nav-item #{'active' if item.get('key') == (active_sidebar_key or active_item) else ''}">
                            <span class="nav-icon"><t t-esc="item['icon']"/></span>
                            <span class="nav-label"><t t-esc="item['label']"/></span>
                            <t t-if="item.get('badge')">
                                <span t-attf-class="nav-badge mono #{'accent' if item.get('badge_accent') else ''}">
                                    <t t-esc="item['badge']"/>
                                </span>
                            </t>
                        </a>
                    </div>
                </t>

                <!-- My Courses section (teacher only) -->
                <t t-if="portal_role == 'teacher' and classrooms">
                    <div class="nav-section">My courses</div>
                    <div class="nav-courses">
                        <t t-foreach="classrooms" t-as="cl">
                            <a t-attf-href="/portal/teacher/classroom/#{cl.id}"
                               class="nav-course">
                                <span class="course-dot saffron"/>
                                <span class="nav-label"><t t-esc="cl.name"/></span>
                                <span class="course-code-short mono">
                                    <t t-esc="cl.subject_id.code or ''"/>
                                </span>
                            </a>
                        </t>
                    </div>
                </t>
            </div>

            <!-- Footer: user info -->
            <div class="sidebar-footer">
                <div class="avatar">
                    <t t-esc="user.name[0].upper() if user.name else '?'"/>
                </div>
                <div class="user-text">
                    <div class="user-name"><t t-esc="user.name"/></div>
                    <div class="user-role">
                        <t t-esc="portal_role.title() if portal_role else ''"/>
                    </div>
                </div>
            </div>
        </aside>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Topbar — Kopila design
         Breadcrumbs, selectors, user menu.
         Expects: page_title, user, portal_role, active_child
    ══════════════════════════════════════════════════════ -->
    <template id="topbar_component" name="Portal Topbar">
        <header class="portal-topbar">
            <!-- Sidebar toggle (hamburger) -->
            <button class="iconbtn" data-sidebar-toggle="1" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
            </button>

            <!-- Breadcrumbs -->
            <div class="crumbs">
                <span class="crumb-hide-sm">Kopilā</span>
                <span class="sep">/</span>
                <span class="current"><t t-esc="page_title or ''"/></span>
            </div>

            <!-- Child selector (parent role only) -->
            <t t-if="portal_role == 'parent' and children">
                <select class="topbar-child-selector"
                        onchange="window.location.href='/portal/parent/switch-child/' + this.value">
                    <t t-foreach="children" t-as="child">
                        <option t-att-value="child.id" t-att-selected="active_child and active_child.id == child.id">
                            <t t-esc="child.display_name"/>
                        </option>
                    </t>
                </select>
            </t>

            <!-- Role switcher (multi-role users only) -->
            <t t-if="user.portal_role == 'multi'">
                <select class="topbar-role-switch"
                        onchange="window.location.href='/portal/role-switch/' + this.value">
                    <option value="student" t-att-selected="portal_role == 'student'">Student</option>
                    <option value="parent" t-att-selected="portal_role == 'parent'">Parent</option>
                    <option value="teacher" t-att-selected="portal_role == 'teacher'">Teacher</option>
                </select>
            </t>

            <!-- Notifications bell -->
            <button class="iconbtn" title="Notifications">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            </button>

            <!-- User menu -->
            <div class="topbar-user" data-user-menu-trigger="1">
                <div class="avatar" style="width:28px; height:28px; font-size:11px;">
                    <t t-esc="user.name[0].upper() if user.name else '?'"/>
                </div>
                <div class="user-menu" data-user-menu="1">
                    <a t-attf-href="/portal/#{portal_role}/profile">My Profile</a>
                    <a href="/web/session/logout">Logout</a>
                </div>
            </div>
        </header>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Stat Card
         Expects: label, value, sub
    ══════════════════════════════════════════════════════ -->
    <template id="stat_card_component" name="Portal Stat Card">
        <div class="card">
            <p class="card-title"><t t-esc="label"/></p>
            <p class="card-value display"><t t-esc="value"/></p>
            <t t-if="sub"><p class="card-sub"><t t-esc="sub"/></p></t>
        </div>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Classroom Card
         Expects: classroom, status_label, status_class, detail_url
    ══════════════════════════════════════════════════════ -->
    <template id="classroom_card_component" name="Portal Classroom Card">
        <a t-att-href="detail_url" class="classroom-card">
            <div class="classroom-card-info">
                <h3><t t-esc="classroom.name"/></h3>
                <p>
                    <t t-esc="classroom.section_id.name"/> &#183;
                    <t t-esc="classroom.subject_id.name"/>
                </p>
            </div>
            <span t-attf-class="pill #{status_class}">
                <t t-esc="status_label"/>
            </span>
        </a>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Classroom Tabs
         Expects: classroom, classroom_tabs, active_tab_key
    ══════════════════════════════════════════════════════ -->
    <template id="classroom_tabs_component" name="Portal Classroom Tabs">
        <nav class="classroom-tabs">
            <div class="classroom-tabs-header">
                <h1 class="classroom-tabs-title display"><t t-esc="classroom.name"/></h1>
                <p class="classroom-tabs-sub">
                    <t t-esc="classroom.section_id.name"/> ·
                    <t t-esc="classroom.subject_id.name"/> ·
                    <t t-esc="classroom.program_term_id.name"/>
                </p>
            </div>
            <ul class="classroom-tabs-list">
                <t t-foreach="classroom_tabs" t-as="tab">
                    <li>
                        <a t-att-href="tab['url']"
                           t-attf-class="classroom-tab #{'active' if tab['key'] == active_tab_key else ''}">
                            <span class="classroom-tab-icon"><t t-esc="tab['icon']"/></span>
                            <span class="classroom-tab-label"><t t-esc="tab['label']"/></span>
                        </a>
                    </li>
                </t>
            </ul>
        </nav>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Post Card (Stream announcements)
         Expects: post, can_manage
    ══════════════════════════════════════════════════════ -->
    <template id="post_card_component" name="Portal Post Card">
        <article t-attf-class="post-card #{'post-pinned' if post.pinned else ''}">
            <header class="post-card-header">
                <div class="post-author">
                    <div class="post-author-avatar">
                        <t t-esc="post.author_id.name[0].upper() if post.author_id.name else '?'"/>
                    </div>
                    <div class="post-author-info">
                        <strong><t t-esc="post.author_id.name"/></strong>
                        <span><t t-esc="post.posted_at"/></span>
                    </div>
                </div>
                <div class="post-card-meta">
                    <t t-if="post.pinned">
                        <span class="pill accent">Pinned</span>
                    </t>
                </div>
            </header>
            <div class="post-card-body">
                <t t-out="post.body"/>
            </div>
            <t t-if="can_manage">
                <footer class="post-card-actions">
                    <form t-attf-action="/portal/teacher/classroom/stream/pin/#{post.id}"
                          method="post" class="post-action-form">
                        <button type="submit" class="btn sm">
                            <t t-esc="'Unpin' if post.pinned else 'Pin'"/>
                        </button>
                    </form>
                    <form t-attf-action="/portal/teacher/classroom/stream/archive/#{post.id}"
                          method="post" class="post-action-form"
                          onsubmit="return confirm('Archive this post?');">
                        <button type="submit" class="btn sm" style="color:var(--danger)">Archive</button>
                    </form>
                </footer>
            </t>
        </article>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Empty State
         Expects: title, message
    ══════════════════════════════════════════════════════ -->
    <template id="empty_state_component" name="Portal Empty State">
        <div class="empty">
            <div style="margin-bottom:8px; color:var(--ink-softer);">○</div>
            <div style="font-weight:500; color:var(--ink); margin-bottom:4px;"><t t-esc="title"/></div>
            <div><t t-esc="message or ''"/></div>
        </div>
    </template>
</odoo>
