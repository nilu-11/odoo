<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         edu.guardian — Portal Access Button
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_guardian_form_portal" model="ir.ui.view">
        <field name="name">edu.guardian.form.portal</field>
        <field name="model">edu.guardian</field>
        <field name="inherit_id" ref="edu_pre_admission_crm.view_edu_guardian_form"/>
        <field name="arch" type="xml">
            <!-- Add portal buttons before the sheet (as a header) -->
            <xpath expr="//form/sheet" position="before">
                <header>
                    <button name="action_grant_portal_access"
                            type="object"
                            string="Grant Portal Access"
                            class="btn-primary"
                            invisible="portal_access"
                            confirm="Grant parent portal access? A welcome email will be sent."
                            groups="edu_academic_structure.group_education_admin"/>
                    <button name="action_revoke_portal_access"
                            type="object"
                            string="Revoke Portal Access"
                            class="btn-warning"
                            invisible="not portal_access"
                            confirm="Revoke parent portal access?"
                            groups="edu_academic_structure.group_education_admin"/>
                </header>
            </xpath>

            <!-- Add portal_access stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="portal_access" widget="boolean_button"
                       class="oe_stat_button" icon="fa-key"/>
            </xpath>
        </field>
    </record>
</odoo>
