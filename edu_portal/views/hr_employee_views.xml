<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         hr.employee — Portal Access Button
    ══════════════════════════════════════════════════════ -->
    <record id="view_hr_employee_form_portal" model="ir.ui.view">
        <field name="name">hr.employee.form.portal</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Add portal buttons to the header -->
            <xpath expr="//header" position="inside">
                <button name="action_grant_portal_access"
                        type="object"
                        string="Grant Portal Access"
                        class="btn-primary"
                        invisible="portal_access"
                        confirm="Grant teacher portal access? A welcome email will be sent."
                        groups="edu_academic_structure.group_education_admin"/>
                <button name="action_revoke_portal_access"
                        type="object"
                        string="Revoke Portal Access"
                        class="btn-warning"
                        invisible="not portal_access"
                        confirm="Revoke teacher portal access?"
                        groups="edu_academic_structure.group_education_admin"/>
            </xpath>

            <!-- Add portal_access stat button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="portal_access" widget="boolean_button"
                       class="oe_stat_button" icon="fa-key"/>
            </xpath>
        </field>
    </record>
</odoo>
