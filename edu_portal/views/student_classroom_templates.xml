<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Student in-classroom hub templates — read-only views.
    ══════════════════════════════════════════════════════ -->

    <!-- ─── Stream (read-only) ─── -->
    <template id="student_classroom_stream_page" name="Student Classroom Stream">
        <t t-call="edu_portal.portal_layout">
            <t t-call="edu_portal.classroom_tabs_component"/>
            <div class="classroom-body stream-body">
                <t t-if="posts">
                    <div class="stream-feed">
                        <t t-foreach="posts" t-as="post">
                            <t t-call="edu_portal.post_card_component">
                                <t t-set="can_manage" t-value="False"/>
                            </t>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <t t-call="edu_portal.empty_state_component">
                        <t t-set="icon" t-value="'💬'"/>
                        <t t-set="title" t-value="'No announcements yet'"/>
                        <t t-set="message" t-value="'Your teacher hasn\'t posted anything yet.'"/>
                    </t>
                </t>
            </div>
        </t>
    </template>

    <!-- ─── Attendance (read-only log) ─── -->
    <template id="student_classroom_attendance_page" name="Student Classroom Attendance">
        <t t-call="edu_portal.portal_layout">
            <t t-call="edu_portal.classroom_tabs_component"/>
            <div class="classroom-body">
                <div class="attendance-summary">
                    <div class="attendance-summary-metric">
                        <span class="metric-label">Attendance</span>
                        <span class="metric-value"><t t-esc="attendance_pct"/>%</span>
                    </div>
                </div>
                <t t-if="lines">
                    <table class="attendance-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Session</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="lines" t-as="line">
                                <tr>
                                    <td><t t-esc="line.session_date"/></td>
                                    <td><t t-esc="line.sheet_id.name or ''"/></td>
                                    <td>
                                        <span t-attf-class="attendance-status status-#{line.status}">
                                            <t t-esc="dict(line._fields['status'].selection).get(line.status, line.status)"/>
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <t t-call="edu_portal.empty_state_component">
                        <t t-set="icon" t-value="'📋'"/>
                        <t t-set="title" t-value="'No attendance records yet'"/>
                        <t t-set="message" t-value="'Your attendance log will appear here after your first class.'"/>
                    </t>
                </t>
            </div>
        </t>
    </template>

    <!-- ─── Exams (read-only marksheets) ─── -->
    <template id="student_classroom_exams_page" name="Student Classroom Exams">
        <t t-call="edu_portal.portal_layout">
            <t t-call="edu_portal.classroom_tabs_component"/>
            <div class="classroom-body">
                <t t-if="marksheets">
                    <table class="marks-table">
                        <thead>
                            <tr>
                                <th>Exam</th>
                                <th>Marks</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="marksheets" t-as="ms">
                                <tr>
                                    <td><t t-esc="ms.exam_paper_id.display_name"/></td>
                                    <td>
                                        <t t-esc="ms.marks_obtained"/> / <t t-esc="ms.max_marks"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <t t-call="edu_portal.empty_state_component">
                        <t t-set="icon" t-value="'📝'"/>
                        <t t-set="title" t-value="'No exam results yet'"/>
                        <t t-set="message" t-value="'Your marks for this subject will appear here once published.'"/>
                    </t>
                </t>
            </div>
        </t>
    </template>

    <!-- ─── Assessments (read-only) ─── -->
    <template id="student_classroom_assessments_page" name="Student Classroom Assessments">
        <t t-call="edu_portal.portal_layout">
            <t t-call="edu_portal.classroom_tabs_component"/>
            <div class="classroom-body">
                <t t-if="records">
                    <table class="assessment-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Category</th>
                                <th>Marks</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="records" t-as="rec">
                                <tr>
                                    <td><t t-esc="rec.assessment_date"/></td>
                                    <td><t t-esc="rec.category_id.name"/></td>
                                    <td><t t-esc="rec.marks_obtained"/> / <t t-esc="rec.max_marks"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <t t-call="edu_portal.empty_state_component">
                        <t t-set="icon" t-value="'📋'"/>
                        <t t-set="title" t-value="'No assessment records yet'"/>
                        <t t-set="message" t-value="'Continuous assessments will appear here as your teacher records them.'"/>
                    </t>
                </t>
            </div>
        </t>
    </template>

    <!-- ─── Results (own card) ─── -->
    <template id="student_classroom_results_page" name="Student Classroom Results">
        <t t-call="edu_portal.portal_layout">
            <t t-call="edu_portal.classroom_tabs_component"/>
            <div class="classroom-body">
                <t t-if="results">
                    <t t-foreach="results" t-as="r">
                        <div class="result-card">
                            <h3><t t-esc="r.result_session_id.name or 'Result'"/></h3>
                            <div class="result-metrics">
                                <div class="result-metric">
                                    <span class="metric-label">GPA</span>
                                    <span class="metric-value"><t t-esc="r.gpa"/></span>
                                </div>
                                <div class="result-metric">
                                    <span class="metric-label">Percentage</span>
                                    <span class="metric-value"><t t-esc="r.percentage"/>%</span>
                                </div>
                                <div class="result-metric">
                                    <span class="metric-label">Grade</span>
                                    <span class="metric-value"><t t-esc="r.grade_letter or ''"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
                <t t-else="">
                    <t t-call="edu_portal.empty_state_component">
                        <t t-set="icon" t-value="'📊'"/>
                        <t t-set="title" t-value="'No results published'"/>
                        <t t-set="message" t-value="'Your result card will appear here once the session is published.'"/>
                    </t>
                </t>
            </div>
        </t>
    </template>

    <!-- ─── People ─── -->
    <template id="student_classroom_people_page" name="Student Classroom People">
        <t t-call="edu_portal.portal_layout">
            <t t-call="edu_portal.classroom_tabs_component"/>
            <div class="classroom-body">
                <section class="people-section">
                    <h3 class="people-section-title">Teacher</h3>
                    <div class="people-grid">
                        <div class="person-card">
                            <div class="person-avatar">
                                <t t-esc="classroom.teacher_id.name[0].upper() if classroom.teacher_id.name else '?'"/>
                            </div>
                            <div class="person-info">
                                <strong><t t-esc="classroom.teacher_id.name"/></strong>
                                <span><t t-esc="classroom.subject_id.name"/></span>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="people-section">
                    <h3 class="people-section-title">
                        Classmates
                        (<t t-esc="len(classmates)"/>)
                    </h3>
                    <t t-if="classmates">
                        <table class="people-table">
                            <thead>
                                <tr>
                                    <th style="width:48px;">#</th>
                                    <th>Name</th>
                                    <th>Student ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="classmates" t-as="cm">
                                    <tr>
                                        <td><t t-esc="cm_index + 1"/></td>
                                        <td><t t-esc="cm.partner_id.name or ''"/></td>
                                        <td><t t-esc="cm.student_no or ''"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <t t-call="edu_portal.empty_state_component">
                            <t t-set="title" t-value="'No classmates yet'"/>
                            <t t-set="message" t-value="'Your classmates will appear here.'"/>
                        </t>
                    </t>
                </section>
            </div>
        </t>
    </template>
</odoo>
