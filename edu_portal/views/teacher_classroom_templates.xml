<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================
         Teacher Classroom Hub — Tab-based detail view
         Mirrors course-detail.jsx with 7 tabs:
         stream, content, attendance, exams, assessments, results, people
         ============================================================ -->

    <!-- ─── Classroom Base Layout (with tab bar) ─────────────────── -->
    <template id="teacher_classroom" name="Teacher — Classroom Hub">
        <t t-call="edu_portal.portal_layout">
            <div class="content" t-att-data-screen-label="'Classroom %s' % classroom.get('code', '')">
                <!-- Page head -->
                <div class="page-head" style="align-items:flex-start;">
                    <div>
                        <div class="mono" style="font-size:12px;color:var(--ink-softer);margin-bottom:6px;">
                            <t t-esc="classroom.get('code', '')"/> ·
                            <t t-esc="classroom.get('credits', 3)"/> credits ·
                            <t t-esc="classroom.get('semester', '')"/> ·
                            <span style="color:var(--ink-soft);">edu.classroom #<t t-esc="classroom.get('id', '')"/></span>
                        </div>
                        <h1 class="page-title"><t t-esc="classroom.get('title', '')"/></h1>
                        <div class="page-sub" style="display:flex;gap:14px;margin-top:8px;">
                            <span>
                                <t t-call="edu_portal.icon"><t t-set="ico" t-value="'users'"/><t t-set="sz" t-value="12"/></t>
                                <t t-esc="classroom.get('students', 0)"/> students
                            </span>
                            <span>
                                <t t-call="edu_portal.icon"><t t-set="ico" t-value="'book'"/><t t-set="sz" t-value="12"/></t>
                                <t t-esc="classroom.get('room', '')"/>
                            </span>
                            <span>
                                <t t-call="edu_portal.icon"><t t-set="ico" t-value="'clock'"/><t t-set="sz" t-value="12"/></t>
                                <t t-esc="classroom.get('next_class', '')"/>
                            </span>
                            <span class="pill success">Active</span>
                        </div>
                    </div>
                    <div style="display:flex;gap:8px;">
                        <a t-att-href="'/portal/teacher/classroom/%s/attendance' % classroom.get('id', '')" class="btn">
                            <t t-call="edu_portal.icon"><t t-set="ico" t-value="'check'"/></t> Attendance
                        </a>
                        <a t-att-href="'/portal/teacher/classroom/%s/exams' % classroom.get('id', '')" class="btn">
                            <t t-call="edu_portal.icon"><t t-set="ico" t-value="'pen'"/></t> Marks entry
                        </a>
                        <a t-att-href="'/portal/teacher/classroom/%s/stream' % classroom.get('id', '')" class="btn primary">
                            <t t-call="edu_portal.icon"><t t-set="ico" t-value="'plus'"/></t> New post
                        </a>
                    </div>
                </div>

                <!-- Tab bar (segmented control) -->
                <div class="seg" style="margin-bottom:20px;overflow-x:auto;">
                    <t t-foreach="[
                        ('stream', 'Stream', 'mega'),
                        ('content', 'Content', 'book'),
                        ('attendance', 'Attendance', 'check'),
                        ('exams', 'Exams', 'paper'),
                        ('assessments', 'Assessments', 'pen'),
                        ('results', 'Results', 'grid'),
                        ('people', 'People', 'users'),
                    ]" t-as="tab">
                        <a t-att-href="'/portal/teacher/classroom/%s/%s' % (classroom.get('id', ''), tab[0])"
                           t-att-class="'active' if active_tab == tab[0] else ''">
                            <t t-call="edu_portal.icon"><t t-set="ico" t-value="tab[2]"/><t t-set="sz" t-value="12"/></t>
                            <t t-esc="tab[1]"/>
                        </a>
                    </t>
                </div>

                <!-- Tab content inserted here -->
                <t t-out="0"/>
            </div>
        </t>
    </template>

    <!-- ─── Stream Tab ───────────────────────────────────────────── -->
    <template id="teacher_classroom_stream" name="Teacher Classroom — Stream">
        <t t-call="edu_portal.teacher_classroom">
            <div class="grid" style="grid-template-columns:1.4fr 1fr;gap:16px;">
                <!-- Left: compose + feed -->
                <div>
                    <!-- Compose box -->
                    <div class="card" style="margin-bottom:16px;">
                        <div style="display:flex;gap:12px;">
                            <div class="avatar"><t t-esc="user_initials or ''"/></div>
                            <div style="flex:1;">
                                <form method="post" action="/portal/teacher/classroom/post" id="stream-post-form">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="classroom_id" t-att-value="classroom.get('id', '')"/>
                                    <textarea name="body"
                                              t-att-placeholder="'Post to %s... Students will be notified.' % classroom.get('code', '')"
                                              style="width:100%;min-height:64px;resize:vertical;border:1px solid var(--border);border-radius:8px;padding:10px;background:var(--bg-sunk);font-size:13.5px;font-family:var(--font-ui);"/>
                                    <div style="display:flex;gap:6px;margin-top:8px;justify-content:space-between;">
                                        <div style="display:flex;gap:6px;">
                                            <button type="button" class="btn sm">
                                                <t t-call="edu_portal.icon"><t t-set="ico" t-value="'paper'"/><t t-set="sz" t-value="12"/></t> Attach
                                            </button>
                                            <label style="display:flex;gap:6px;align-items:center;font-size:12px;color:var(--ink-soft);">
                                                <input type="checkbox" name="pin"/> Pin post
                                            </label>
                                        </div>
                                        <button type="submit" class="btn primary sm">Post</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Posts feed -->
                    <t t-foreach="stream_posts or []" t-as="post">
                        <div class="card" style="margin-bottom:12px;">
                            <div style="display:flex;gap:12px;">
                                <div class="avatar"><t t-esc="post.get('author_initials', '')"/></div>
                                <div style="flex:1;">
                                    <div style="display:flex;justify-content:space-between;align-items:baseline;">
                                        <div>
                                            <div style="font-weight:500;"><t t-esc="post.get('author_name', '')"/></div>
                                            <div style="font-size:11.5px;color:var(--ink-softer);"><t t-esc="post.get('time_ago', '')"/></div>
                                        </div>
                                        <t t-if="post.get('pinned')">
                                            <span class="pill accent">
                                                <t t-call="edu_portal.icon"><t t-set="ico" t-value="'flag'"/><t t-set="sz" t-value="10"/></t> Pinned
                                            </span>
                                        </t>
                                    </div>
                                    <t t-if="post.get('title')">
                                        <div style="font-weight:500;font-size:15px;margin-top:8px;">
                                            <t t-esc="post.get('title', '')"/>
                                        </div>
                                    </t>
                                    <div style="font-size:13.5px;color:var(--ink-soft);margin-top:4px;line-height:1.55;">
                                        <t t-esc="post.get('body', '')"/>
                                    </div>
                                    <div style="display:flex;gap:4px;margin-top:10px;">
                                        <button class="btn ghost sm">
                                            <t t-call="edu_portal.icon"><t t-set="ico" t-value="'flag'"/><t t-set="sz" t-value="11"/></t>
                                            <t t-esc="'Unpin' if post.get('pinned') else 'Pin'"/>
                                        </button>
                                        <button class="btn ghost sm">
                                            <t t-call="edu_portal.icon"><t t-set="ico" t-value="'pen'"/><t t-set="sz" t-value="11"/></t> Edit
                                        </button>
                                        <button class="btn ghost sm">Archive</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                    <t t-if="not stream_posts">
                        <div class="empty">No posts yet. Share an update with your class.</div>
                    </t>
                </div>

                <!-- Right: weekly plan + quick links -->
                <div>
                    <!-- Weekly plan -->
                    <div class="card" style="margin-bottom:16px;">
                        <h3 class="card-title">Weekly plan</h3>
                        <div class="card-sub">Week <t t-esc="classroom.get('current_week', 0)"/> of <t t-esc="classroom.get('total_weeks', 15)"/></div>
                        <t t-foreach="syllabus_items or []" t-as="w">
                            <div style="display:grid;grid-template-columns:auto 1fr auto;gap:14px;padding:8px 0;align-items:center;"
                                 t-att-style="'border-top:1px solid var(--border);' if not w_first else ''">
                                <div style="width:24px;height:24px;border-radius:6px;display:grid;place-items:center;font-family:var(--font-mono);font-size:10px;"
                                     t-att-style="'background:var(--accent-soft);color:var(--accent-ink);' if w.get('current') else 'background:var(--bg-sunk);color:var(--ink-soft);' if w.get('done') else 'border:1px dashed var(--border);color:var(--ink-soft);'">
                                    <t t-if="w.get('done')">
                                        <t t-call="edu_portal.icon"><t t-set="ico" t-value="'check'"/><t t-set="sz" t-value="12"/></t>
                                    </t>
                                    <t t-else="">W<t t-esc="w.get('week', '')"/></t>
                                </div>
                                <div style="font-size:13px;" t-att-style="'font-weight:500;' if w.get('current') else ''">
                                    <t t-esc="w.get('topic', '')"/>
                                </div>
                                <t t-if="w.get('current')">
                                    <span class="pill accent">This week</span>
                                </t>
                            </div>
                        </t>
                    </div>

                    <!-- Quick links -->
                    <div class="card">
                        <h3 class="card-title">Quick links</h3>
                        <div class="card-sub">edu.classroom actions</div>
                        <t t-foreach="[
                            ('check', 'Attendance Register', 'edu.attendance.register'),
                            ('paper', 'Exam Papers', 'edu.exam.paper'),
                            ('pen', 'Continuous Assessments', 'edu.assessment.record'),
                            ('grid', 'Published Results', 'edu.result.student'),
                        ]" t-as="ql">
                            <div style="display:flex;gap:10px;padding:8px 0;align-items:center;"
                                 t-att-style="'border-top:1px solid var(--border);' if not ql_first else ''">
                                <div style="width:28px;height:28px;border-radius:6px;background:var(--bg-sunk);display:grid;place-items:center;">
                                    <t t-call="edu_portal.icon"><t t-set="ico" t-value="ql[0]"/><t t-set="sz" t-value="13"/></t>
                                </div>
                                <div style="flex:1;">
                                    <div style="font-size:13px;font-weight:500;"><t t-esc="ql[1]"/></div>
                                    <div class="mono" style="font-size:10.5px;color:var(--ink-softer);"><t t-esc="ql[2]"/></div>
                                </div>
                                <t t-call="edu_portal.icon"><t t-set="ico" t-value="'caretRight'"/><t t-set="sz" t-value="12"/></t>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ─── Content Tab ──────────────────────────────────────────── -->
    <template id="teacher_classroom_content" name="Teacher Classroom — Content">
        <t t-call="edu_portal.teacher_classroom">
            <div class="grid cols-3">
                <t t-foreach="content_items or []" t-as="ci">
                    <div class="card" style="display:flex;flex-direction:column;gap:10px;">
                        <div style="aspect-ratio:4/3;border-radius:8px;background:repeating-linear-gradient(45deg,var(--bg-sunk),var(--bg-sunk) 8px,var(--bg-hover) 8px,var(--bg-hover) 16px);display:grid;place-items:center;font-family:var(--font-mono);font-size:11px;color:var(--ink-softer);">
                            [<t t-esc="ci.get('file_type', 'PDF')"/>]
                        </div>
                        <div style="font-weight:500;font-size:13.5px;"><t t-esc="ci.get('title', '')"/></div>
                        <div style="font-size:11.5px;color:var(--ink-softer);">
                            Uploaded <t t-esc="ci.get('uploaded_date', '')"/> · <t t-esc="ci.get('size', '')"/>
                        </div>
                    </div>
                </t>
                <t t-if="not content_items">
                    <div class="empty" style="grid-column:1/-1;">No content uploaded yet.</div>
                </t>
            </div>
        </t>
    </template>

    <!-- ─── Attendance Tab ───────────────────────────────────────── -->
    <template id="teacher_classroom_attendance" name="Teacher Classroom — Attendance">
        <t t-call="edu_portal.teacher_classroom">
            <!-- Stats row -->
            <div class="grid cols-4" style="margin-bottom:16px;">
                <t t-foreach="[
                    ('Students', classroom_att_students or '0', classroom_att_students_sub or ''),
                    ('Sessions held', classroom_att_sessions or '0', classroom_att_sessions_sub or ''),
                    ('Average', classroom_att_avg or '—', classroom_att_avg_trend or ''),
                    ('Low attendance', classroom_att_low or '0', classroom_att_low_sub or ''),
                ]" t-as="stat">
                    <div class="card">
                        <div class="card-sub" style="margin:0;"><t t-esc="stat[0]"/></div>
                        <div class="display" style="font-size:30px;margin-top:4px;"><t t-esc="stat[1]"/></div>
                        <div style="font-size:11.5px;color:var(--ink-softer);"><t t-esc="stat[2]"/></div>
                    </div>
                </t>
            </div>

            <!-- Attendance sheets table -->
            <div class="card" style="padding:0;overflow:hidden;">
                <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--border);">
                    <div>
                        <div style="font-weight:500;">Attendance sheets</div>
                        <div class="mono" style="font-size:11px;color:var(--ink-softer);">
                            edu.attendance.sheet · register #R-<t t-esc="classroom.get('id', '')"/>
                        </div>
                    </div>
                    <div style="display:flex;gap:8px;">
                        <button class="btn sm">Matrix view</button>
                        <form t-att-action="'/portal/teacher/classroom/%s/attendance/create' % classroom.get('id', '')" method="post" style="display:inline;">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn primary sm">
                                <t t-call="edu_portal.icon"><t t-set="ico" t-value="'plus'"/><t t-set="sz" t-value="11"/></t> New session
                            </button>
                        </form>
                    </div>
                </div>
                <table class="tbl">
                    <thead><tr><th>Date</th><th>Time</th><th>State</th><th>Present</th><th>Rate</th><th/></tr></thead>
                    <tbody>
                        <t t-foreach="attendance_sheets or []" t-as="sh">
                            <tr>
                                <td style="font-weight:500;"><t t-esc="sh.get('date', '')"/></td>
                                <td class="mono"><t t-esc="sh.get('time', '')"/></td>
                                <td>
                                    <span class="pill"
                                          t-att-class="'warn' if sh.get('state') == 'in_progress' else 'success'">
                                        <t t-esc="'In progress' if sh.get('state') == 'in_progress' else 'Submitted'"/>
                                    </span>
                                </td>
                                <td class="mono"><t t-esc="sh.get('present', 0)"/>/<t t-esc="sh.get('total', 0)"/></td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div class="bar" style="width:80px;">
                                            <span t-att-style="'width:' + str(sh.get('rate', 0)) + '%;background:' + ('var(--success)' if sh.get('rate', 0) >= 90 else 'var(--warn)' if sh.get('rate', 0) >= 80 else 'var(--danger)') + ';'"/>
                                        </div>
                                        <span class="mono" style="font-size:11px;min-width:30px;"><t t-esc="sh.get('rate', 0)"/>%</span>
                                    </div>
                                </td>
                                <td>
                                    <t t-if="sh.get('state') in ('in_progress', 'draft')">
                                        <a t-att-href="'/portal/teacher/classroom/%s/attendance/%s' % (classroom.get('id', ''), sh.get('id', ''))" class="btn primary sm">
                                            Continue <t t-call="edu_portal.icon"><t t-set="ico" t-value="'caretRight'"/><t t-set="sz" t-value="11"/></t>
                                        </a>
                                    </t>
                                    <t t-elif="sh.get('state') == 'submitted'">
                                        <span class="pill success">Submitted</span>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <!-- Active sheet: student roster for marking -->
            <t t-if="active_sheet_id and roster">
                <div id="attendance-roster" class="card" style="padding:0;overflow:hidden;margin-top:16px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--border);">
                        <div>
                            <div style="font-weight:500;">Mark attendance</div>
                            <div class="mono" style="font-size:11px;color:var(--ink-softer);">
                                Sheet #<t t-esc="active_sheet_id"/> · <t t-esc="len(roster)"/> students
                            </div>
                        </div>
                        <div style="display:flex;gap:8px;">
                            <form t-att-action="'/portal/teacher/classroom/%s/attendance/%s/mark-all' % (classroom.get('id', ''), active_sheet_id)" method="post" style="display:inline;">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input type="hidden" name="status" value="present"/>
                                <button type="submit" class="btn sm">Mark all present</button>
                            </form>
                            <form t-att-action="'/portal/teacher/classroom/%s/attendance/%s/submit' % (classroom.get('id', ''), active_sheet_id)" method="post" style="display:inline;">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn primary sm">Submit sheet</button>
                            </form>
                        </div>
                    </div>
                    <table class="tbl">
                        <thead><tr><th/><th>Student</th><th>ID</th><th>Status</th><th>Actions</th></tr></thead>
                        <tbody>
                            <t t-foreach="roster" t-as="r">
                                <tr t-att-data-student-id="r.get('id', '')" t-att-data-att-status="r.get('status', '')">
                                    <td style="width:40px;">
                                        <div class="avatar" style="width:28px;height:28px;font-size:10px;"
                                             t-att-style="'background:oklch(94% 0.04 ' + str(r.get('hue', 0)) + ');color:oklch(35% 0.08 ' + str(r.get('hue', 0)) + ');'">
                                            <t t-esc="r.get('initials', '')"/>
                                        </div>
                                    </td>
                                    <td style="font-weight:500;"><t t-esc="r.get('name', '')"/></td>
                                    <td class="mono"><t t-esc="r.get('student_no', '')"/></td>
                                    <td>
                                        <span class="pill"
                                              t-att-class="'success' if r.get('status') == 'present' else 'danger' if r.get('status') == 'absent' else 'warn' if r.get('status') == 'late' else 'info' if r.get('status') == 'excused' else ''">
                                            <t t-if="r.get('status')"><t t-esc="r.get('status', '').title()"/></t>
                                            <t t-else="">—</t>
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:4px;">
                                            <t t-foreach="[('present', 'P'), ('absent', 'A'), ('late', 'L'), ('excused', 'E')]" t-as="st">
                                                <form t-att-action="'/portal/teacher/classroom/%s/attendance/mark' % classroom.get('id', '')" method="post" style="display:inline;">
                                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                    <input type="hidden" name="sheet_id" t-att-value="active_sheet_id"/>
                                                    <input type="hidden" name="student_id" t-att-value="r.get('id', '')"/>
                                                    <input type="hidden" name="status" t-att-value="st[0]"/>
                                                    <button type="submit"
                                                            class="att-btn"
                                                            t-att-class="'active att-btn--success' if st[0] == 'present' and r.get('status') == 'present' else 'active att-btn--danger' if st[0] == 'absent' and r.get('status') == 'absent' else 'active att-btn--warn' if st[0] == 'late' and r.get('status') == 'late' else 'active att-btn--info' if st[0] == 'excused' and r.get('status') == 'excused' else ''"
                                                            t-att-data-status="st[0]">
                                                        <t t-esc="st[1]"/>
                                                    </button>
                                                </form>
                                            </t>
                                        </div>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- ─── Exams Tab ────────────────────────────────────────────── -->
    <template id="teacher_classroom_exams" name="Teacher Classroom — Exams">
        <t t-call="edu_portal.teacher_classroom">
            <div class="card" style="padding:0;overflow:hidden;">
                <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--border);">
                    <div>
                        <div style="font-weight:500;">Exam papers</div>
                        <div class="mono" style="font-size:11px;color:var(--ink-softer);">
                            edu.exam.paper · batch <t t-esc="classroom.get('code', '')"/>
                        </div>
                    </div>
                </div>
                <table class="tbl">
                    <thead><tr><th>Paper</th><th>Session</th><th>Max · Pass</th><th>State</th><th>Marksheets</th><th/></tr></thead>
                    <tbody>
                        <t t-foreach="exam_papers or []" t-as="ep">
                            <tr>
                                <td style="font-weight:500;"><t t-esc="ep.get('title', '')"/></td>
                                <td style="font-size:12.5px;color:var(--ink-soft);"><t t-esc="ep.get('session', '')"/></td>
                                <td class="mono"><t t-esc="ep.get('max_marks', 0)"/> · <t t-esc="ep.get('pass_marks', 0)"/></td>
                                <td>
                                    <span class="pill"
                                          t-att-class="'warn' if ep.get('state') == 'marks_entry' else 'success' if ep.get('state') == 'published' else 'info'">
                                        <t t-esc="ep.get('state_label', '')"/>
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div class="bar" style="width:80px;">
                                            <span t-att-style="'width:' + str(ep.get('marked_pct', 0)) + '%;background:var(--accent);'"/>
                                        </div>
                                        <span class="mono" style="font-size:11px;min-width:48px;">
                                            <t t-esc="ep.get('marked', 0)"/>/<t t-esc="ep.get('total', 0)"/>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <t t-if="ep.get('state') == 'marks_entry'">
                                        <a href="/portal/marking" class="btn primary sm">
                                            Enter marks <t t-call="edu_portal.icon"><t t-set="ico" t-value="'caretRight'"/><t t-set="sz" t-value="11"/></t>
                                        </a>
                                    </t>
                                    <t t-else="">
                                        <button class="btn sm">
                                            View <t t-call="edu_portal.icon"><t t-set="ico" t-value="'caretRight'"/><t t-set="sz" t-value="11"/></t>
                                        </button>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <!-- ─── Assessments Tab ──────────────────────────────────────── -->
    <template id="teacher_classroom_assessments" name="Teacher Classroom — Assessments">
        <t t-call="edu_portal.teacher_classroom">
            <div class="card" style="padding:0;overflow:hidden;">
                <div style="padding:12px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;">
                    <div>
                        <div style="font-weight:500;">Continuous assessment records</div>
                        <div class="mono" style="font-size:11px;color:var(--ink-softer);">edu.continuous.assessment.record</div>
                    </div>
                    <button class="btn primary sm">
                        <t t-call="edu_portal.icon"><t t-set="ico" t-value="'plus'"/><t t-set="sz" t-value="11"/></t> New assessment
                    </button>
                </div>
                <table class="tbl">
                    <thead><tr><th>Date</th><th>Category</th><th>Title</th><th>Max</th><th>Avg</th><th>Submissions</th><th/></tr></thead>
                    <tbody>
                        <t t-foreach="assessment_records or []" t-as="ar">
                            <tr>
                                <td class="mono"><t t-esc="ar.get('date', '')"/></td>
                                <td><span class="pill"><t t-esc="ar.get('category', '')"/></span></td>
                                <td style="font-weight:500;"><t t-esc="ar.get('title', '')"/></td>
                                <td class="mono"><t t-esc="ar.get('max', 0)"/></td>
                                <td class="mono"><t t-esc="ar.get('avg', 0)"/>/<t t-esc="ar.get('max', 0)"/></td>
                                <td class="mono"><t t-esc="ar.get('submissions', '')"/></td>
                                <td>
                                    <button class="btn ghost sm">
                                        Open <t t-call="edu_portal.icon"><t t-set="ico" t-value="'caretRight'"/><t t-set="sz" t-value="11"/></t>
                                    </button>
                                </td>
                            </tr>
                        </t>
                        <t t-if="not assessment_records">
                            <tr><td colspan="7" class="empty" style="border:0;">No assessment records yet.</td></tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <!-- ─── Results Tab ──────────────────────────────────────────── -->
    <template id="teacher_classroom_results" name="Teacher Classroom — Results">
        <t t-call="edu_portal.teacher_classroom">
            <div class="card" style="padding:0;overflow:hidden;">
                <div style="padding:12px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;">
                    <div>
                        <div style="font-weight:500;">Published results — <t t-esc="classroom.get('code', '')"/></div>
                        <div class="mono" style="font-size:11px;color:var(--ink-softer);">
                            edu.result.student · result_session: <t t-esc="results_session_label or 'Latest'"/>
                        </div>
                    </div>
                    <button class="btn sm">
                        <t t-call="edu_portal.icon"><t t-set="ico" t-value="'download'"/><t t-set="sz" t-value="11"/></t> Export
                    </button>
                </div>
                <table class="tbl">
                    <thead><tr><th>Student</th><th>ID</th><th>CA (<t t-esc="results_ca_max or 30"/>)</th><th>Internal (<t t-esc="results_int_max or 20"/>)</th><th>External (<t t-esc="results_ext_max or 50"/>)</th><th>Total</th><th>Grade</th></tr></thead>
                    <tbody>
                        <t t-foreach="results_rows or []" t-as="rr">
                            <tr>
                                <td style="font-weight:500;"><t t-esc="rr.get('name', '')"/></td>
                                <td class="mono"><t t-esc="rr.get('student_id', '')"/></td>
                                <td class="mono"><t t-esc="rr.get('ca', 0)"/></td>
                                <td class="mono"><t t-esc="rr.get('internal', 0)"/></td>
                                <td class="mono"><t t-esc="rr.get('external', 0)"/></td>
                                <td class="mono" style="font-weight:600;"><t t-esc="rr.get('total', 0)"/></td>
                                <td>
                                    <span class="pill"
                                          t-att-class="'danger' if rr.get('grade') == 'F' else 'success' if rr.get('grade', '').startswith('A') else ''">
                                        <t t-esc="rr.get('grade', '')"/>
                                    </span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <!-- ─── People Tab ───────────────────────────────────────────── -->
    <template id="teacher_classroom_people" name="Teacher Classroom — People">
        <t t-call="edu_portal.teacher_classroom">
            <div class="card" style="padding:0;overflow:hidden;">
                <div style="padding:12px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;">
                    <div>
                        <div style="font-weight:500;">Enrolled students</div>
                        <div class="mono" style="font-size:11px;color:var(--ink-softer);">
                            edu.student.progression.history · state=active
                        </div>
                    </div>
                    <button class="btn sm">
                        <t t-call="edu_portal.icon"><t t-set="ico" t-value="'download'"/><t t-set="sz" t-value="11"/></t> Export
                    </button>
                </div>
                <table class="tbl">
                    <thead><tr><th/><th>Student</th><th>ID</th><th>Attendance</th><th>Avg mark</th><th>Flags</th></tr></thead>
                    <tbody>
                        <t t-foreach="people_rows or []" t-as="pr">
                            <tr>
                                <td style="width:40px;">
                                    <div class="avatar" style="width:28px;height:28px;font-size:10px;"
                                         t-att-style="'background:oklch(94% 0.04 ' + str(pr.get('hue', 0)) + ');color:oklch(35% 0.08 ' + str(pr.get('hue', 0)) + ');'">
                                        <t t-esc="pr.get('initials', '')"/>
                                    </div>
                                </td>
                                <td style="font-weight:500;"><t t-esc="pr.get('name', '')"/></td>
                                <td class="mono"><t t-esc="pr.get('student_id', '')"/></td>
                                <td class="mono"
                                    t-att-style="'color:var(--danger);' if pr.get('attendance_rate', 100) &lt; 80 else 'color:var(--ink-soft);'">
                                    <t t-esc="pr.get('attendance_rate', '')"/>%
                                </td>
                                <td class="mono"><t t-esc="pr.get('avg', '')"/></td>
                                <td style="display:flex;gap:4px;">
                                    <t t-if="pr.get('at_risk')"><span class="pill danger">at-risk</span></t>
                                    <t t-if="pr.get('low_attendance')"><span class="pill warn">low-att</span></t>
                                    <t t-if="pr.get('behavior_flag')"><span class="pill info">behavior</span></t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

</odoo>
