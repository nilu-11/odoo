<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Backend views for edu.classroom.post — admin moderation.

         Teachers post via the portal UI (HTMX composer); admins can
         read / edit / archive any post from the backend.
    ══════════════════════════════════════════════════════ -->

    <record id="view_edu_classroom_post_list" model="ir.ui.view">
        <field name="name">edu.classroom.post.list</field>
        <field name="model">edu.classroom.post</field>
        <field name="arch" type="xml">
            <list string="Classroom Posts" decoration-muted="not active">
                <field name="posted_at"/>
                <field name="classroom_id"/>
                <field name="author_id"/>
                <field name="pinned" widget="boolean_toggle"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_edu_classroom_post_form" model="ir.ui.view">
        <field name="name">edu.classroom.post.form</field>
        <field name="model">edu.classroom.post</field>
        <field name="arch" type="xml">
            <form string="Classroom Post">
                <header>
                    <button name="action_toggle_pin"
                            type="object"
                            string="Toggle Pin"
                            class="btn-secondary"/>
                    <button name="action_archive_post"
                            type="object"
                            string="Archive"
                            class="btn-warning"
                            confirm="Archive this post? Students will no longer see it."/>
                </header>
                <sheet>
                    <widget name="web_ribbon"
                            title="Archived"
                            bg_color="bg-danger"
                            invisible="active"/>
                    <group>
                        <group>
                            <field name="classroom_id"/>
                            <field name="author_id" readonly="1"/>
                            <field name="author_employee_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="posted_at" readonly="1"/>
                            <field name="pinned"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Body"/>
                    <field name="body"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_edu_classroom_post" model="ir.actions.act_window">
        <field name="name">Classroom Posts</field>
        <field name="res_model">edu.classroom.post</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
