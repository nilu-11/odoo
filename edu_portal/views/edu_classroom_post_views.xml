<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_edu_classroom_post_list" model="ir.ui.view">
        <field name="name">edu.classroom.post.list</field>
        <field name="model">edu.classroom.post</field>
        <field name="arch" type="xml">
            <list>
                <field name="classroom_id"/>
                <field name="author_id"/>
                <field name="pinned"/>
                <field name="posted_at"/>
            </list>
        </field>
    </record>

    <record id="view_edu_classroom_post_form" model="ir.ui.view">
        <field name="name">edu.classroom.post.form</field>
        <field name="model">edu.classroom.post</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="classroom_id"/>
                        <field name="author_id" readonly="1"/>
                        <field name="pinned"/>
                        <field name="posted_at"/>
                        <field name="active" invisible="1"/>
                    </group>
                    <field name="body" widget="html"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_edu_classroom_post" model="ir.actions.act_window">
        <field name="name">Classroom Posts</field>
        <field name="res_model">edu.classroom.post</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
