<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Student Payment sequence -->
        <record id="seq_edu_student_payment" model="ir.sequence">
            <field name="name">Student Payment</field>
            <field name="code">edu.student.payment</field>
            <field name="prefix">PAY/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

    </data>
</odoo>
