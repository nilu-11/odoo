<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Student Payment — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_payment_search" model="ir.ui.view">
        <field name="name">edu.student.payment.search</field>
        <field name="model">edu.student.payment</field>
        <field name="arch" type="xml">
            <search string="Student Payments">
                <field name="payment_no"/>
                <field name="enrollment_id"/>
                <field name="student_id"/>
                <field name="reference"/>
                <filter string="Draft" name="state_draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Posted" name="state_posted"
                        domain="[('state','=','posted')]"/>
                <filter string="Cancelled" name="state_cancelled"
                        domain="[('state','=','cancelled')]"/>
                <separator/>
                <filter string="Unallocated" name="unallocated"
                        domain="[('unallocated_amount','>',0)]"/>
                <group name="group_by">
                    <filter string="Payment Method" name="group_method"
                            context="{'group_by': 'payment_method'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Payment Date" name="group_date"
                            context="{'group_by': 'payment_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Payment — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_payment_list" model="ir.ui.view">
        <field name="name">edu.student.payment.list</field>
        <field name="model">edu.student.payment</field>
        <field name="arch" type="xml">
            <list string="Student Payments"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'posted'"
                  decoration-muted="state == 'cancelled'">
                <field name="payment_no"/>
                <field name="enrollment_id"/>
                <field name="student_id" optional="show"/>
                <field name="payment_date"/>
                <field name="amount" sum="Total Amount"/>
                <field name="payment_method" optional="show"/>
                <field name="reference" optional="show"/>
                <field name="allocated_amount" sum="Total Allocated"/>
                <field name="unallocated_amount" sum="Total Unallocated" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'posted'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Payment — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_payment_form" model="ir.ui.view">
        <field name="name">edu.student.payment.form</field>
        <field name="model">edu.student.payment</field>
        <field name="arch" type="xml">
            <form string="Student Payment">
                <header>
                    <button name="action_allocate_payment" type="object"
                            string="Auto-Allocate" class="btn-secondary"
                            invisible="state != 'draft'"
                            confirm="Auto-allocate unallocated amount to outstanding dues?"/>
                    <button name="action_post" type="object"
                            string="Post" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state not in ('draft', 'posted')"
                            confirm="Cancel this payment? Allocated dues will be updated."/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="payment_no" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Payment Details">
                            <field name="enrollment_id"
                                   readonly="state != 'draft'"/>
                            <field name="student_id"/>
                            <field name="applicant_profile_id"/>
                            <field name="payment_date"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Reference">
                            <field name="payment_method"
                                   readonly="state != 'draft'"/>
                            <field name="reference"
                                   readonly="state != 'draft'"/>
                            <field name="allocated_amount"/>
                            <field name="unallocated_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Allocations" name="allocations">
                            <field name="allocation_ids"
                                   readonly="state == 'posted'">
                                <list editable="bottom">
                                    <field name="due_id"
                                           domain="[('enrollment_id','=',parent.enrollment_id),
                                                     ('state','in',['due','partial','overdue'])]"/>
                                    <field name="fee_head_id" readonly="1"/>
                                    <field name="allocated_amount"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Payment — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_student_payment" model="ir.actions.act_window">
        <field name="name">Student Payments</field>
        <field name="res_model">edu.student.payment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_student_payment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record your first student payment</p>
            <p>Student payments track fee collections and allocate amounts to outstanding dues.</p>
        </field>
    </record>
</odoo>
