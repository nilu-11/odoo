<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Student Fee Plan — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_fee_plan_search" model="ir.ui.view">
        <field name="name">edu.student.fee.plan.search</field>
        <field name="model">edu.student.fee.plan</field>
        <field name="arch" type="xml">
            <search string="Student Fee Plans">
                <field name="enrollment_id"/>
                <field name="student_id"/>
                <field name="program_id"/>
                <field name="batch_id"/>
                <filter string="Draft" name="state_draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="state_confirmed"
                        domain="[('state','=','confirmed')]"/>
                <filter string="Active" name="state_active"
                        domain="[('state','=','active')]"/>
                <separator/>
                <group name="group_by">
                    <filter string="Program" name="group_program"
                            context="{'group_by': 'program_id'}"/>
                    <filter string="Batch" name="group_batch"
                            context="{'group_by': 'batch_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Fee Plan — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_fee_plan_list" model="ir.ui.view">
        <field name="name">edu.student.fee.plan.list</field>
        <field name="model">edu.student.fee.plan</field>
        <field name="arch" type="xml">
            <list string="Student Fee Plans" decoration-info="state == 'draft'"
                  decoration-success="state == 'active'"
                  decoration-muted="state == 'closed'">
                <field name="enrollment_id"/>
                <field name="student_id" optional="show"/>
                <field name="program_id"/>
                <field name="batch_id"/>
                <field name="fee_structure_id" optional="show"/>
                <field name="total_original" sum="Total Original"/>
                <field name="total_discount" sum="Total Discount"/>
                <field name="total_final" sum="Total Final"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'active'"
                       decoration-muted="state == 'closed'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Fee Plan — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_student_fee_plan_form" model="ir.ui.view">
        <field name="name">edu.student.fee.plan.form</field>
        <field name="model">edu.student.fee.plan</field>
        <field name="arch" type="xml">
            <form string="Student Fee Plan">
                <header>
                    <button name="action_confirm" type="object"
                            string="Confirm" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_activate" type="object"
                            string="Activate" class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_close" type="object"
                            string="Close"
                            invisible="state != 'active'"
                            confirm="Close this fee plan?"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state not in ('confirmed', 'closed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Enrollment">
                            <field name="enrollment_id"/>
                            <field name="student_id"/>
                            <field name="applicant_profile_id"/>
                        </group>
                        <group string="Academic Context">
                            <field name="program_id"/>
                            <field name="batch_id"/>
                            <field name="academic_year_id"/>
                            <field name="fee_structure_id"/>
                        </group>
                    </group>
                    <group string="Summary">
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_original"/>
                            <field name="total_discount"/>
                            <field name="total_final"/>
                        </group>
                        <group>
                            <field name="line_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Fee Plan Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="program_term_id"/>
                                    <field name="progression_no" optional="hide"/>
                                    <field name="fee_head_id"/>
                                    <field name="fee_nature" optional="show"/>
                                    <field name="original_amount"/>
                                    <field name="discount_amount"/>
                                    <field name="final_amount"/>
                                    <field name="schedule_template_id" optional="show"/>
                                    <field name="is_required_for_enrollment" optional="show"/>
                                    <field name="due_count" optional="show"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Student Fee Plan — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_student_fee_plan" model="ir.actions.act_window">
        <field name="name">Student Fee Plans</field>
        <field name="res_model">edu.student.fee.plan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_student_fee_plan_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No fee plans yet</p>
            <p>Student fee plans are generated from enrollment records linked to fee structures.</p>
        </field>
    </record>
</odoo>
