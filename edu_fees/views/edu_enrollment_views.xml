<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Enrollment Form — Finance Smart Buttons
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_enrollment_form_inherit_fees" model="ir.ui.view">
        <field name="name">edu.enrollment.form.inherit.fees</field>
        <field name="model">edu.enrollment</field>
        <field name="inherit_id" ref="edu_enrollment.view_edu_enrollment_form"/>
        <field name="arch" type="xml">

            <!-- ── Smart buttons for fee plans, dues, payments ── -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_fee_plans"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-list-alt"
                        invisible="fee_plan_count == 0">
                    <field name="fee_plan_count"
                           string="Fee Plans" widget="statinfo"/>
                </button>
                <button name="action_view_fee_dues"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-calendar-check-o"
                        invisible="fee_due_count == 0">
                    <field name="fee_due_count"
                           string="Dues" widget="statinfo"/>
                </button>
                <button name="action_view_payments"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money"
                        invisible="payment_count == 0">
                    <field name="payment_count"
                           string="Payments" widget="statinfo"/>
                </button>
            </xpath>

            <!-- ── Generate Fee Plan button in header ── -->
            <xpath expr="//button[@name='action_activate']" position="before">
                <button name="action_generate_fee_plan" type="object"
                        string="Generate Fee Plan" class="btn-secondary"
                        invisible="state != 'draft' or fee_plan_count > 0 or not fee_structure_id"/>
                <button name="action_generate_all_dues" type="object"
                        string="Generate All Dues" class="btn-secondary"
                        invisible="state != 'draft' or fee_plan_count == 0"/>
            </xpath>

            <!-- ── Override button in header ── -->
            <xpath expr="//button[@name='action_activate']" position="after">
                <!-- TODO: re-enable once full fee payment flow is in place -->
                <button name="action_override_enrollment_fee_block" type="object"
                        string="Override Fee Block" class="btn-warning"
                        invisible="True"
                        groups="edu_fees.group_enrollment_fee_override"
                        confirm="Override the enrollment fee payment requirement?"/>
            </xpath>

            <!-- ── Fee eligibility banner after existing block reason banner ── -->
            <xpath expr="//div[contains(@class,'alert-warning')]" position="after">
                <!-- TODO: re-enable once full fee payment flow is in place -->
                <div class="alert alert-danger mb-3"
                     invisible="True">
                    <i class="fa fa-ban me-2"/>
                    <strong>Fee Payment Required:</strong>
                    <field name="enrollment_fee_block_detail" readonly="1"
                           nolabel="1" class="d-inline" widget="text"/>
                </div>
                <div class="alert alert-warning mb-3"
                     invisible="not enrollment_fee_override_used">
                    <i class="fa fa-exclamation-circle me-2"/>
                    <strong>Fee Override Active:</strong>
                    Enrollment fee block overridden by
                    <field name="enrollment_fee_override_by" readonly="1"
                           nolabel="1" class="d-inline"/>
                    on <field name="enrollment_fee_override_date" readonly="1"
                              nolabel="1" class="d-inline"/>
                </div>
            </xpath>

            <!-- ── Enrollment Fee Summary in Financial Snapshot page ── -->
            <xpath expr="//page[@name='financial']//div[contains(@class,'text-muted')]" position="before">
                <group>
                    <group string="Enrollment Fee Requirement">
                        <field name="enrollment_required_total" readonly="1"/>
                        <field name="enrollment_required_paid" readonly="1"/>
                        <field name="enrollment_required_balance" readonly="1"
                               decoration-danger="enrollment_required_balance > 0"
                               decoration-success="enrollment_required_balance == 0"/>
                        <field name="enrollment_fee_eligible" readonly="1"
                               widget="boolean"/>
                    </group>
                    <group string="Fee Override" invisible="not enrollment_fee_override_used">
                        <field name="enrollment_fee_override_used" readonly="1"/>
                        <field name="enrollment_fee_override_by" readonly="1"/>
                        <field name="enrollment_fee_override_date" readonly="1"/>
                        <field name="enrollment_fee_override_reason"
                               readonly="enrollment_fee_override_used"/>
                    </group>
                    <group string="Fee Override"
                           invisible="enrollment_fee_override_used or enrollment_fee_eligible">
                        <field name="enrollment_fee_override_reason"
                               placeholder="Enter reason before overriding..."/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Enrollment List — Add fee eligibility column
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_enrollment_list_inherit_fees" model="ir.ui.view">
        <field name="name">edu.enrollment.list.inherit.fees</field>
        <field name="model">edu.enrollment</field>
        <field name="inherit_id" ref="edu_enrollment.view_edu_enrollment_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="enrollment_fee_eligible" optional="show"
                       string="Fees OK" widget="boolean"/>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Enrollment Search — Add fee filters
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_enrollment_search_inherit_fees" model="ir.ui.view">
        <field name="name">edu.enrollment.search.inherit.fees</field>
        <field name="model">edu.enrollment</field>
        <field name="inherit_id" ref="edu_enrollment.view_edu_enrollment_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter string="Fee Eligible" name="fee_eligible"
                        domain="[('enrollment_fee_eligible','=',True)]"/>
                <filter string="Fee Blocked" name="fee_blocked"
                        domain="[('enrollment_fee_eligible','=',False)]"/>
                <filter string="Fee Override" name="fee_override"
                        domain="[('enrollment_fee_override_used','=',True)]"/>
            </xpath>
        </field>
    </record>
</odoo>
