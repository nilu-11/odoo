<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ======================================================
         Privilege (res.groups.privilege)
         Classroom access is a separate privilege under the
         shared Education module category.
    ====================================================== -->
    <record id="privilege_classroom_access" model="res.groups.privilege">
        <field name="name">Classroom</field>
        <field name="sequence">70</field>
        <field name="category_id" ref="edu_academic_structure.module_category_education"/>
    </record>

    <!-- ======================================================
         Security Groups (res.groups)
         Hierarchy: Admin → Teacher → Viewer
         Each higher group implies the one below it.
    ====================================================== -->

    <!-- Classroom Viewer: read-only access -->
    <record id="group_classroom_viewer" model="res.groups">
        <field name="name">Viewer</field>
        <field name="privilege_id" ref="privilege_classroom_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Read-only access to classroom records.</field>
    </record>

    <!-- Classroom Teacher: read and write own classrooms -->
    <record id="group_classroom_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="privilege_id" ref="privilege_classroom_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_classroom_viewer'))]"/>
        <field name="comment">Can read and write classrooms where they are the assigned teacher.</field>
    </record>

    <!-- Classroom Admin: full access to all classrooms -->
    <record id="group_classroom_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="privilege_classroom_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_classroom_teacher'))]"/>
        <field name="comment">Full access to all classroom records including creation, deletion, and state management.</field>
    </record>

    <!-- ======================================================
         Record Rules
    ====================================================== -->

    <!-- Teachers can only read/write classrooms where they are assigned.
         Does NOT apply to Classroom Admins (who get unrestricted access). -->
    <record id="rule_classroom_teacher_own" model="ir.rule">
        <field name="name">Classroom: teacher sees own classrooms only</field>
        <field name="model_id" ref="model_edu_classroom"/>
        <field name="domain_force">[('teacher_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_classroom_teacher'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
