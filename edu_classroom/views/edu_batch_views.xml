<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         edu.batch form — inject Classrooms smart button
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_batch_form_classroom_inherit" model="ir.ui.view">
        <field name="name">edu.batch.form.classroom.inherit</field>
        <field name="model">edu.batch</field>
        <field name="inherit_id" ref="edu_academic_structure.view_edu_batch_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_classrooms"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-chalkboard-teacher"
                        invisible="classroom_count == 0">
                    <field name="classroom_count"
                           widget="statinfo"
                           string="Classrooms"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
