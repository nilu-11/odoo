<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Classroom — Kanban View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_classroom_kanban" model="ir.ui.view">
        <field name="name">edu.classroom.kanban</field>
        <field name="model">edu.classroom</field>
        <field name="arch" type="xml">
            <kanban default_group_by="batch_id" class="o_kanban_small_column">
                <field name="id"/>
                <field name="state"/>
                <field name="student_count"/>
                <templates>
                    <t t-name="card">
                        <field name="name" bold="True"/>
                        <field name="subject_id"/>
                        <div class="row g-0 mt-1">
                            <div class="col-6">
                                <span class="text-muted small">Section: </span>
                                <field name="section_id"/>
                            </div>
                            <div class="col-6">
                                <span class="text-muted small">Batch: </span>
                                <field name="batch_id"/>
                            </div>
                        </div>
                        <field name="program_term_id"/>
                        <div class="d-flex align-items-center mt-1">
                            <field name="teacher_id" widget="many2one_avatar_user"/>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="badge text-bg-secondary">
                                <t t-out="record.student_count.value"/> Students
                            </span>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-success="state == 'active'"
                                   decoration-muted="state == 'closed'"/>
                        </div>
                        <div name="kanban_buttons" class="mt-2"/>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
