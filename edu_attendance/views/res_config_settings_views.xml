<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_attendance" model="ir.ui.view">
        <field name="name">res.config.settings.form.attendance</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Attendance" string="Attendance" name="edu_attendance">
                    <block title="Attendance Thresholds">
                        <setting help="Minimum attendance percentage for the Defaulters report (default: 75%).">
                            <label for="attendance_threshold_percent"/>
                            <field name="attendance_threshold_percent"/>
                            <span class="o_form_label">%</span>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
