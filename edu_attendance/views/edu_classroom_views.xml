<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Classroom Form — Attendance Enhancements
         Add header buttons + smart buttons + register info.
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_classroom_form_attendance_inherit" model="ir.ui.view">
        <field name="name">edu.classroom.form.attendance.inherit</field>
        <field name="model">edu.classroom</field>
        <field name="inherit_id" ref="edu_classroom.view_edu_classroom_form"/>
        <field name="arch" type="xml">
            <!-- Header buttons — before the statusbar -->
            <xpath expr="//header/field[@name='state']" position="before">
                <field name="today_attendance_taken" invisible="1"/>
                <button name="action_take_attendance_today"
                        string="Take Attendance Today"
                        type="object"
                        class="btn-primary"
                        icon="fa-check-square-o"
                        invisible="state != 'active' or today_attendance_taken"
                        groups="edu_attendance.group_attendance_teacher,edu_attendance.group_attendance_admin,edu_academic_structure.group_education_admin"/>
                <button name="action_view_today_attendance"
                        string="View Today's Attendance"
                        type="object"
                        class="btn-secondary"
                        icon="fa-eye"
                        invisible="state != 'active' or not today_attendance_taken"
                        groups="edu_attendance.group_attendance_teacher,edu_attendance.group_attendance_admin,edu_academic_structure.group_education_admin"/>
                <button name="action_create_attendance_sheet"
                        string="Create Attendance Sheet"
                        type="object"
                        invisible="state != 'active'"
                        groups="edu_attendance.group_attendance_teacher,edu_attendance.group_attendance_admin,edu_academic_structure.group_education_admin"/>
            </xpath>

            <!-- Smart buttons — Sheets count + Matrix -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_attendance_sheets"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-list-alt"
                        groups="edu_attendance.group_attendance_viewer,edu_attendance.group_attendance_teacher,edu_attendance.group_attendance_admin,edu_academic_structure.group_education_admin">
                    <field name="attendance_sheet_count"
                           widget="statinfo"
                           string="Sheets"/>
                </button>
                <button name="action_open_attendance_matrix"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-th"
                        groups="edu_attendance.group_attendance_viewer,edu_attendance.group_attendance_teacher,edu_attendance.group_attendance_admin,edu_academic_structure.group_education_admin">
                    <span class="o_stat_text">Att. Matrix</span>
                </button>
            </xpath>

            <!-- Attendance info above notebook -->
            <xpath expr="//notebook" position="before">
                <group string="Attendance" invisible="not attendance_register_id">
                    <group>
                        <field name="attendance_register_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="latest_attendance_date" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Classroom Kanban — Attendance Buttons
         Extends the base kanban from edu_classroom to add
         Take Attendance and View Sheets quick actions.
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_classroom_kanban_attendance_inherit" model="ir.ui.view">
        <field name="name">edu.classroom.kanban.attendance.inherit</field>
        <field name="model">edu.classroom</field>
        <field name="inherit_id" ref="edu_classroom.view_edu_classroom_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='kanban_buttons']" position="inside">
                <field name="today_attendance_taken" invisible="1"/>
                <button name="action_take_attendance_today"
                        type="object"
                        class="btn btn-sm btn-primary me-1"
                        invisible="state != 'active' or today_attendance_taken"
                        title="Take Attendance Today">
                    <i class="fa fa-check-square-o"/> Attendance
                </button>
                <button name="action_view_today_attendance"
                        type="object"
                        class="btn btn-sm btn-success me-1"
                        invisible="state != 'active' or not today_attendance_taken"
                        title="View Today's Attendance">
                    <i class="fa fa-eye"/> Done
                </button>
                <button name="action_view_attendance_sheets"
                        type="object"
                        class="btn btn-sm btn-outline-secondary"
                        title="View Attendance Sheets">
                    <i class="fa fa-list-alt"/> Sheets
                </button>
            </xpath>
        </field>
    </record>
</odoo>
