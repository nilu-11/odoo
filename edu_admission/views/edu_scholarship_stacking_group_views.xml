<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Scholarship Stacking Group — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_scholarship_stacking_group_list" model="ir.ui.view">
        <field name="name">edu.scholarship.stacking.group.list</field>
        <field name="model">edu.scholarship.stacking.group</field>
        <field name="arch" type="xml">
            <list string="Stacking Groups" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description" optional="show"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Scholarship Stacking Group — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_scholarship_stacking_group_form" model="ir.ui.view">
        <field name="name">edu.scholarship.stacking.group.form</field>
        <field name="model">edu.scholarship.stacking.group</field>
        <field name="arch" type="xml">
            <form string="Stacking Group">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description of this stacking group..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Scholarship Stacking Group — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_scholarship_stacking_group" model="ir.actions.act_window">
        <field name="name">Stacking Groups</field>
        <field name="res_model">edu.scholarship.stacking.group</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Define Stacking Groups</p>
            <p>Stacking groups classify scholarship schemes for stacking rule enforcement (e.g. merit, financial_need, sibling, promotional).</p>
        </field>
    </record>
</odoo>
