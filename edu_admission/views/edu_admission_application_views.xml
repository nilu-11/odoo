<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Admission Application — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_admission_application_search" model="ir.ui.view">
        <field name="name">edu.admission.application.search</field>
        <field name="model">edu.admission.application</field>
        <field name="arch" type="xml">
            <search string="Admission Applications">
                <field name="application_no"/>
                <field name="applicant_profile_id"/>
                <field name="program_id"/>
                <field name="admission_register_id"/>
                <field name="assigned_user_id"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Under Review" name="under_review"
                        domain="[('state', '=', 'under_review')]"/>
                <filter string="Approved" name="approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Enrolled" name="enrolled"
                        domain="[('state', '=', 'enrolled')]"/>
                <filter string="Rejected" name="rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Scholarship Pending" name="scholarship_pending"
                        domain="[('scholarship_status', '=', 'pending')]"/>
                <filter string="Has Scholarship" name="has_scholarship"
                        domain="[('total_scholarship_discount_amount', '>', 0)]"/>
                <filter string="Fee Confirmed" name="fee_confirmed"
                        domain="[('fee_confirmed', '=', True)]"/>
                <separator/>
                <filter string="My Applications" name="my_apps"
                        domain="[('assigned_user_id', '=', uid)]"/>
                <filter string="Archived" name="archived"
                        domain="[('active', '=', False)]"/>
                <group name="group_by">
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Program" name="group_program"
                            context="{'group_by': 'program_id'}"/>
                    <filter string="Register" name="group_register"
                            context="{'group_by': 'admission_register_id'}"/>
                    <filter string="Academic Year" name="group_year"
                            context="{'group_by': 'academic_year_id'}"/>
                    <filter string="Scholarship Status" name="group_scholarship"
                            context="{'group_by': 'scholarship_status'}"/>
                    <filter string="Assigned To" name="group_assigned"
                            context="{'group_by': 'assigned_user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Admission Application — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_admission_application_list" model="ir.ui.view">
        <field name="name">edu.admission.application.list</field>
        <field name="model">edu.admission.application</field>
        <field name="arch" type="xml">
            <list string="Admission Applications"
                  decoration-success="state == 'enrolled'"
                  decoration-danger="state == 'rejected'"
                  decoration-warning="state == 'under_review'"
                  decoration-info="state == 'approved'">
                <field name="application_no"/>
                <field name="applicant_profile_id"/>
                <field name="program_id"/>
                <field name="academic_year_id" optional="show"/>
                <field name="batch_id" optional="show"/>
                <field name="admission_register_id" optional="show"/>
                <field name="scholarship_status" optional="show"
                       widget="badge"/>
                <field name="net_fee_after_scholarship" optional="show"
                       string="Net Fee"/>
                <field name="offer_status" optional="show" widget="badge"/>
                <field name="assigned_user_id" optional="show"
                       widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'enrolled'"
                       decoration-danger="state == 'rejected'"
                       decoration-warning="state == 'under_review'"
                       decoration-info="state == 'approved'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Admission Application — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_admission_application_form" model="ir.ui.view">
        <field name="name">edu.admission.application.form</field>
        <field name="model">edu.admission.application</field>
        <field name="arch" type="xml">
            <form string="Admission Application">
                <header>
                    <button name="action_submit" string="Submit"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'under_review'"/>
                    <button name="action_generate_offer" string="Generate Offer"
                            type="object" class="btn-secondary"
                            invisible="not show_offer_button"/>
                    <button name="action_enroll" string="Enroll"
                            type="object" class="btn-primary"
                            invisible="state != 'approved'"
                            confirm="Enroll this applicant? This will create an enrollment record."/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state in ('enrolled', 'rejected', 'draft')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state != 'rejected'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,under_review,approved,enrolled"/>
                </header>

                <sheet>
                    <!-- Ribbon badges -->
                    <widget name="web_ribbon" title="Enrolled" bg_color="text-bg-success"
                            invisible="state != 'enrolled'"/>
                    <widget name="web_ribbon" title="Rejected" bg_color="text-bg-danger"
                            invisible="state != 'rejected'"/>

                    <!-- Smart buttons -->
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_scholarship_reviews"
                                type="object" class="oe_stat_button"
                                icon="fa-gift"
                                invisible="not show_scholarship_button">
                            <field name="scholarship_review_count" widget="statinfo"
                                   string="Scholarships"/>
                        </button>
                        <button name="action_print_offer_letter"
                                type="object" class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="not offer_letter_generated">
                            <span>Offer Letter</span>
                        </button>
                        <!-- Enrollment and Student smart buttons are added by
                             edu_enrollment and edu_student via view inheritance. -->
                    </div>

                    <!-- Title -->
                    <div class="oe_title">
                        <h1><field name="application_no" readonly="1"/></h1>
                    </div>

                    <!-- Scholarship frozen indicator -->
                    <div class="alert alert-warning mb-3"
                         invisible="not scholarship_frozen">
                        <i class="fa fa-lock me-2"/>
                        <strong>Scholarship outcome frozen</strong> on
                        <field name="scholarship_freeze_date" readonly="1"
                               class="d-inline" nolabel="1"/>.
                        Approved scholarship lines cannot be edited.
                    </div>

                    <!-- ── Applicant &amp; Admission Context ── -->
                    <group>
                        <group string="Applicant">
                            <field name="applicant_profile_id"
                                   readonly="state != 'draft'"/>
                            <field name="partner_id" invisible="1"/>
                            <field name="crm_lead_id" readonly="1"
                                   invisible="not crm_lead_id"/>
                            <field name="assigned_user_id"/>
                        </group>
                        <group string="Admission">
                            <field name="admission_register_id"
                                   readonly="state != 'draft'"/>
                            <field name="program_id"
                                   readonly="state != 'draft'"/>
                            <field name="academic_year_id"
                                   readonly="state != 'draft'"/>
                            <field name="batch_id"
                                   readonly="state != 'draft'"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ── Financial Tab ── -->
                        <page string="Financial" name="financial">
                            <group>
                                <group string="Fee Structure">
                                    <field name="fee_structure_id"
                                           readonly="state == 'enrolled'"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="base_total_fee" readonly="1"/>
                                    <field name="scholarship_eligible_total" readonly="1"/>
                                </group>
                                <group string="Payment Plan">
                                    <field name="available_payment_plan_ids"
                                           widget="many2many_tags" readonly="1"
                                           force_save="1"/>
                                    <field name="selected_payment_plan_id"
                                           domain="[('id', 'in', available_payment_plan_ids)]"
                                           readonly="state == 'enrolled'"/>
                                </group>
                            </group>

                            <group>
                                <group string="Scholarship Summary">
                                    <field name="total_scholarship_discount_amount" readonly="1"/>
                                    <field name="net_fee_after_scholarship" readonly="1"/>
                                    <field name="scholarship_cap_applied" readonly="1"/>
                                </group>
                                <group string="Payment Confirmation">
                                    <field name="payment_received"/>
                                    <field name="fee_confirmed" readonly="1"/>
                                    <field name="fee_confirmation_date" readonly="1"/>
                                </group>
                            </group>

                            <div class="o_horizontal_separator mt-4 mb-3">Fee Breakdown</div>
                            <field name="fee_summary_display" readonly="1"
                                   widget="html" nolabel="1" sanitize="0"/>
                        </page>

                        <!-- ── Scholarship Tab ── -->
                        <page string="Scholarship" name="scholarship"
                              invisible="not show_scholarship_button">
                            <div class="o_row mb-3">
                                <button name="action_suggest_scholarships"
                                        type="object"
                                        string="Suggest Scholarships"
                                        class="btn-primary btn-sm"
                                        icon="fa-magic"
                                        invisible="scholarship_frozen"
                                        title="Auto-detect eligible scholarship schemes based on applicant profile, program, and demographics."/>
                                <button name="action_recompute_scholarship"
                                        type="object"
                                        string="Recalculate"
                                        class="btn-secondary btn-sm"
                                        invisible="scholarship_frozen"/>
                                <button name="action_freeze_scholarship_outcome"
                                        type="object"
                                        string="Freeze Outcome"
                                        class="btn-secondary btn-sm"
                                        invisible="scholarship_frozen"
                                        groups="edu_admission.group_scholarship_approver"
                                        confirm="Freeze the scholarship outcome? Approved lines will be locked and cannot be modified."/>
                            </div>

                            <group>
                                <group string="Scholarship Summary">
                                    <field name="scholarship_status" readonly="1"
                                           widget="badge"/>
                                    <field name="scholarship_review_count" readonly="1"
                                           string="Review Lines"/>
                                    <field name="approved_scholarship_count" readonly="1"
                                           string="Approved"/>
                                    <field name="scholarship_scheme_count" readonly="1"
                                           string="Distinct Schemes"/>
                                </group>
                                <group string="Financial Impact">
                                    <field name="scholarship_eligible_total" readonly="1"/>
                                    <field name="total_scholarship_discount_amount" readonly="1"/>
                                    <field name="net_fee_after_scholarship" readonly="1"/>
                                    <field name="scholarship_cap_applied" readonly="1"/>
                                </group>
                            </group>

                            <group string="Cap Details"
                                   invisible="not scholarship_cap_reason_summary">
                                <field name="scholarship_cap_reason_summary" readonly="1"
                                       nolabel="1"/>
                            </group>
                            <group string="Scholarship Notes"
                                   invisible="not scholarship_note_summary">
                                <field name="scholarship_note_summary" readonly="1"
                                       nolabel="1"/>
                            </group>

                            <div class="o_horizontal_separator mt-4 mb-3">Scholarship Reviews</div>
                            <field name="scholarship_review_ids"
                                   readonly="scholarship_frozen">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="scholarship_scheme_id"/>
                                    <field name="eligibility_result" optional="show"
                                           widget="badge"/>
                                    <field name="approved_type"/>
                                    <field name="approved_percent" optional="show"/>
                                    <field name="approved_amount" optional="show"/>
                                    <field name="calculated_discount_amount"
                                           string="Discount" readonly="1"/>
                                    <field name="cap_applied" readonly="1"/>
                                    <field name="cap_reason" optional="hide" readonly="1"/>
                                    <field name="approved_by" optional="show"
                                           widget="many2one_avatar_user" readonly="1"/>
                                    <field name="state" widget="badge"/>
                                    <button name="action_approve" type="object"
                                            string="Approve" icon="fa-check"
                                            class="btn-link text-success"
                                            invisible="state not in ('draft', 'under_review', 'recommended')"
                                            groups="edu_admission.group_scholarship_approver"/>
                                    <button name="action_reject" type="object"
                                            string="Reject" icon="fa-times"
                                            class="btn-link text-danger"
                                            invisible="state not in ('draft', 'under_review', 'recommended')"
                                            groups="edu_admission.group_scholarship_approver"/>
                                </list>
                            </field>
                        </page>

                        <!-- ── Offer Tab ── -->
                        <page string="Offer" name="offer"
                              invisible="not offer_letter_generated and state not in ('approved', 'enrolled')">
                            <group>
                                <group string="Offer Details">
                                    <field name="offer_status" readonly="1" widget="badge"/>
                                    <field name="offer_letter_generated" readonly="1"/>
                                    <field name="offer_letter_date" readonly="1"/>
                                    <field name="offer_letter_ref"/>
                                    <field name="offer_expiry_date"/>
                                </group>
                                <group string="Digital Signature">
                                    <field name="sign_request_id" readonly="1"
                                           invisible="not sign_request_id"/>
                                </group>
                            </group>

                            <group string="Outcome"
                                   invisible="offer_status == 'not_generated'">
                                <field name="offer_acceptance_date" readonly="1"/>
                                <field name="offer_rejection_reason"
                                       invisible="offer_status != 'rejected'"/>
                            </group>
                        </page>

                        <!-- ── Notes Tab ── -->
                        <page string="Notes" name="notes">
                            <group string="Internal Notes">
                                <field name="internal_note" nolabel="1"/>
                            </group>
                            <group string="General Notes">
                                <field name="note" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>

                    <field name="active" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="show_offer_button" invisible="1"/>
                    <field name="show_sign_button" invisible="1"/>
                    <field name="show_scholarship_button" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Admission Application — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_admission_application" model="ir.actions.act_window">
        <field name="name">Admission Applications</field>
        <field name="res_model">edu.admission.application</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_admission_application_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create an Admission Application</p>
            <p>Applications are typically created through CRM lead conversion or manual entry. Each application tracks an applicant through the admission lifecycle from submission to enrollment.</p>
        </field>
    </record>
</odoo>
