<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Scholarship Review — Search
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_admission_scholarship_review_search" model="ir.ui.view">
        <field name="name">edu.admission.scholarship.review.search</field>
        <field name="model">edu.admission.scholarship.review</field>
        <field name="arch" type="xml">
            <search string="Scholarship Reviews">
                <field name="application_id"/>
                <field name="scholarship_scheme_id"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Under Review" name="under_review"
                        domain="[('state', '=', 'under_review')]"/>
                <filter string="Recommended" name="recommended"
                        domain="[('state', '=', 'recommended')]"/>
                <filter string="Approved" name="approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Cap Applied" name="capped"
                        domain="[('cap_applied', '=', True)]"/>
                <filter string="Eligibility Checked" name="elig_checked"
                        domain="[('eligibility_checked', '=', True)]"/>
                <group name="group_by">
                    <filter string="Application" name="group_app"
                            context="{'group_by': 'application_id'}"/>
                    <filter string="Scheme" name="group_scheme"
                            context="{'group_by': 'scholarship_scheme_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Eligibility Result" name="group_eligibility"
                            context="{'group_by': 'eligibility_result'}"/>
                    <filter string="Approved By" name="group_approver"
                            context="{'group_by': 'approved_by'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Scholarship Review — List
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_admission_scholarship_review_list" model="ir.ui.view">
        <field name="name">edu.admission.scholarship.review.list</field>
        <field name="model">edu.admission.scholarship.review</field>
        <field name="arch" type="xml">
            <list string="Scholarship Reviews">
                <field name="sequence" widget="handle"/>
                <field name="application_id"/>
                <field name="scholarship_scheme_id"/>
                <field name="eligibility_result" optional="show" widget="badge"/>
                <field name="recommendation_type" optional="show"/>
                <field name="recommended_percent" optional="show"/>
                <field name="recommended_amount" optional="show"/>
                <field name="approved_type"/>
                <field name="approved_percent"/>
                <field name="approved_amount"/>
                <field name="calculated_discount_amount" string="Discount"/>
                <field name="cap_applied"/>
                <field name="approved_by" optional="show"
                       widget="many2one_avatar_user"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Scholarship Review — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_admission_scholarship_review_form" model="ir.ui.view">
        <field name="name">edu.admission.scholarship.review.form</field>
        <field name="model">edu.admission.scholarship.review</field>
        <field name="arch" type="xml">
            <form string="Scholarship Review">
                <header>
                    <button name="action_start_review" type="object"
                            string="Start Review" class="btn-secondary"
                            invisible="state != 'draft'"/>
                    <button name="action_recommend" type="object"
                            string="Recommend" class="btn-secondary"
                            invisible="state not in ['draft', 'under_review']"
                            confirm="Mark this scholarship as Recommended? The approver will review and approve or reject."/>
                    <button name="action_approve" type="object"
                            string="Approve" class="btn-primary"
                            invisible="state not in ['draft', 'under_review', 'recommended']"
                            groups="edu_admission.group_scholarship_approver"
                            confirm="Approve this scholarship? Scheme rules will be frozen as a snapshot."/>
                    <button name="action_reject" type="object"
                            string="Reject" class="btn-secondary"
                            invisible="state not in ['draft', 'under_review', 'recommended']"
                            groups="edu_admission.group_scholarship_approver"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ['cancelled', 'approved']"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state not in ['rejected', 'cancelled']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,recommended,approved"/>
                </header>

                <sheet>
                    <!-- Frozen indicator -->
                    <div class="alert alert-warning mb-3"
                         invisible="not application_id or not application_id.scholarship_frozen">
                        <i class="fa fa-lock me-2"/>
                        The scholarship outcome for this application is frozen.
                        Approved values cannot be edited.
                    </div>

                    <!-- ── Identification ── -->
                    <group>
                        <group string="Scholarship">
                            <field name="application_id"
                                   readonly="state != 'draft'"/>
                            <field name="scholarship_scheme_id"
                                   readonly="state in ['approved', 'rejected']"/>
                            <field name="sequence"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Approved Values">
                            <field name="approved_type"
                                   readonly="state == 'approved'"/>
                            <field name="approved_percent"
                                   invisible="approved_type not in ['percentage', 'full']"
                                   readonly="state == 'approved'"/>
                            <field name="approved_amount"
                                   invisible="approved_type not in ['fixed', 'custom']"
                                   readonly="state == 'approved'"/>
                        </group>
                    </group>

                    <!-- ── Outcome ── -->
                    <group>
                        <group string="Outcome">
                            <field name="calculated_discount_amount" readonly="1"/>
                            <field name="eligible_base_amount_snapshot" readonly="1"
                                   invisible="state != 'approved'"/>
                            <field name="cap_applied" readonly="1"/>
                            <field name="cap_reason" readonly="1"
                                   invisible="not cap_reason"/>
                        </group>
                    </group>

                    <!-- ── Rejection Reason ── -->
                    <group string="Rejection" invisible="state != 'rejected'">
                        <field name="rejection_reason" nolabel="1"
                               placeholder="State the reason for rejection..."/>
                    </group>

                    <!-- ── Audit Trail ── -->
                    <group string="Audit" invisible="state not in ['recommended', 'approved']">
                        <group>
                            <field name="reviewed_by" readonly="1"/>
                            <field name="reviewed_on" readonly="1"/>
                        </group>
                        <group>
                            <field name="approved_by" readonly="1"
                                   invisible="state != 'approved'"/>
                            <field name="approval_date" readonly="1"
                                   invisible="state != 'approved'"/>
                        </group>
                    </group>

                    <field name="eligibility_basis" invisible="1"/>
                    <notebook>
                        <!-- ── Eligibility Tab ── -->
                        <page string="Eligibility Assessment" name="eligibility">
                            <group>
                                <group string="Eligibility Check">
                                    <field name="eligibility_checked"/>
                                    <field name="eligibility_result"
                                           invisible="not eligibility_checked"/>
                                </group>
                            </group>
                            <group string="Eligibility Notes">
                                <field name="eligibility_note" nolabel="1"
                                       placeholder="Notes on eligibility assessment against scheme criteria..."/>
                            </group>
                            <group string="Supporting Documents">
                                <field name="supporting_document_note" nolabel="1"
                                       placeholder="List and describe documents verified (income certificate, sports certificate, employment proof, etc.)..."/>
                            </group>
                        </page>

                        <!-- ── Evidence Tab ── -->
                        <page string="Evidence" name="evidence"
                              invisible="eligibility_basis not in ['merit','financial_aid','sibling','sports','staff_child','quota']">

                            <!-- Merit -->
                            <group string="Merit Criteria"
                                   invisible="eligibility_basis != 'merit'">
                                <group>
                                    <field name="merit_score_type"/>
                                    <field name="merit_min_score"
                                           string="Minimum Score Required"/>
                                    <field name="merit_actual_score"
                                           string="Actual Score Achieved"/>
                                </group>
                                <group>
                                    <field name="merit_certificate_ref"/>
                                    <field name="merit_score_verified"/>
                                </group>
                            </group>

                            <!-- Financial Aid -->
                            <group string="Income Assessment"
                                   invisible="eligibility_basis != 'financial_aid'">
                                <group>
                                    <field name="financial_max_income"
                                           string="Income Limit (Annual)"/>
                                    <field name="financial_actual_income"
                                           string="Verified Annual Income"/>
                                </group>
                                <group>
                                    <field name="financial_certificate_ref"
                                           string="Income Certificate Ref"/>
                                    <field name="financial_income_verified"/>
                                </group>
                            </group>

                            <!-- Sibling -->
                            <group string="Sibling Verification"
                                   invisible="eligibility_basis != 'sibling'">
                                <group>
                                    <field name="sibling_min_count"/>
                                </group>
                                <group>
                                    <field name="sibling_verified"/>
                                </group>
                                <field name="sibling_details" nolabel="1" colspan="2"
                                       placeholder="Names and enrollment / roll numbers of currently enrolled siblings..."/>
                            </group>

                            <!-- Sports -->
                            <group string="Sports Achievement"
                                   invisible="eligibility_basis != 'sports'">
                                <group>
                                    <field name="sports_sport_name"/>
                                    <field name="sports_required_level"/>
                                    <field name="sports_actual_level"/>
                                </group>
                                <group>
                                    <field name="sports_certificate_ref"/>
                                    <field name="sports_verified"/>
                                </group>
                            </group>

                            <!-- Staff Child -->
                            <group string="Staff Relationship"
                                   invisible="eligibility_basis != 'staff_child'">
                                <group>
                                    <field name="staff_member_name"/>
                                    <field name="staff_employee_id"/>
                                    <field name="staff_relation"/>
                                </group>
                                <group>
                                    <field name="staff_employment_verified"/>
                                </group>
                            </group>

                            <!-- Quota / Reservation -->
                            <group string="Reservation Certificate"
                                   invisible="eligibility_basis != 'quota'">
                                <group>
                                    <field name="quota_category"/>
                                    <field name="quota_certificate_number"/>
                                    <field name="quota_issuing_authority"/>
                                </group>
                                <group>
                                    <field name="quota_certificate_verified"/>
                                </group>
                            </group>

                        </page>

                        <!-- ── Review Notes Tab ── -->
                        <page string="Review Notes" name="review_notes">
                            <group string="Recommendation (Reviewer Proposal)">
                                <field name="recommendation_type"
                                       readonly="state in ['approved', 'rejected']"/>
                                <field name="recommended_percent"
                                       invisible="recommendation_type != 'percentage'"
                                       readonly="state in ['approved', 'rejected']"/>
                                <field name="recommended_amount"
                                       invisible="recommendation_type not in ['fixed', 'custom']"
                                       readonly="state in ['approved', 'rejected']"/>
                            </group>
                            <group string="Financial Review Notes"
                                   invisible="eligibility_basis != 'financial_aid'">
                                <field name="financial_review_note" nolabel="1"
                                       placeholder="Income assessment, hardship details, family background notes..."/>
                            </group>
                            <group string="Committee / Senior Approver Notes">
                                <field name="committee_note" nolabel="1"
                                       placeholder="Notes from the scholarship committee or senior approver..."/>
                            </group>
                            <group string="General Remarks">
                                <field name="remarks" nolabel="1"
                                       placeholder="Justification, observations, or any other notes..."/>
                            </group>
                        </page>

                        <!-- ── Scheme Snapshots Tab ── -->
                        <page string="Scheme Snapshot" name="snapshots"
                              invisible="state != 'approved'">
                            <div class="alert alert-info mb-3">
                                These values were recorded at the time of approval.
                                They are frozen and will not change if the scheme
                                master data is updated later.
                            </div>
                            <group>
                                <group>
                                    <field name="scheme_name_snapshot" readonly="1"/>
                                    <field name="scheme_category_snapshot" readonly="1"/>
                                    <field name="award_type_snapshot" readonly="1"/>
                                    <field name="priority_snapshot" readonly="1"/>
                                </group>
                                <group>
                                    <field name="exclusive_snapshot" readonly="1"/>
                                    <field name="stacking_allowed_snapshot" readonly="1"/>
                                    <field name="stacking_group_snapshot" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="eligibility_basis_snapshot" readonly="1"/>
                                    <field name="applies_on_snapshot" readonly="1"/>
                                </group>
                                <group>
                                    <field name="max_discount_percent_snapshot" readonly="1"/>
                                    <field name="max_discount_amount_snapshot" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Scholarship Review — Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_admission_scholarship_review" model="ir.actions.act_window">
        <field name="name">Scholarship Reviews</field>
        <field name="res_model">edu.admission.scholarship.review</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_admission_scholarship_review_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add a Scholarship Review</p>
            <p>
                Scholarship reviews evaluate and approve scholarship awards per
                application. Each line references a scheme, captures eligibility
                assessment, recommended vs. approved values, and freezes scheme
                rules as a snapshot for audit stability.
            </p>
        </field>
    </record>
</odoo>
