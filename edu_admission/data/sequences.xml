<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_edu_admission_register" model="ir.sequence">
        <field name="name">Admission Register</field>
        <field name="code">edu.admission.register</field>
        <field name="prefix">REG/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next_actual">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_edu_admission_application" model="ir.sequence">
        <field name="name">Admission Application</field>
        <field name="code">edu.admission.application</field>
        <field name="prefix">APP/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="number_next_actual">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
