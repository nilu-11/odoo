<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_edu_room_list" model="ir.ui.view">
        <field name="name">edu.room.list</field>
        <field name="model">edu.room</field>
        <field name="arch" type="xml">
            <list string="Rooms">
                <field name="code"/>
                <field name="name"/>
                <field name="building"/>
                <field name="floor"/>
                <field name="room_type"/>
                <field name="capacity"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_edu_room_form" model="ir.ui.view">
        <field name="name">edu.room.form</field>
        <field name="model">edu.room</field>
        <field name="arch" type="xml">
            <form string="Room">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Room 101"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="room_type"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="building"/>
                            <field name="floor"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_edu_room_search" model="ir.ui.view">
        <field name="name">edu.room.search</field>
        <field name="model">edu.room</field>
        <field name="arch" type="xml">
            <search string="Rooms">
                <field name="name"/>
                <field name="code"/>
                <field name="building"/>
                <filter string="Classrooms" name="filter_classroom" domain="[('room_type','=','classroom')]"/>
                <filter string="Labs" name="filter_lab" domain="[('room_type','=','lab')]"/>
                <filter string="Archived" name="filter_inactive" domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by':'room_type'}"/>
                    <filter string="Building" name="group_building" context="{'group_by':'building'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_edu_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">edu.room</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_edu_room_search"/>
    </record>
</odoo>
