<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_schedule_page" name="Portal — My Schedule">
        <t t-call="edu_portal.portal_layout">
            <h2 class="page-title">My Schedule</h2>
            <t t-if="slots">
                <table class="data-table schedule-table">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>Period</th>
                            <th>Time</th>
                            <th>Subject</th>
                            <th t-if="role == 'teacher'">Section</th>
                            <th t-if="role == 'student'">Teacher</th>
                            <th>Room</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="day_labels" t-value="{'0':'Mon','1':'Tue','2':'Wed','3':'Thu','4':'Fri','5':'Sat','6':'Sun'}"/>
                        <t t-foreach="slots" t-as="s">
                            <tr>
                                <td><t t-esc="day_labels.get(s.day_of_week, '')"/></td>
                                <td><t t-esc="s.period_id.name"/></td>
                                <td>
                                    <t t-esc="'%02d:%02d' % (int(s.period_id.start_time), int(round((s.period_id.start_time % 1) * 60)))"/>
                                    –
                                    <t t-esc="'%02d:%02d' % (int(s.period_id.end_time), int(round((s.period_id.end_time % 1) * 60)))"/>
                                </td>
                                <td><t t-esc="s.subject_id.display_name"/></td>
                                <td t-if="role == 'teacher'"><t t-esc="s.section_id.display_name"/></td>
                                <td t-if="role == 'student'"><t t-esc="s.teacher_id.display_name"/></td>
                                <td><t t-esc="s.room_id.display_name"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>
            <t t-else="">
                <t t-call="edu_portal.empty_state_component">
                    <t t-set="icon" t-value="'&#x1F4C5;'"/>
                    <t t-set="title" t-value="'No schedule yet'"/>
                    <t t-set="message" t-value="'Your weekly timetable will appear here once it has been published.'"/>
                </t>
            </t>
        </t>
    </template>
</odoo>
