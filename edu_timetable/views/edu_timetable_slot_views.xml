<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_edu_timetable_slot_list" model="ir.ui.view">
        <field name="name">edu.timetable.slot.list</field>
        <field name="model">edu.timetable.slot</field>
        <field name="arch" type="xml">
            <list string="Slots">
                <field name="template_id"/>
                <field name="day_of_week"/>
                <field name="period_id"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="room_id"/>
                <field name="section_id"/>
                <field name="slot_type"/>
            </list>
        </field>
    </record>

    <record id="view_edu_timetable_slot_form" model="ir.ui.view">
        <field name="name">edu.timetable.slot.form</field>
        <field name="model">edu.timetable.slot</field>
        <field name="arch" type="xml">
            <form string="Slot">
                <sheet>
                    <group>
                        <group>
                            <field name="template_id"/>
                            <field name="day_of_week"/>
                            <field name="period_id" domain="[('template_id','=',template_id)]"/>
                            <field name="slot_type"/>
                        </group>
                        <group>
                            <field name="subject_id"/>
                            <field name="teacher_id"/>
                            <field name="room_id"/>
                            <field name="classroom_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="start_datetime" readonly="1"/>
                        <field name="end_datetime" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_edu_timetable_slot_search" model="ir.ui.view">
        <field name="name">edu.timetable.slot.search</field>
        <field name="model">edu.timetable.slot</field>
        <field name="arch" type="xml">
            <search string="Slots">
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="room_id"/>
                <field name="section_id"/>
                <filter string="Regular" name="f_regular" domain="[('slot_type','=','regular')]"/>
                <filter string="Exam" name="f_exam" domain="[('slot_type','=','exam')]"/>
                <filter string="Cancelled" name="f_cancelled" domain="[('slot_type','=','cancelled')]"/>
                <group expand="0" string="Group By">
                    <filter string="Teacher" name="g_teacher" context="{'group_by':'teacher_id'}"/>
                    <filter string="Room" name="g_room" context="{'group_by':'room_id'}"/>
                    <filter string="Section" name="g_section" context="{'group_by':'section_id'}"/>
                    <filter string="Day" name="g_day" context="{'group_by':'day_of_week'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_edu_timetable_slot_gantt" model="ir.ui.view">
        <field name="name">edu.timetable.slot.gantt</field>
        <field name="model">edu.timetable.slot</field>
        <field name="arch" type="xml">
            <gantt date_start="start_datetime"
                   date_stop="end_datetime"
                   default_group_by="teacher_id"
                   default_scale="week"
                   color="subject_id"
                   string="Timetable Gantt">
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="room_id"/>
                <field name="section_id"/>
                <field name="slot_type"/>
                <templates>
                    <div t-name="gantt-popover">
                        <strong><t t-esc="subject_id.display_name"/></strong><br/>
                        <t t-esc="teacher_id.display_name"/><br/>
                        <t t-esc="room_id.display_name"/><br/>
                        <t t-esc="section_id.display_name"/>
                    </div>
                </templates>
            </gantt>
        </field>
    </record>

    <record id="view_edu_timetable_slot_calendar" model="ir.ui.view">
        <field name="name">edu.timetable.slot.calendar</field>
        <field name="model">edu.timetable.slot</field>
        <field name="arch" type="xml">
            <calendar date_start="start_datetime"
                      date_stop="end_datetime"
                      string="Weekly Timetable"
                      color="subject_id"
                      mode="week"
                      quick_create="0">
                <field name="subject_id" filters="1" invisible="1"/>
                <field name="teacher_id" filters="1" avatar_field="image_128"/>
                <field name="section_id" filters="1"/>
                <field name="room_id"/>
            </calendar>
        </field>
    </record>

    <record id="action_edu_timetable_slot" model="ir.actions.act_window">
        <field name="name">Timetable Slots</field>
        <field name="res_model">edu.timetable.slot</field>
        <field name="view_mode">gantt,calendar,list,form</field>
        <field name="search_view_id" ref="view_edu_timetable_slot_search"/>
    </record>
</odoo>
