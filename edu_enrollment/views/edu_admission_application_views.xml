<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Admission Application — Enrollment Integration
         Adds enrollment smart button and header action buttons
         extending the base edu_admission form view.
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_admission_application_form_enrollment"
            model="ir.ui.view">
        <field name="name">edu.admission.application.form.enrollment</field>
        <field name="model">edu.admission.application</field>
        <field name="inherit_id"
               ref="edu_admission.view_edu_admission_application_form"/>
        <field name="arch" type="xml">

            <!-- Smart button: Enrollment (shown when enrollment exists) -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_enrollment"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-id-card"
                        invisible="enrollment_count == 0">
                    <field name="enrollment_count"
                           string="Enrollment" widget="statinfo"/>
                </button>
            </xpath>

            <!-- Header: Change "Create Enrollment" button visibility to
                 also hide when an enrollment already exists, and add
                 "View Enrollment" button for the enrolled state. -->
            <xpath expr="//button[@name='action_enroll']" position="attributes">
                <!-- Restrict: show only when ready AND no enrollment yet -->
                <attribute name="invisible">state != 'ready_for_enrollment' or enrollment_count > 0</attribute>
                <attribute name="confirm">Create an enrollment record? This advances the application to Enrolled state and cannot be undone.</attribute>
            </xpath>

            <!-- View Enrollment: visible when enrollment exists -->
            <xpath expr="//button[@name='action_enroll']" position="after">
                <button name="action_view_enrollment" type="object"
                        string="View Enrollment" class="btn-secondary"
                        invisible="enrollment_count == 0"/>
            </xpath>

        </field>
    </record>
</odoo>
