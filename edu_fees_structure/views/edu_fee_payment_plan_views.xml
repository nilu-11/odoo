<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Fee Payment Plan — Form (standalone / from smart button)
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_fee_payment_plan_form" model="ir.ui.view">
        <field name="name">edu.fee.payment.plan.form</field>
        <field name="model">edu.fee.payment.plan</field>
        <field name="arch" type="xml">
            <form string="Payment Plan">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>

                    <group>
                        <group string="Plan Details">
                            <field name="fee_structure_id" readonly="1"/>
                            <field name="plan_type"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Monthly Settings"
                               invisible="plan_type != 'monthly'">
                            <field name="months_count"/>
                            <field name="excluded_fee_head_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <!-- Installment Lines — shown only for installment plans -->
                    <notebook invisible="plan_type != 'installment'">
                        <page string="Installment Slots" name="installment_slots">
                            <!--
                                Each row = one installment slot.
                                Sequence controls the order (Installment 1, 2, 3...).
                                Fee Heads column: which fee heads are due at this slot.
                            -->
                            <field name="installment_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="label"/>
                                    <field name="fee_head_ids"
                                           widget="many2many_tags"
                                           options="{'no_create': True}"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <group string="Note">
                        <field name="note" nolabel="1" placeholder="Optional notes about this payment plan..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Fee Payment Plan — List (standalone / from smart button)
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_fee_payment_plan_list" model="ir.ui.view">
        <field name="name">edu.fee.payment.plan.list</field>
        <field name="model">edu.fee.payment.plan</field>
        <field name="arch" type="xml">
            <list string="Payment Plans">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="plan_type"/>
                <field name="months_count"
                       string="Months"
                       optional="show"/>
                <field name="excluded_fee_head_ids"
                       widget="many2many_tags"
                       string="Excluded Heads"
                       optional="show"/>
                <field name="fee_structure_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Fee Payment Plan — Action (from smart button)
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_fee_payment_plan" model="ir.actions.act_window">
        <field name="name">Payment Plans</field>
        <field name="res_model">edu.fee.payment.plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add a payment plan</p>
            <p>Payment plans define how fees are collected — installment slots or monthly billing.</p>
        </field>
    </record>
</odoo>
