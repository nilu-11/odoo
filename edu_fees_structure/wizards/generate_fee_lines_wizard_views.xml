<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_generate_fee_lines_wizard_form" model="ir.ui.view">
        <field name="name">edu.fee.structure.generate.wizard.form</field>
        <field name="model">edu.fee.structure.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Fee Lines">
                <group>
                    <field name="fee_structure_id" invisible="1"/>
                    <field name="program_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="fee_head_ids"
                           widget="many2many_tags"
                           options="{'no_create': True, 'color_field': 'fee_type'}"/>
                </group>
                <div class="alert alert-info" role="alert">
                    <strong>Note:</strong>
                    Admission and one-time fee heads will only be added to the first
                    progression stage. All other selected heads will be added to every
                    progression stage. Amounts default to zero — edit them after generation.
                </div>
                <footer>
                    <button name="action_generate"
                            string="Generate"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
