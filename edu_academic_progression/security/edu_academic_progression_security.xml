<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Privilege (res.groups.privilege)
         Follows the same pattern as edu_student.privilege_student_access.
    ══════════════════════════════════════════════════════ -->
    <record id="privilege_progression_access" model="res.groups.privilege">
        <field name="name">Academic Progression</field>
        <field name="description">
            Controls access to student academic progression history records
            and the batch promotion workflow.
        </field>
        <field name="placeholder">No progression access</field>
        <field name="sequence">60</field>
        <field name="category_id" ref="edu_academic_structure.module_category_education"/>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Security Groups — Viewer → Officer → Admin
    ══════════════════════════════════════════════════════ -->

    <record id="group_progression_viewer" model="res.groups">
        <field name="name">Progression Viewer</field>
        <field name="privilege_id" ref="privilege_progression_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Read-only access to progression history records.</field>
    </record>

    <record id="group_progression_officer" model="res.groups">
        <field name="name">Progression Officer</field>
        <field name="privilege_id" ref="privilege_progression_access"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('group_progression_viewer'))
        ]"/>
        <field name="comment">
            Can create and update progression history records.
            Cannot delete closed records or run batch promotions.
        </field>
    </record>

    <record id="group_progression_admin" model="res.groups">
        <field name="name">Progression Administrator</field>
        <field name="privilege_id" ref="privilege_progression_access"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('group_progression_officer'))
        ]"/>
        <field name="comment">
            Full access including deletion of open records, running promotions,
            and cancelling active progression histories.
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Batch Promotion Manager
         Cross-cutting group: grants promotion wizard access to users
         who may not be full Progression Administrators.
         Implies officer so they can read/create progression records.
    ══════════════════════════════════════════════════════ -->
    <record id="group_progression_promotion_manager" model="res.groups">
        <field name="name">Batch Promotion Manager</field>
        <field name="privilege_id" ref="privilege_progression_access"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('group_progression_officer'))
        ]"/>
        <field name="comment">
            Authorised to run batch promotion operations via the wizard.
            Implies Progression Officer access.
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Section Assignment Groups
         Officer  — can run section assignments for unassigned students.
         Admin    — can override reassignment of students who have existing
                    attendance or exam records; implies Officer.
    ══════════════════════════════════════════════════════ -->

    <record id="group_section_assignment_officer" model="res.groups">
        <field name="name">Section Assignment Officer</field>
        <field name="privilege_id" ref="privilege_progression_access"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('group_progression_viewer'))
        ]"/>
        <field name="comment">
            Can open and run the Bulk Section Assignment wizard.
            Cannot reassign students who already have attendance or exam records;
            that requires the Section Assignment Administrator group.
        </field>
    </record>

    <record id="group_section_assignment_admin" model="res.groups">
        <field name="name">Section Assignment Administrator</field>
        <field name="privilege_id" ref="privilege_progression_access"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('group_section_assignment_officer'))
        ]"/>
        <field name="comment">
            Full section assignment authority, including reassignment of students
            who already have attendance or exam records linked to their current section.
            Implies Section Assignment Officer access.
        </field>
    </record>
</odoo>
