<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Batch Promotion Wizard — Form
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_batch_promotion_wizard_form" model="ir.ui.view">
        <field name="name">edu.batch.promotion.wizard.form</field>
        <field name="model">edu.batch.promotion.wizard</field>
        <field name="arch" type="xml">
            <form string="Promote Batch">

                <div class="alert alert-warning mb-2"
                     invisible="active_progression_count != 0"
                     role="alert">
                    <strong>No active student progression records found for this batch.</strong>
                    There are no students to promote. Please verify the batch and its
                    current progression configuration.
                </div>

                <group string="Batch">
                    <field name="batch_id"/>
                    <field name="batch_program_id" readonly="1" string="Program"/>
                    <field name="current_program_term_id" readonly="1"
                           string="Current Progression"/>
                </group>

                <group string="Promote To">
                    <field name="next_program_term_id"
                           options="{'no_create': True, 'no_open': True}"/>
                    <field name="effective_date"/>
                    <field name="new_academic_year_id"
                           options="{'no_create': True, 'no_open': True}"
                           placeholder="Leave blank to use the currently open year"/>
                </group>

                <group string="Section Assignment">
                    <field name="section_mode" widget="radio"/>
                </group>

                <group string="Preview">
                    <field name="active_progression_count"
                           string="Students to be promoted"
                           readonly="1"/>
                </group>

                <footer>
                    <button name="action_promote"
                            string="Promote Batch"
                            type="object"
                            class="btn-primary"
                            invisible="active_progression_count == 0"
                            confirm="This will close all active progression records for this batch and create new ones. This action cannot be undone. Proceed?"/>
                    <button special="cancel"
                            string="Cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
