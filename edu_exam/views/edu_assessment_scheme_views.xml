<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         edu.assessment.scheme — Search View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_assessment_scheme_search" model="ir.ui.view">
        <field name="name">edu.assessment.scheme.search</field>
        <field name="model">edu.assessment.scheme</field>
        <field name="arch" type="xml">
            <search string="Search Assessment Schemes">
                <field name="name"/>
                <field name="code"/>
                <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="filter_inactive" string="Inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.assessment.scheme — List View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_assessment_scheme_list" model="ir.ui.view">
        <field name="name">edu.assessment.scheme.list</field>
        <field name="model">edu.assessment.scheme</field>
        <field name="arch" type="xml">
            <list string="Assessment Schemes">
                <field name="name"/>
                <field name="code"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.assessment.scheme — Form View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_assessment_scheme_form" model="ir.ui.view">
        <field name="name">edu.assessment.scheme.form</field>
        <field name="model">edu.assessment.scheme</field>
        <field name="arch" type="xml">
            <form string="Assessment Scheme">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Scheme Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description..."/>
                    <notebook>
                        <page string="Scheme Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="exam_type"/>
                                    <field name="attempt_type"/>
                                    <field name="weightage_percent"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_assessment_scheme" model="ir.actions.act_window">
        <field name="name">Assessment Schemes</field>
        <field name="res_model">edu.assessment.scheme</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>
</odoo>
