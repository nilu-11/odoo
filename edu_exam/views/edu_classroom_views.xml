<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         edu.classroom form — inject Exam Papers smart button
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_classroom_form_exam_button" model="ir.ui.view">
        <field name="name">edu.classroom.form.exam.button</field>
        <field name="model">edu.classroom</field>
        <field name="inherit_id" ref="edu_classroom.view_edu_classroom_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_exam_papers"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        groups="edu_exam.group_exam_viewer,edu_academic_structure.group_education_admin,edu_academic_structure.group_academic_officer">
                    <field name="exam_paper_count" widget="statinfo" string="Exam Papers"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
