<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         edu.exam.paper.generate.wizard — Form View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_exam_paper_generate_wizard_form" model="ir.ui.view">
        <field name="name">edu.exam.paper.generate.wizard.form</field>
        <field name="model">edu.exam.paper.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Exam Papers">
                <sheet>
                    <group string="Session">
                        <field name="exam_session_id"/>
                        <field name="scope"/>
                        <field name="batch_id" readonly="1"/>
                        <field name="program_term_id" readonly="1"/>
                    </group>
                    <group string="Defaults">
                        <group>
                            <field name="default_max_marks"/>
                            <field name="default_pass_marks"/>
                        </group>
                    </group>

                    <div invisible="not result_summary" class="alert alert-info">
                        <field name="result_summary" readonly="1"/>
                    </div>

                    <separator string="Preview"/>
                    <field name="preview_line_ids">
                        <list editable="bottom">
                            <field name="classroom_id"/>
                            <field name="subject_id" readonly="1"/>
                            <field name="teacher_id"/>
                            <field name="already_exists" readonly="1"/>
                            <field name="will_create"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_load_preview" string="Load Preview"
                            type="object" class="btn-secondary"/>
                    <button name="action_generate" string="Generate Papers"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_edu_exam_paper_generate_wizard" model="ir.actions.act_window">
        <field name="name">Generate Exam Papers</field>
        <field name="res_model">edu.exam.paper.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
