<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         edu.exam.session — Search View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_exam_session_search" model="ir.ui.view">
        <field name="name">edu.exam.session.search</field>
        <field name="model">edu.exam.session</field>
        <field name="arch" type="xml">
            <search string="Search Exam Sessions">
                <field name="name"/>
                <field name="code"/>
                <field name="academic_year_id"/>
                <field name="batch_id"/>
                <field name="program_term_id"/>
                <!-- Filters -->
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_planned" string="Planned" domain="[('state', '=', 'planned')]"/>
                <filter name="filter_ongoing" string="Ongoing" domain="[('state', '=', 'ongoing')]"/>
                <filter name="filter_marks_entry" string="Marks Entry" domain="[('state', '=', 'marks_entry')]"/>
                <filter name="filter_published" string="Published" domain="[('state', '=', 'published')]"/>
                <filter name="filter_closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="filter_regular" string="Regular" domain="[('attempt_type', '=', 'regular')]"/>
                <filter name="filter_back_exams" string="Back/Makeup/Improvement" domain="[('attempt_type', 'in', ('back', 'makeup', 'improvement', 'special'))]"/>
                <!-- Group By -->
                <group name="group_by">
                    <filter name="group_exam_type" string="Exam Type" context="{'group_by': 'exam_type'}"/>
                    <filter name="group_attempt_type" string="Attempt Type" context="{'group_by': 'attempt_type'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_academic_year" string="Academic Year" context="{'group_by': 'academic_year_id'}"/>
                    <filter name="group_batch" string="Batch" context="{'group_by': 'batch_id'}"/>
                    <filter name="group_program_term" string="Program Term" context="{'group_by': 'program_term_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.exam.session — List View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_exam_session_list" model="ir.ui.view">
        <field name="name">edu.exam.session.list</field>
        <field name="model">edu.exam.session</field>
        <field name="arch" type="xml">
            <list string="Exam Sessions" decoration-muted="state == 'cancelled'" decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="code"/>
                <field name="exam_type"/>
                <field name="attempt_type"/>
                <field name="academic_year_id"/>
                <field name="batch_id"/>
                <field name="program_term_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('planned', 'ongoing')"
                       decoration-warning="state == 'marks_entry'"
                       decoration-success="state == 'published'"
                       decoration-muted="state in ('closed', 'cancelled')"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.exam.session — Kanban View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_exam_session_kanban" model="ir.ui.view">
        <field name="name">edu.exam.session.kanban</field>
        <field name="model">edu.exam.session</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <field name="name"/>
                <field name="exam_type"/>
                <field name="attempt_type"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="paper_count"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div class="text-muted">
                                <field name="exam_type"/> /
                                <field name="attempt_type"/>
                            </div>
                            <div>
                                <span><field name="date_start"/> — <field name="date_end"/></span>
                            </div>
                            <div class="mt-1">
                                <span class="badge bg-secondary"><t t-out="record.paper_count.value"/> papers</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.exam.session — Form View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_exam_session_form" model="ir.ui.view">
        <field name="name">edu.exam.session.form</field>
        <field name="model">edu.exam.session</field>
        <field name="arch" type="xml">
            <form string="Exam Session">
                <header>
                    <!-- State action buttons -->
                    <button name="action_plan" string="Plan" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="edu_exam.group_exam_officer,edu_academic_structure.group_education_admin"/>
                    <button name="action_start" string="Start" type="object"
                            class="btn-primary"
                            invisible="state != 'planned'"
                            groups="edu_exam.group_exam_officer,edu_academic_structure.group_education_admin"/>
                    <button name="action_open_marks_entry" string="Open Marks Entry" type="object"
                            class="btn-primary"
                            invisible="state != 'ongoing'"
                            groups="edu_exam.group_exam_officer,edu_academic_structure.group_education_admin"/>
                    <button name="action_publish" string="Publish" type="object"
                            class="btn-primary"
                            invisible="state != 'marks_entry'"
                            groups="edu_exam.group_exam_publish_manager,edu_academic_structure.group_education_admin"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="state != 'published'"
                            groups="edu_exam.group_exam_admin,edu_academic_structure.group_education_admin"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('closed', 'cancelled')"
                            groups="edu_exam.group_exam_officer,edu_academic_structure.group_education_admin"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"
                            groups="edu_exam.group_exam_admin,edu_academic_structure.group_education_admin"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,planned,ongoing,marks_entry,published,closed"/>
                </header>
                <sheet>
                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_papers" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <field name="paper_count" widget="statinfo" string="Papers"/>
                        </button>
                        <button name="action_view_marksheets" type="object"
                                class="oe_stat_button" icon="fa-list-alt">
                            <field name="marksheet_count" widget="statinfo" string="Marksheets"/>
                        </button>
                        <button name="action_generate_papers" type="object"
                                class="oe_stat_button" icon="fa-magic"
                                invisible="state not in ('draft', 'planned')"
                                groups="edu_exam.group_exam_officer,edu_academic_structure.group_education_admin">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Generate Papers</span>
                            </div>
                        </button>
                        <button name="action_generate_marksheets" type="object"
                                class="oe_stat_button" icon="fa-users"
                                invisible="state in ('draft', 'closed', 'cancelled')"
                                groups="edu_exam.group_exam_officer,edu_academic_structure.group_education_admin">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Generate Marksheets</span>
                            </div>
                        </button>
                        <button name="action_print_report_card" type="object"
                                class="oe_stat_button" icon="fa-print"
                                invisible="state in ('draft', 'planned')"
                                groups="edu_exam.group_exam_viewer,edu_exam.group_exam_officer,edu_exam.group_exam_admin,edu_academic_structure.group_education_admin">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Report Card</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Session Name"/>
                        </h1>
                    </div>

                    <notebook>
                        <page string="General" name="general">
                            <group>
                                <group string="Classification">
                                    <field name="code"/>
                                    <field name="exam_type"/>
                                    <field name="attempt_type"/>
                                    <field name="assessment_scheme_id"/>
                                    <field name="assessment_scheme_line_id"
                                           domain="[('scheme_id', '=', assessment_scheme_id)]"/>
                                </group>
                                <group string="Flags">
                                    <field name="is_board_exam"/>
                                    <field name="is_external_exam"/>
                                    <field name="active" invisible="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Academic Scope" name="scope">
                            <group>
                                <group>
                                    <field name="exam_scope"/>
                                    <field name="academic_year_id"/>
                                    <field name="program_id"/>
                                    <field name="batch_id"/>
                                    <field name="program_term_id"/>
                                </group>
                                <group>
                                    <field name="section_ids" widget="many2many_tags"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </group>
                            </group>
                        </page>

                        <page string="Back Exam Config" name="back_exam"
                              invisible="attempt_type == 'regular'">
                            <group>
                                <group>
                                    <field name="based_on_result_session_id"/>
                                    <field name="based_on_exam_session_id"/>
                                </group>
                                <group>
                                    <field name="back_exam_policy_id"/>
                                </group>
                            </group>
                        </page>

                        <page string="Schedule" name="schedule">
                            <group>
                                <group>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                </group>
                            </group>
                            <field name="note" placeholder="Notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Actions
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_exam_session_all" model="ir.actions.act_window">
        <field name="name">Exam Sessions</field>
        <field name="res_model">edu.exam.session</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_regular': 1}</field>
    </record>

    <record id="action_edu_exam_session_back" model="ir.actions.act_window">
        <field name="name">Back Exams</field>
        <field name="res_model">edu.exam.session</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('attempt_type', 'in', ('back', 'makeup', 'improvement', 'special'))]</field>
        <field name="context">{'default_attempt_type': 'back'}</field>
    </record>
</odoo>
