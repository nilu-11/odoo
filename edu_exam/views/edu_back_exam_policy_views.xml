<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         edu.back.exam.policy — Search View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_back_exam_policy_search" model="ir.ui.view">
        <field name="name">edu.back.exam.policy.search</field>
        <field name="model">edu.back.exam.policy</field>
        <field name="arch" type="xml">
            <search string="Search Back Exam Policies">
                <field name="name"/>
                <field name="code"/>
                <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="filter_inactive" string="Inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.back.exam.policy — List View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_back_exam_policy_list" model="ir.ui.view">
        <field name="name">edu.back.exam.policy.list</field>
        <field name="model">edu.back.exam.policy</field>
        <field name="arch" type="xml">
            <list string="Back Exam Policies">
                <field name="name"/>
                <field name="code"/>
                <field name="max_back_attempts"/>
                <field name="max_makeup_attempts"/>
                <field name="max_improvement_attempts"/>
                <field name="allow_back"/>
                <field name="allow_makeup"/>
                <field name="allow_improvement"/>
                <field name="allow_special"/>
                <field name="min_attendance_for_back"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         edu.back.exam.policy — Form View
    ══════════════════════════════════════════════════════ -->
    <record id="view_edu_back_exam_policy_form" model="ir.ui.view">
        <field name="name">edu.back.exam.policy.form</field>
        <field name="model">edu.back.exam.policy</field>
        <field name="arch" type="xml">
            <form string="Back Exam Policy">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Policy Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="code"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Attempt Limits">
                            <field name="max_back_attempts"/>
                            <field name="max_makeup_attempts"/>
                            <field name="max_improvement_attempts"/>
                        </group>
                    </group>
                    <group string="Allowed Attempt Types">
                        <group>
                            <field name="allow_back"/>
                            <field name="allow_makeup"/>
                        </group>
                        <group>
                            <field name="allow_improvement"/>
                            <field name="allow_special"/>
                        </group>
                    </group>
                    <group>
                        <field name="min_attendance_for_back"
                               help="Set to 0 to disable the attendance requirement."/>
                    </group>
                    <field name="description" placeholder="Description..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Action
    ══════════════════════════════════════════════════════ -->
    <record id="action_edu_back_exam_policy" model="ir.actions.act_window">
        <field name="name">Back Exam Policies</field>
        <field name="res_model">edu.back.exam.policy</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>
</odoo>
