<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Privilege
    ══════════════════════════════════════════════════════ -->
    <record id="privilege_exam_access" model="res.groups.privilege">
        <field name="name">Examinations</field>
        <field name="category_id" ref="edu_academic_structure.module_category_education"/>
        <field name="sequence">90</field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Groups
    ══════════════════════════════════════════════════════ -->
    <record id="group_exam_viewer" model="res.groups">
        <field name="name">Viewer</field>
        <field name="privilege_id" ref="privilege_exam_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_exam_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="privilege_id" ref="privilege_exam_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_exam_viewer'))]"/>
    </record>

    <record id="group_exam_officer" model="res.groups">
        <field name="name">Exam Officer</field>
        <field name="privilege_id" ref="privilege_exam_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_exam_teacher'))]"/>
    </record>

    <record id="group_exam_publish_manager" model="res.groups">
        <field name="name">Publish Manager</field>
        <field name="privilege_id" ref="privilege_exam_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_exam_officer'))]"/>
    </record>

    <record id="group_exam_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="privilege_exam_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_exam_publish_manager'))]"/>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Record Rules
    ══════════════════════════════════════════════════════ -->

    <!-- Teacher: sees only papers where they are the teacher -->
    <record id="rule_exam_paper_teacher" model="ir.rule">
        <field name="name">Exam Paper: Teacher sees own papers</field>
        <field name="model_id" ref="model_edu_exam_paper"/>
        <field name="domain_force">[('teacher_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_exam_teacher'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Officer: sees all papers (overrides the teacher rule for higher groups) -->
    <record id="rule_exam_paper_officer" model="ir.rule">
        <field name="name">Exam Paper: Officer sees all</field>
        <field name="model_id" ref="model_edu_exam_paper"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_exam_officer'))]"/>
    </record>

    <!-- Teacher: sees only marksheets for their own papers -->
    <record id="rule_exam_marksheet_teacher" model="ir.rule">
        <field name="name">Marksheet: Teacher sees own paper marksheets</field>
        <field name="model_id" ref="model_edu_exam_marksheet"/>
        <field name="domain_force">[('exam_paper_id.teacher_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_exam_teacher'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Officer: sees all marksheets -->
    <record id="rule_exam_marksheet_officer" model="ir.rule">
        <field name="name">Marksheet: Officer sees all</field>
        <field name="model_id" ref="model_edu_exam_marksheet"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_exam_officer'))]"/>
    </record>
</odoo>
